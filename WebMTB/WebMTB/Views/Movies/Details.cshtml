        padding: 32px;
        border-radius: 30px;
        border: 1px solid rgba(255, 255, 255, 0.09);
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025));
        backdrop-filter: blur(16px);
