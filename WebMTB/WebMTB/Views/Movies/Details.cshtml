        }
    }

    @@media (max-width: 575.98px) {
        .customer-hero {
            height: 50vh;
            min-height: 320px;
        }

        .customer-detail-content {
            margin-top: -60px;
        }

        .customer-info-card {
            padding: 20px;
            border-radius: 22px;
        }

        .customer-title {
            font-size: 2rem;
            letter-spacing: -0.04em;
        }

        .customer-bottom-actions .customer-btn,
        .customer-action-stack .customer-btn {
            width: 100%;
        }

        .play-circle {
            width: 68px;
            height: 68px;
        }

            .play-circle span {
                font-size: 38px;
            }
    }
</style>

@section Scripts {
    @if (hasTrailer)
    {
        <script>
            const videoModal = document.getElementById("videoModal");
            const fullVideoFrame = document.getElementById("fullVideoFrame");
            const fullUrl = "@GetFullVideoUrl(Model.TrailerUrl)";

            if (videoModal && fullVideoFrame) {
                videoModal.addEventListener("show.bs.modal", function () {
                    fullVideoFrame.src = fullUrl;
                });

                videoModal.addEventListener("hide.bs.modal", function () {
                    fullVideoFrame.src = "";
                });
            }
        </script>
    }
}