@model WebMTB.Models.Movie

@{
    ViewData["Title"] = "Chi tiết phim " + Model.Title;

    string displayAge = !string.IsNullOrEmpty(Model.AgeRating)
        ? (Model.AgeRating == "P" || Model.AgeRating == "K" ? Model.AgeRating : "T" + Model.AgeRating)
        : "P";

    string ageClass = displayAge == "P"
        ? "age-green"
        : (displayAge == "K" ? "age-blue" : "age-red");

    string directorText = !string.IsNullOrWhiteSpace(Model.Director) ? Model.Director : "Chưa cập nhật";
    string castText = !string.IsNullOrWhiteSpace(Model.Cast) ? Model.Cast : "Chưa cập nhật";
    string descriptionText = !string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "Chưa có mô tả nội dung cho phim này.";
    bool hasTrailer = !string.IsNullOrWhiteSpace(Model.TrailerUrl);
    bool hasPoster = !string.IsNullOrWhiteSpace(Model.ImageUrl);
    bool hasCover = !string.IsNullOrWhiteSpace(Model.CoverImageUrl);
}

@functions {
    public string GetYoutubeVideoId(string url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";

        if (url.Contains("watch?v="))
        {
            return url.Split("v=")[1].Split("&")[0];
        }

        if (url.Contains("youtu.be/"))
        {
            return url.Split("/").Last().Split("?")[0];
        }

        if (url.Contains("/embed/"))
        {
            return url.Split("/embed/")[1].Split("?")[0];
        }

        return "";
    }

    public string GetBackgroundVideoUrl(string url)
    {
        var videoId = GetYoutubeVideoId(url);
        if (string.IsNullOrEmpty(videoId)) return "";

        return $"https://www.youtube.com/embed/{videoId}?autoplay=1&mute=1&loop=1&playlist={videoId}&controls=0&modestbranding=1&rel=0&showinfo=0";
    }

    public string GetFullVideoUrl(string url)
    {
        var videoId = GetYoutubeVideoId(url);
        if (string.IsNullOrEmpty(videoId)) return "";

        return $"https://www.youtube.com/embed/{videoId}?autoplay=1&controls=1&rel=0";
    }
}

<div class="customer-detail-page">

    <section class="customer-hero">
        @if (hasTrailer)
        {
            <div class="customer-trailer-bg" data-bs-toggle="modal" data-bs-target="#videoModal">
                <iframe src="@GetBackgroundVideoUrl(Model.TrailerUrl)"
                        title="@Model.Title trailer background"
                        frameborder="0"
                        allow="autoplay; encrypted-media"
                        allowfullscreen>
                </iframe>

                <div class="customer-hero-overlay">
                    <div class="trailer-play-hint">
                        <div class="play-circle">
                            <span class="material-symbols-outlined">play_arrow</span>
                        </div>
                        <p>Nhấn để xem trailer</p>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="customer-cover-bg">
                @if (hasCover)
                {
                    <img src="@Model.CoverImageUrl" alt="@Model.Title" />
                }
                else if (hasPoster)
                {
                    <img src="@Model.ImageUrl" alt="@Model.Title" />
                }

                <div class="customer-hero-overlay">
                    <div class="trailer-play-hint show">
                        <div class="play-circle muted">
                            <span class="material-symbols-outlined">movie</span>
                        </div>
                        <p>Chưa có trailer</p>
                    </div>
                </div>
            </div>
        }
    </section>

    <main class="container customer-detail-content">
        <div class="row g-4 g-lg-5">

            <div class="col-lg-3 col-md-4">
                <div class="customer-poster-panel">
                    <div class="customer-poster">
                        @if (hasPoster)
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Title" />
                        }
                        else
                        {
                            <div class="poster-empty">
                                <span class="material-symbols-outlined">image_not_supported</span>
                                <p>Không có poster</p>
                            </div>
                        }

                        <div class="poster-rating">
                            <span class="material-symbols-outlined">star</span>
                            <strong>@Model.Rating</strong>
                        </div>
                    </div>

                    <div class="customer-action-stack">
                        <a asp-controller="Bookings"
                           asp-action="Create"
                           asp-route-movieId="@Model.Id"
                           class="btn customer-btn booking">
                            <span class="material-symbols-outlined">confirmation_number</span>
                            Đặt vé ngay
                        </a>

                        @if (hasTrailer)
                        {
                            <button type="button"
                                    class="btn customer-btn trailer"
                                    data-bs-toggle="modal"
                                    data-bs-target="#videoModal">
                                <span class="material-symbols-outlined">play_circle</span>
                                Xem trailer
                            </button>
                        }

                        <a asp-action="Index" class="btn customer-btn back">
                            <span class="material-symbols-outlined">arrow_back</span>
                            Quay lại
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-9 col-md-8">
                <div class="customer-info-card">

                    <div class="customer-badges">
                        <span class="age-badge @ageClass">@displayAge</span>

                        @if (Model.IsHot)
                        {
                            <span class="movie-badge hot">
                                <span class="material-symbols-outlined">local_fire_department</span>
                                Phim hot
                            </span>
                        }

                        @if (Model.IsActive)
                        {
                            <span class="movie-badge active">
                                <i></i>
                                Đang chiếu
                            </span>
                        }
                        else
                        {
                            <span class="movie-badge inactive">
                                <i></i>
                                Tạm dừng
                            </span>
                        }
                    </div>

                    <h1 class="customer-title">@Model.Title</h1>

                    <div class="customer-meta">
                        <span class="rating-meta">
                            <span class="material-symbols-outlined">star</span>
                            @Model.Rating/10
                        </span>

                        <span>
                            <span class="material-symbols-outlined">schedule</span>
                            @Model.Duration phút
                        </span>

                        <span>
                            <span class="material-symbols-outlined">calendar_month</span>
                            @Model.ReleaseDate.ToString("dd/MM/yyyy")
                        </span>
                    </div>

                    <div class="quick-info-grid">
                        <div class="quick-info-card">
                            <span class="material-symbols-outlined">person</span>
                            <div>
                                <p>Đạo diễn</p>
                                <h6>@directorText</h6>
                            </div>
                        </div>

                        <div class="quick-info-card">
                            <span class="material-symbols-outlined">groups</span>
                            <div>
                                <p>Diễn viên</p>
                                <h6>@castText</h6>
                            </div>
                        </div>

                        <div class="quick-info-card">
                            <span class="material-symbols-outlined">local_movies</span>
                            <div>
                                <p>Định dạng</p>
                                <h6>2D Phụ Đề</h6>
                            </div>
                        </div>
                    </div>

                    <section class="description-card">
                        <div class="section-heading">
                            <span class="material-symbols-outlined">subject</span>
                            <h5>Tóm tắt nội dung</h5>
                        </div>

                        <p>@descriptionText</p>
                    </section>

                </div>
            </div>

        </div>
    </main>
</div>

@if (hasTrailer)
{
    <div class="modal fade" id="videoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content customer-trailer-modal">
                <div class="modal-header">
                    <h5 class="modal-title text-white">
                        Trailer: @Model.Title
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal"
                            aria-label="Close">
                    </button>
                </div>

                <div class="modal-body p-0">
                    <div class="ratio ratio-16x9">
                        <iframe id="fullVideoFrame"
                                src=""
                                title="YouTube video player"
                                frameborder="0"
                                allow="autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen>
                        </iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
