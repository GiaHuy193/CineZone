        margin-bottom: 26px;
    }

    .quick-info-card {
        min-height: 104px;
        padding: 18px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.045);
        border: 1px solid rgba(255, 255, 255, 0.075);
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

        .quick-info-card > span {
            color: #ff5964;
            font-size: 26px;
        }

        .quick-info-card p {
            color: #939393;
            font-size: 0.76rem;
            font-weight: 900;
