        overflow: hidden;
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.65);
    }

        .customer-trailer-modal .modal-header {
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding: 14px 18px;
        }

        .customer-trailer-modal .modal-title {
            font-weight: 800;
