@{
    ViewData["Title"] = "Liên hệ";
}

<section class="cz-info-page">
    <div class="cz-info-wrap">
        <div class="cz-info-hero">
            <span class="cz-info-kicker">
                <span class="material-symbols-outlined">support_agent</span>
                Contact CineZone
            </span>
            <h1>Liên hệ hỗ trợ</h1>
            <p>Cần hỗ trợ đặt vé, thanh toán, chọn ghế hoặc ưu đãi? CineZone luôn sẵn sàng hỗ trợ bạn.</p>
        </div>

        <div class="cz-contact-layout">
            <div class="cz-contact-list">
                <div class="cz-contact-item">
                    <span class="material-symbols-outlined">call</span>
                    <div>
                        <strong>Hotline</strong>
                        <small>0776 683 204</small>
                    </div>
                </div>

                <div class="cz-contact-item">
                    <span class="material-symbols-outlined">mail</span>
                    <div>
                        <strong>Email</strong>
                        <small>maidoangiahuy@gmail.com</small>
                    </div>
                </div>

                <div class="cz-contact-item">
                    <span class="material-symbols-outlined">location_on</span>
                    <div>
                        <strong>Địa chỉ</strong>
                        <small>TP. Hồ Chí Minh, Việt Nam</small>
                    </div>
                </div>
            </div>

            <div class="cz-form-box">
                <div class="row g-3">
                    <div class="col-md-6">
                        <input class="form-control cz-form-control" placeholder="Họ và tên" />
                    </div>

                    <div class="col-md-6">
                        <input class="form-control cz-form-control" placeholder="Email" />
                    </div>

                    <div class="col-12">
                        <input class="form-control cz-form-control" placeholder="Tiêu đề cần hỗ trợ" />
                    </div>

                    <div class="col-12">
                        <textarea class="form-control cz-form-control" rows="5" placeholder="Nội dung liên hệ"></textarea>
                    </div>

                    <div class="col-12">
                        <button type="button" class="cz-submit-btn">Gửi liên hệ</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>