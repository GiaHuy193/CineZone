@model WebMTB.Models.Booking

@{
    ViewData["Title"] = "Vé điện tử - CineZone";

    var tickets = Model.Tickets?.ToList() ?? new List<WebMTB.Models.Ticket>();
    var firstTicket = tickets.FirstOrDefault();

    var showtime = firstTicket?.Showtime;
    var movie = showtime?.Movie;
    var room = showtime?.Room;
    var cinema = room?.Cinema;

    string movieTitle = movie?.Title ?? "Thông tin phim";
    string cinemaName = cinema?.Name ?? "Chưa có rạp";
    string roomName = room?.Name ?? "Chưa có phòng";
    DateTime? expiresAt = Model.ExpiresAt;

    bool isPending = Model.Status == "Pending";
    bool isExpired = Model.Status == "Expired";

    bool isPendingExpired =
        Model.Status == "Pending" &&
        expiresAt.HasValue &&
        expiresAt.Value <= DateTime.Now;

    string statusClass = Model.Status == "Completed" ? "status-success"
        : Model.Status == "Cancelled" || Model.Status == "Expired" ? "status-danger"
        : "status-warning";
}

<div class="booking-detail-page">
    <div class="container py-5">

        <div class="detail-header mb-4">
            <div>
                <div class="detail-eyebrow">
                    <span class="material-symbols-outlined">confirmation_number</span>
                    Booking Confirmation
                </div>

                <h1>Vé điện tử</h1>

                <p>
                    Thông tin vé và hóa đơn đặt vé của bạn.
                </p>
            </div>

            <a asp-controller="Home" asp-action="Index" class="btn back-btn">
                <span class="material-symbols-outlined">arrow_back</span>
                Về trang chủ
            </a>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="detail-card">
                    <div class="detail-card-header">
                        <div>
                            <h5>Thông tin vé</h5>
                            <p>Phim, rạp, suất chiếu và ghế đã chọn.</p>
                        </div>

                        <span class="booking-status @statusClass">
                            @Model.Status
                        </span>
                    </div>

                    <div class="detail-card-body">
                        <div class="movie-summary mb-4">
                            <div class="movie-icon">
                                <span class="material-symbols-outlined">movie</span>
                            </div>

                            <div>
                                <h3>@movieTitle</h3>
                                <p>
                                    @cinemaName · @roomName
                                </p>
                            </div>
                        </div>

                        <div class="info-grid">
                            <div class="info-box">
                                <span class="material-symbols-outlined">calendar_month</span>
                                <div>
                                    <p>Ngày đặt</p>
                                    <h6>@Model.BookingDate.ToString("HH:mm - dd/MM/yyyy")</h6>
                                </div>
                            </div>

                            <div class="info-box">
                                <span class="material-symbols-outlined">schedule</span>
                                <div>
                                    <p>Suất chiếu</p>
                                    <h6>
                                        @(showtime != null ? showtime.StartTime.ToString("HH:mm - dd/MM/yyyy") : "Chưa có suất chiếu")
                                    </h6>
                                </div>
                            </div>

                            <div class="info-box">
                                <span class="material-symbols-outlined">location_on</span>
                                <div>
                                    <p>Rạp chiếu</p>
                                    <h6>@cinemaName</h6>
                                </div>
                            </div>

                            <div class="info-box">
                                <span class="material-symbols-outlined">meeting_room</span>
                                <div>
                                    <p>Phòng chiếu</p>
                                    <h6>@roomName</h6>
                                </div>
                            </div>
                        </div>

                        <div class="seat-section mt-4">
                            <div class="section-title">
                                <span class="material-symbols-outlined">event_seat</span>
                                Ghế đã chọn
                            </div>

                            @if (tickets.Any())
                            {
                                <div class="selected-seat-list">
                                    @foreach (var ticket in tickets.OrderBy(t => t.Seat?.Row).ThenBy(t => t.Seat?.Number))
                                    {
                                        string seatName = ticket.Seat != null ? $"{ticket.Seat.Row}{ticket.Seat.Number}" : "N/A";
                                        string seatType = ticket.Seat?.SeatType ?? "Normal";
                                        string seatTypeClass = seatType.ToLower();

                                        <div class="selected-seat-item @seatTypeClass">
                                            <strong>@seatName</strong>
                                            <span>@seatType</span>
                                            <small>@ticket.Price.ToString("N0") VNĐ</small>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-message">
                                    Chưa có ghế nào trong booking này.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="payment-card">
                    <div class="payment-card-header">
                        <span class="material-symbols-outlined">payments</span>
                        <div>
                            <h5>Thanh toán</h5>
                            <p>Mã đặt vé #@Model.Id</p>
                        </div>
                    </div>

                    <div class="payment-body">
                        <div class="payment-row">
                            <span>Số lượng vé</span>
                            <strong>@tickets.Count</strong>
                        </div>

                        <div class="payment-row">
                            <span>Tổng tiền</span>
                            <strong>@Model.TotalAmount.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="payment-row">
                            <span>Trạng thái</span>
                            <strong class="@statusClass">@Model.Status</strong>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.PayPalTransactionId))
                        {
                            <div class="payment-row">
                                <span>Mã PayPal</span>
                                <strong>@Model.PayPalTransactionId</strong>
                            </div>
                        }

                        @if (Model.Status == "Completed")
                        {
                            <div class="ticket-qr-card">
                                <div class="qr-frame">
                                    <img src="@Url.Action("QrCode", "Bookings", new { id = Model.Id })"
                                         alt="QR Code vé điện tử" />
                                </div>

                                <div class="qr-info">
                                    <h6>Mã QR vé điện tử</h6>
                                    <p>Đưa mã này cho nhân viên rạp để quét và xác minh vé.</p>
                                    <span>CZ-@Model.Id.ToString("D6")</span>
                                </div>
                            </div>
                        }

                        <hr />

                        @if (Model.Status == "Pending")
                        {
                            if (isPendingExpired)
                            {
                                <div class="danger-box">
                                    <span class="material-symbols-outlined">timer_off</span>
                                    Thời gian giữ ghế đã hết. Vui lòng chọn ghế lại.
                                </div>
                            }
                            else
                            {
                                <div class="warning-box countdown-box mb-3">
                                    <span class="material-symbols-outlined">schedule</span>

                                    <div>
                                        <div>Booking đang chờ thanh toán.</div>

                                        @if (expiresAt != null)
                                        {
                                            <strong class="countdown-line">
                                                Thời gian giữ ghế còn:
                                                <span id="holdCountdown" class="countdown-time">--:--</span>
                                            </strong>
                                        }
                                        else
                                        {
                                            <small>Booking này chưa có thời gian hết hạn.</small>
                                        }
                                    </div>
                                </div>

                                <a asp-controller="Bookings"
                                   asp-action="Checkout"
                                   asp-route-id="@Model.Id"
                                   id="continuePaymentButton"
                                   class="btn paypal-btn w-100">
                                    <span class="material-symbols-outlined">payments</span>
                                    Tiếp tục thanh toán
                                </a>

                                <form asp-controller="Bookings"
                                      asp-action="CancelPending"
                                      asp-route-id="@Model.Id"
                                      method="post"
                                      class="mt-3">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn cancel-hold-btn w-100">
                                        <span class="material-symbols-outlined">event_busy</span>
                                        Hủy giữ ghế
                                    </button>
                                </form>

                                <p class="payment-note mt-3">
                                    Ghế chỉ được giữ trong thời gian hiển thị. Hết thời gian, hệ thống sẽ tự nhả ghế.
                                </p>
                            }
                        }
                        else if (Model.Status == "Completed")
                        {
                            <div class="success-box">
                                <span class="material-symbols-outlined">check_circle</span>
                                Vé đã được thanh toán thành công.
                            </div>
                        }
                        else
                        {
                            <div class="danger-box">
                                <span class="material-symbols-outlined">cancel</span>
                                Booking đã bị hủy.
                            </div>
                        }

                        <a asp-action="Index" class="btn outline-btn w-100 mt-3">
                            Xem lịch sử đặt vé
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>



