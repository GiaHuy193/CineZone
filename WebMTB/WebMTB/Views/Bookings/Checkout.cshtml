@model WebMTB.Models.Booking

@{
    ViewData["Title"] = "Thanh toán vé - CineZone";

    var tickets = Model.Tickets?.ToList() ?? new List<WebMTB.Models.Ticket>();
    var firstTicket = tickets.FirstOrDefault();

    var showtime = firstTicket?.Showtime;
    var movie = showtime?.Movie;
    var room = showtime?.Room;
    var cinema = room?.Cinema;

    string movieTitle = movie?.Title ?? "Thông tin phim";
    string cinemaName = cinema?.Name ?? "Chưa có rạp";
    string roomName = room?.Name ?? "Chưa có phòng";
    string cinemaAddress = cinema?.Address ?? "";

    DateTime? expiresAt = Model.ExpiresAt;

    bool isPending = Model.Status == "Pending";
    bool isExpired = Model.Status == "Expired";

    bool isPendingExpired =
        Model.Status == "Pending" &&
        expiresAt.HasValue &&
        expiresAt.Value <= DateTime.Now;

    string statusClass = Model.Status == "Completed" ? "status-success"
        : Model.Status == "Cancelled" || Model.Status == "Expired" ? "status-danger"
        : "status-warning";

    string seatNames = tickets.Any()
        ? string.Join(", ", tickets
            .Where(t => t.Seat != null)
            .OrderBy(t => t.Seat!.Row)
            .ThenBy(t => t.Seat!.Number)
            .Select(t => $"{t.Seat!.Row}{t.Seat!.Number}"))
        : "---";
}

<div class="ticket-detail-page">
    <div class="container py-5">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger rounded-4 border-0 mb-4">
                <span class="material-symbols-outlined align-middle me-1">warning</span>
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-4 border-0 mb-4">
                <span class="material-symbols-outlined align-middle me-1">check_circle</span>
                @TempData["Success"]
            </div>
        }

        <div class="ticket-header mb-4">
            <div>
                <div class="ticket-eyebrow">
                    <span class="material-symbols-outlined">payments</span>
                    CineZone Checkout
                </div>

                <h1>Thanh toán vé</h1>
                <p>Xác nhận thông tin đặt vé trước khi thanh toán.</p>
            </div>

            <div class="header-actions">
                <a asp-action="Index" class="btn outline-btn">
                    <span class="material-symbols-outlined">history</span>
                    Lịch sử vé
                </a>

                @if (Model.Status == "Pending" && !isPendingExpired)
                {
                    <form asp-controller="Bookings"
                          asp-action="CancelPending"
                          asp-route-id="@Model.Id"
                          method="post"
                          onsubmit="return confirm('Bạn muốn rời trang thanh toán và hủy giữ ghế?');">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn back-btn">
                            <span class="material-symbols-outlined">event_busy</span>
                            Hủy và quay lại
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="btn back-btn">
                        <span class="material-symbols-outlined">home</span>
                        Trang chủ
                    </a>
                }
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="ticket-card">
                    <div class="ticket-top">
                        <div>
                            <p>CineZone Ticket</p>
                            <h3>@movieTitle</h3>
                        </div>

                        <span class="ticket-status @statusClass">@Model.Status</span>
                    </div>

                    <div class="ticket-body">
                        <div class="ticket-main-info">
                            <div class="ticket-icon">
                                <span class="material-symbols-outlined">movie</span>
                            </div>

                            <div>
                                <h4>@movieTitle</h4>
                                <p>@cinemaName · @roomName</p>

                                @if (!string.IsNullOrWhiteSpace(cinemaAddress))
                                {
                                    <small>@cinemaAddress</small>
                                }
                            </div>
                        </div>

                        <div class="ticket-grid mt-4">
                            <div class="ticket-info-box">
                                <span class="material-symbols-outlined">confirmation_number</span>
                                <div>
                                    <p>Mã booking</p>
                                    <h6>#@Model.Id</h6>
                                </div>
                            </div>

                            <div class="ticket-info-box">
                                <span class="material-symbols-outlined">event_seat</span>
                                <div>
                                    <p>Ghế</p>
                                    <h6>@seatNames</h6>
                                </div>
                            </div>

                            <div class="ticket-info-box">
                                <span class="material-symbols-outlined">schedule</span>
                                <div>
                                    <p>Suất chiếu</p>
                                    <h6>@(showtime != null ? showtime.StartTime.ToString("HH:mm - dd/MM/yyyy") : "Chưa có suất chiếu")</h6>
                                </div>
                            </div>

                            <div class="ticket-info-box">
                                <span class="material-symbols-outlined">payments</span>
                                <div>
                                    <p>Tổng tiền</p>
                                    <h6>@Model.TotalAmount.ToString("N0") VNĐ</h6>
                                </div>
                            </div>
                        </div>

                        <div class="seat-section mt-4">
                            <div class="section-title">
                                <span class="material-symbols-outlined">event_seat</span>
                                Danh sách vé
                            </div>

                            @if (tickets.Any())
                            {
                                <div class="ticket-seat-list">
                                    @foreach (var ticket in tickets.OrderBy(t => t.Seat?.Row).ThenBy(t => t.Seat?.Number))
                                    {
                                        string seatName = ticket.Seat != null ? $"{ticket.Seat.Row}{ticket.Seat.Number}" : "N/A";
                                        string seatType = ticket.Seat?.SeatType ?? "Normal";

                                        <div class="ticket-seat-item">
                                            <div>
                                                <strong>@seatName</strong>
                                                <span>@seatType</span>
                                            </div>

                                            <small>@ticket.Price.ToString("N0") VNĐ</small>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-message">
                                    Không có ghế trong booking này.
                                </div>
                            }
                        </div>
                    </div>

                    <div class="ticket-bottom">
                        <div>
                            <p>Ngày đặt</p>
                            <strong>@Model.BookingDate.ToString("HH:mm - dd/MM/yyyy")</strong>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.PayPalTransactionId))
                        {
                            <div>
                                <p>Mã PayPal</p>
                                <strong>@Model.PayPalTransactionId</strong>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="invoice-card">
                    <div class="invoice-header">
                        <span class="material-symbols-outlined">receipt_long</span>
                        <div>
                            <h5>Thanh toán</h5>
                            <p>Chọn phương thức thanh toán</p>
                        </div>
                    </div>

                    <div class="invoice-body">
                        <div class="invoice-row">
                            <span>Mã booking</span>
                            <strong>#@Model.Id</strong>
                        </div>

                        <div class="invoice-row">
                            <span>Số lượng vé</span>
                            <strong>@tickets.Count</strong>
                        </div>

                        <div class="invoice-row">
                            <span>Trạng thái</span>
                            <strong class="@statusClass">@Model.Status</strong>
                        </div>

                        <div class="invoice-row total">
                            <span>Tổng tiền</span>
                            <strong>@Model.TotalAmount.ToString("N0") VNĐ</strong>
                        </div>

                        <hr />

                        @if (Model.Status == "Completed")
                        {
                            <div class="success-box">
                                <span class="material-symbols-outlined">check_circle</span>
                                Vé đã thanh toán thành công.
                            </div>

                            <button type="button" onclick="window.print()" class="btn print-btn w-100 mt-3">
                                <span class="material-symbols-outlined">print</span>
                                In vé / hóa đơn
                            </button>
                        }
                        else if (Model.Status == "Pending")
                        {
                            if (isPendingExpired)
                            {
                                <div class="danger-box">
                                    <span class="material-symbols-outlined">timer_off</span>
                                    Thời gian giữ ghế đã hết. Vui lòng chọn ghế lại.
                                </div>

                                <a asp-controller="Home"
                                   asp-action="Index"
                                   class="btn outline-btn w-100 mt-3">
                                    Quay về trang chủ
                                </a>
                            }
                            else
                            {
                                <div class="warning-box countdown-box">
                                    <span class="material-symbols-outlined">schedule</span>

                                    <div>
                                        <div>Vé đang chờ thanh toán.</div>

                                        @if (expiresAt != null)
                                        {
                                            <strong class="countdown-line">
                                                Thời gian giữ ghế còn:
                                                <span id="holdCountdown" class="countdown-time">--:--</span>
                                            </strong>
                                        }
                                        else
                                        {
                                            <small>Booking này chưa có thời gian hết hạn.</small>
                                        }
                                    </div>
                                </div>

                                <a asp-controller="Bookings"
                                   asp-action="PayWithPayPal"
                                   asp-route-id="@Model.Id"
                                   id="paypalButton"
                                   class="btn paypal-btn w-100 mt-3">
                                    <span class="material-symbols-outlined">payments</span>
                                    Thanh toán PayPal
                                </a>

                                <form asp-controller="Bookings"
                                      asp-action="CancelPending"
                                      asp-route-id="@Model.Id"
                                      method="post"
                                      class="mt-3"
                                      onsubmit="return confirm('Bạn có chắc muốn hủy giữ ghế? Các ghế trong booking này sẽ được nhả ra ngay.');">

                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn cancel-hold-btn w-100">
                                        <span class="material-symbols-outlined">event_busy</span>
                                        Hủy giữ ghế
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <div class="danger-box">
                                <span class="material-symbols-outlined">cancel</span>
                                Booking đã bị hủy.
                            </div>
                        }

                        <a asp-action="Index" class="btn outline-btn w-100 mt-3">
                            Xem lịch sử đặt vé
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .ticket-detail-page {
        min-height: 100vh;
        color: #fff;
        background: radial-gradient(circle at top left, rgba(229, 9, 20, 0.14), transparent 32%), #111;
    }

    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
    }

    .ticket-eyebrow {
        color: #ff5964;
        font-size: 0.8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 10px;
    }

    .ticket-header h1 {
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 950;
        letter-spacing: -0.05em;
        margin-bottom: 8px;
    }

    .ticket-header p {
        color: #999;
        margin: 0;
    }

    .header-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .back-btn,
    .outline-btn,
    .print-btn,
    .paypal-btn {
        border-radius: 999px;
        color: #fff;
        font-weight: 850;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 18px;
    }

    .back-btn,
    .outline-btn {
        border: 1px solid rgba(255,255,255,0.16);
        background: rgba(255,255,255,0.06);
    }

        .back-btn:hover,
        .outline-btn:hover {
            color: #fff;
            background: rgba(255,255,255,0.12);
        }

    .ticket-card,
    .invoice-card {
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.09);
        background: rgba(18,18,22,0.92);
        box-shadow: 0 22px 60px rgba(0,0,0,0.34);
        overflow: hidden;
    }

    .ticket-top {
        padding: 24px;
        background: radial-gradient(circle at top left, rgba(229,9,20,0.2), transparent 32%), linear-gradient(135deg, rgba(255,255,255,0.075), rgba(255,255,255,0.018));
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        border-bottom: 1px dashed rgba(255,255,255,0.16);
    }

        .ticket-top p {
            color: #ff5964;
            font-size: 0.76rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .ticket-top h3 {
            font-weight: 950;
            margin: 0;
            letter-spacing: -0.04em;
        }

    .ticket-status {
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 950;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .status-success {
        color: #37d67a;
        background: rgba(25,135,84,0.14);
    }

    .status-warning {
        color: #ffc94a;
        background: rgba(255,193,7,0.12);
    }

    .status-danger {
        color: #ff5964;
        background: rgba(229,9,20,0.14);
    }

    .ticket-body,
    .invoice-body {
        padding: 24px;
    }

    .ticket-main-info {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .ticket-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        background: rgba(229,9,20,0.15);
        color: #ff5964;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .ticket-icon span {
            font-size: 34px;
        }

    .ticket-main-info h4 {
        font-weight: 950;
        margin-bottom: 4px;
    }

    .ticket-main-info p,
    .ticket-main-info small {
        color: #999;
        margin: 0;
    }

    .ticket-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .ticket-info-box {
        padding: 16px;
        border-radius: 18px;
        background: rgba(255,255,255,0.045);
        border: 1px solid rgba(255,255,255,0.075);
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .ticket-info-box > span {
            color: #ff5964;
            font-size: 28px;
        }

        .ticket-info-box p {
            color: #999;
            font-size: 0.78rem;
            font-weight: 800;
            text-transform: uppercase;
            margin: 0 0 4px;
        }

        .ticket-info-box h6 {
            font-weight: 900;
            margin: 0;
        }

    .section-title {
        color: #fff;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
    }

        .section-title span {
            color: #ff5964;
        }

    .ticket-seat-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .ticket-seat-item {
        padding: 14px;
        border-radius: 16px;
        background: rgba(255,255,255,0.045);
        border: 1px solid rgba(255,255,255,0.075);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

        .ticket-seat-item strong {
            display: block;
            font-size: 1.1rem;
            font-weight: 950;
        }

        .ticket-seat-item span {
            color: #999;
            font-size: 0.82rem;
            font-weight: 700;
        }

        .ticket-seat-item small {
            color: #ff5964;
            font-weight: 900;
        }

    .ticket-bottom {
        padding: 20px 24px;
        border-top: 1px dashed rgba(255,255,255,0.16);
        display: flex;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        background: rgba(255,255,255,0.025);
    }

        .ticket-bottom p {
            color: #999;
            font-size: 0.76rem;
            font-weight: 800;
            text-transform: uppercase;
            margin: 0 0 4px;
        }

        .ticket-bottom strong {
            color: #fff;
            word-break: break-all;
        }

    .invoice-card {
        position: sticky;
        top: 90px;
    }

    .invoice-header {
        padding: 22px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        display: flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, rgba(229,9,20,0.12), rgba(255,255,255,0.02));
    }

        .invoice-header > span {
            color: #ff5964;
            font-size: 32px;
        }

        .invoice-header h5 {
            font-weight: 900;
            margin-bottom: 4px;
        }

        .invoice-header p {
            color: #999;
            margin: 0;
            font-size: 0.86rem;
        }

    .invoice-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        gap: 16px;
    }

        .invoice-row span {
            color: #999;
            font-weight: 700;
        }

        .invoice-row strong {
            color: #fff;
            text-align: right;
        }

        .invoice-row.total strong {
            color: #ff5964;
            font-size: 1.18rem;
        }

    .success-box,
    .warning-box,
    .danger-box,
    .empty-message {
        padding: 14px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
    }

    .success-box {
        color: #9ff3bd;
        background: rgba(25,135,84,0.14);
        border: 1px solid rgba(25,135,84,0.22);
    }

    .warning-box {
        color: #ffe4a3;
        background: rgba(255,193,7,0.12);
        border: 1px solid rgba(255,193,7,0.2);
    }

    .danger-box {
        color: #ffb4ba;
        background: rgba(229,9,20,0.14);
        border: 1px solid rgba(229,9,20,0.22);
    }

    .empty-message {
        color: #aaa;
        background: rgba(255,255,255,0.05);
    }

    .print-btn {
        border: none;
        background: linear-gradient(135deg, #ff8a85 0%, #e50914 60%, #a9050d 100%);
        box-shadow: 0 12px 28px rgba(229,9,20,0.28);
    }

        .print-btn:hover {
            color: #fff;
            transform: translateY(-2px);
        }

    .paypal-btn {
        border: none;
        background: linear-gradient(135deg, #0070ba, #003087);
        box-shadow: 0 12px 28px rgba(0,112,186,0.26);
    }

        .paypal-btn:hover {
            color: #fff;
            transform: translateY(-2px);
        }

    @@media (max-width: 991.98px) {
        .ticket-header {
            flex-direction: column;
        }

        .header-actions,
        .back-btn,
        .outline-btn {
            width: 100%;
        }

        .ticket-grid {
            grid-template-columns: 1fr;
        }

        .invoice-card {
            position: static;
        }
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        .ticket-card,
        .ticket-card * {
            visibility: visible;
        }

        .ticket-card {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            box-shadow: none;
            border: 1px solid #ddd;
            color: #000;
            background: #fff;
        }
    }

    .countdown-box {
        align-items: flex-start;
    }

    .countdown-line {
        display: block;
        margin-top: 5px;
        color: #fff;
        font-size: 0.95rem;
    }

    .countdown-time {
        color: #ff5964;
        font-weight: 950;
        font-size: 1.1rem;
    }

    .paypal-btn.disabled,
    .paypal-btn[aria-disabled="true"] {
        opacity: 0.55;
        pointer-events: none;
    }

    .cancel-hold-btn {
        min-height: 48px;
        border-radius: 999px;
        color: #ffb4ba;
        background: rgba(229,9,20,0.12);
        border: 1px solid rgba(229,9,20,0.28);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 950;
        text-transform: uppercase;
    }

        .cancel-hold-btn:hover {
            color: #fff;
            background: rgba(229,9,20,0.25);
        }

</style>

@section Scripts {
    @if (Model.Status == "Pending" && expiresAt != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const countdownEl = document.getElementById("holdCountdown");
                const paypalButton = document.getElementById("paypalButton");

                const expireAt = new Date("@expiresAt.Value.ToString("yyyy-MM-ddTHH:mm:ss")").getTime();

                function updateCountdown() {
                    const now = new Date().getTime();
                    const distance = expireAt - now;

                    if (distance <= 0) {
                        if (countdownEl) {
                            countdownEl.textContent = "00:00";
                        }

                        if (paypalButton) {
                            paypalButton.classList.add("disabled");
                            paypalButton.setAttribute("aria-disabled", "true");
                            paypalButton.removeAttribute("href");
                            paypalButton.innerHTML =
                                '<span class="material-symbols-outlined">timer_off</span> Hết thời gian giữ ghế';
                        }

                        setTimeout(function () {
                            window.location.reload();
                        }, 1200);

                        return;
                    }

                    const minutes = Math.floor(distance / 1000 / 60);
                    const seconds = Math.floor((distance / 1000) % 60);

                    if (countdownEl) {
                        countdownEl.textContent =
                            String(minutes).padStart(2, "0") + ":" +
                            String(seconds).padStart(2, "0");
                    }
                }

                updateCountdown();
                setInterval(updateCountdown, 1000);
            });
        </script>
    }
}