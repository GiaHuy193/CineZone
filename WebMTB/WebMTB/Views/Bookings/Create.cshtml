</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        $(document).ready(function () {
        const pricePerSeat = @pricePerSeat.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const currentShowtimeId = @showtimeId;
        const currentUserId = "@ViewBag.CurrentUserId";
        const MAX_SELECTED_SEATS = 8;

        const $checkoutBtn = $('#checkoutBtn');
        let isSubmittingBooking = false;

        function showSeatWarning(message) {
        alert(message);
        }

        function getSelectedSeatIds() {
        let selectedSeatIds = [];

        $('.seat-checkbox:checked:not(:disabled)').each(function () {
        selectedSeatIds.push($(this).data('seat-id'));
        });

        return selectedSeatIds;
        }

        function updateBookingSummary() {
        let selectedSeatIds = [];
        let selectedSeatNames = [];

        $('.seat-checkbox:checked:not(:disabled)').each(function () {
        selectedSeatIds.push($(this).data('seat-id'));
        selectedSeatNames.push($(this).data('seat-name'));
        });

        const total = selectedSeatIds.length * pricePerSeat;

        $('#display-seats').text(selectedSeatNames.length > 0 ? selectedSeatNames.join(', ') : '---');
        $('#display-total').text(total.toLocaleString('vi-VN') + ' VNĐ');
        $('#hiddenTotalAmount').val(total);
        $('#hiddenSeats').val(selectedSeatIds.join(','));

        $checkoutBtn.prop('disabled', selectedSeatIds.length === 0 || currentShowtimeId <= 0);
        }

        function isCheckboxBlocked($checkbox) {
        const seatId = $checkbox.data('seat-id');
        const $label = $('label[for="seat-' + seatId + '"]');

        return $checkbox.is(':checked') ||
        $label.hasClass('sold') ||
        $label.hasClass('seat-holding') ||
        $checkbox.data('status') === 'Sold' ||
        $checkbox.data('status') === 'Held';
        }

        function hasSingleEmptySeatGap() {
        const rows = {};

        $('.seat-checkbox').each(function () {
        const $checkbox = $(this);
        const seatId = $checkbox.data('seat-id');
        const row = $checkbox.data('grid-row');
        const col = parseInt($checkbox.data('grid-col'));
        const rowName = $checkbox.data('row');
        const number = $checkbox.data('number');

        if (!row || !col) {
        return;
        }

        if (!rows[row]) {
        rows[row] = {};
        }

        rows[row][col] = {
        checkbox: $checkbox,
        seatId: seatId,
        rowName: rowName,
        number: number,
        col: col
        };
        });

        for (const rowKey in rows) {
        const rowSeats = rows[rowKey];

        for (const colKey in rowSeats) {
        const col = parseInt(colKey);
        const currentSeat = rowSeats[col];

        const leftSeat = rowSeats[col - 1];
        const rightSeat = rowSeats[col + 1];

        if (!leftSeat || !rightSeat) {
        continue;
        }

        const currentBlocked = isCheckboxBlocked(currentSeat.checkbox);
        const leftBlocked = isCheckboxBlocked(leftSeat.checkbox);
        const rightBlocked = isCheckboxBlocked(rightSeat.checkbox);

        if (!currentBlocked && leftBlocked && rightBlocked) {
        return {
        invalid: true,
        seatName: `${currentSeat.rowName}${currentSeat.number}`
        };
        }
        }
        }

        return {
        invalid: false,
        seatName: null
        };
        }

        function markSeatHolding(seatId, message) {
        const $checkbox = $("#seat-" + seatId);
        const $seatLabel = $('label[for="seat-' + seatId + '"]');

        if (!$checkbox.length || !$seatLabel.length) {
        return;
        }

        $checkbox.prop("checked", false);
        $checkbox.prop("disabled", true);
        $checkbox.data("status", "Held");

        $seatLabel.removeClass("sold");
        $seatLabel.addClass("seat-holding");
        $seatLabel.attr("title", message || "Ghế đang được người khác giữ");
        }

        function releaseSeatUi(seatId) {
        const $checkbox = $("#seat-" + seatId);
        const $seatLabel = $('label[for="seat-' + seatId + '"]');

        if (!$checkbox.length || !$seatLabel.length) {
        return;
        }

        if (!$seatLabel.hasClass("sold")) {
        $checkbox.prop("checked", false);
        $checkbox.prop("disabled", false);
        $checkbox.data("status", "Available");

        $seatLabel.removeClass("seat-holding");
        $seatLabel.removeAttr("title");
        }
        }

        function markSeatSold(seatId) {
        const $checkbox = $("#seat-" + seatId);
        const $seatLabel = $('label[for="seat-' + seatId + '"]');

        if (!$checkbox.length || !$seatLabel.length) {
        return;
        }

        $checkbox.prop("checked", false);
        $checkbox.prop("disabled", true);
        $checkbox.data("status", "Sold");

        $seatLabel.removeClass("seat-holding");
        $seatLabel.addClass("sold");
        $seatLabel.attr("title", "Ghế đã bán");
        }

        if (currentShowtimeId <= 0) {
        $checkoutBtn.prop('disabled', true);
        updateBookingSummary();
        return;
        }

        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/ticketHub")
        .withAutomaticReconnect()
        .build();

        connection.start()
        .then(function () {
        console.log("SignalR Connected!");
        return connection.invoke("JoinShowtimeRoom", currentShowtimeId);
        })
        .then(function () {
        console.log("Joined showtime room:", currentShowtimeId);
        })
        .catch(function (err) {
        console.error("SignalR Connection Error:", err);
        });

        connection.on("SeatHeld", function (seatId, userId) {
        if (userId === currentUserId) {
        return;
        }

        markSeatHolding(seatId, "Ghế đang được người khác giữ");
        updateBookingSummary();
        });

        connection.on("SeatReleased", function (seatId, userId) {
        if (userId === currentUserId) {
        return;
        }

        releaseSeatUi(seatId);
        updateBookingSummary();
        });

        connection.on("SeatReleasedBatch", function (data) {
        if (!data || !data.seatIds) {
        return;
        }

        data.seatIds.forEach(function (seatId) {
        releaseSeatUi(seatId);
        });

        updateBookingSummary();
        });

        connection.on("SeatSold", function (data) {
        if (!data || !data.seatIds) {
        return;
        }

        data.seatIds.forEach(function (seatId) {
        markSeatSold(seatId);
        });

        updateBookingSummary();
        });

        $('.seat-checkbox').on('change', function () {
        const $checkbox = $(this);
        const seatId = $checkbox.data('seat-id');
        const $seatLabel = $('label[for="seat-' + seatId + '"]');

        if ($checkbox.is(':checked')) {
        const selectedSeatCount = getSelectedSeatIds().length;

        if (selectedSeatCount > MAX_SELECTED_SEATS) {
        $checkbox.prop('checked', false);
        updateBookingSummary();

        showSeatWarning("Bạn chỉ được chọn tối đa 8 ghế trong một lần đặt. Nếu muốn đặt vé nhóm, vui lòng liên hệ rạp để được hỗ trợ.");
        return;
        }

        const gapCheck = hasSingleEmptySeatGap();

        if (gapCheck.invalid) {
        $checkbox.prop('checked', false);
        updateBookingSummary();

        showSeatWarning(`Không được bỏ trống 1 ghế lẻ tại vị trí ${gapCheck.seatName}. Vui lòng chọn liền ghế hoặc đổi vị trí khác.`);
        return;
        }

        if (connection.state !== signalR.HubConnectionState.Connected) {
        $checkbox.prop('checked', false);
        updateBookingSummary();

        showSeatWarning("Kết nối giữ ghế chưa sẵn sàng. Vui lòng thử lại.");
        return;
        }

        $checkbox.prop('disabled', true);

        connection.invoke("HoldSeat", currentShowtimeId, seatId)
        .then(function (result) {
        if (!result || !result.success) {
        $checkbox.prop('checked', false);
        markSeatHolding(seatId, result ? result.message : "Ghế này đang được giữ.");

        showSeatWarning(result ? result.message : "Ghế này không còn khả dụng.");
        } else {
        $checkbox.prop('disabled', false);
        $checkbox.data("status", "Available");

        $seatLabel.removeClass("seat-holding");
        $seatLabel.removeAttr("title");
        }

        updateBookingSummary();
        })
        .catch(function (err) {
        console.error(err);

        $checkbox.prop('checked', false);
        $checkbox.prop('disabled', false);

        updateBookingSummary();

        showSeatWarning("Có lỗi khi giữ ghế. Vui lòng thử lại.");
        });
        } else {
        const gapCheck = hasSingleEmptySeatGap();

        if (gapCheck.invalid) {
        $checkbox.prop('checked', true);
        updateBookingSummary();

        showSeatWarning(`Không được bỏ trống 1 ghế lẻ tại vị trí ${gapCheck.seatName}. Vui lòng bỏ chọn ghế ngoài cùng trước.`);
        return;
        }

        if (connection.state === signalR.HubConnectionState.Connected) {
        connection.invoke("ReleaseSeat", currentShowtimeId, seatId)
        .catch(function (err) {
        console.error(err);
        });
        }

        updateBookingSummary();
        }
        });

        $('#bookingForm').on('submit', function (e) {
        updateBookingSummary();

        const selectedSeatIds = getSelectedSeatIds();

        if (currentShowtimeId <= 0) {
        e.preventDefault();
        showSeatWarning("Vui lòng chọn suất chiếu trước.");
        return false;
        }

        if (selectedSeatIds.length === 0) {
        e.preventDefault();
        showSeatWarning("Vui lòng chọn ít nhất một ghế.");
        return false;
        }

        if (selectedSeatIds.length > MAX_SELECTED_SEATS) {
        e.preventDefault();
        showSeatWarning("Bạn chỉ được chọn tối đa 8 ghế trong một lần đặt.");
        return false;
        }

        const gapCheck = hasSingleEmptySeatGap();

        if (gapCheck.invalid) {
        e.preventDefault();
        showSeatWarning(`Không được bỏ trống 1 ghế lẻ tại vị trí ${gapCheck.seatName}.`);
        return false;
        }

        isSubmittingBooking = true;

        $checkoutBtn.prop('disabled', true);
        $checkoutBtn.html('<span class="material-symbols-outlined">hourglass_top</span> Đang xử lý...');
        });

        window.addEventListener("beforeunload", function () {
        if (isSubmittingBooking) {
        return;
        }

        $('.seat-checkbox:checked:not(:disabled)').each(function () {
        const seatId = $(this).data('seat-id');

        if (connection.state === signalR.HubConnectionState.Connected) {
        connection.invoke("ReleaseSeat", currentShowtimeId, seatId)
        .catch(function () { });
        }
        });
        });

        window.addEventListener("pageshow", function (event) {
        const navEntries = performance.getEntriesByType("navigation");
        const navType = navEntries.length > 0 ? navEntries[0].type : "";

        if (event.persisted || navType === "back_forward") {
        window.location.reload();
        }
        });

        updateBookingSummary();
        });
    </script>
}