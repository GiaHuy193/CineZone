@model WebMTB.Models.Booking

@{
    ViewData["Title"] = "Đặt vé - " + ViewBag.MovieTitle;

    string movieTitle = ViewBag.MovieTitle ?? "Tên phim";
    string movieImage = ViewBag.MovieImage ?? "";
    string ageRating = ViewBag.AgeRating ?? "P";

    string displayAge = ageRating == "P" || ageRating == "K"
        ? ageRating
        : "T" + ageRating;

    string ageClass = displayAge == "P"
        ? "age-green"
        : (displayAge == "K" ? "age-blue" : "age-red");

    var seats = ViewBag.Seats as List<WebMTB.Models.Seat> ?? new List<WebMTB.Models.Seat>();
    var soldSeatIds = ViewBag.SoldSeatIds as List<int> ?? new List<int>();
    var heldSeatIds = ViewBag.HeldSeatIds as List<int> ?? new List<int>();

    int showtimeId = ViewBag.ShowtimeId ?? 0;
    var showtime = ViewBag.Showtime as WebMTB.Models.Showtime;
    decimal pricePerSeat = showtime?.BasePrice ?? 0;

    var showtimes = ViewBag.Showtimes as List<WebMTB.Models.Showtime> ?? new List<WebMTB.Models.Showtime>();

    string cinemaName = showtime?.Room?.Cinema?.Name ?? "Chưa chọn rạp";
    string cinemaAddress = showtime?.Room?.Cinema?.Address ?? "";
    string roomName = showtime?.Room?.Name ?? "Chưa chọn phòng";

    var weekDates = ViewBag.WeekDates as List<DateTime>
        ?? Enumerable.Range(0, 7).Select(i => DateTime.Today.AddDays(i)).ToList();

    DateTime selectedDate = ViewBag.SelectedDate is DateTime d
        ? d.Date
        : DateTime.Today;

    var viCulture = new System.Globalization.CultureInfo("vi-VN");

    var cinemaGroups = showtimes
        .GroupBy(s => new
        {
            CinemaId = s.Room?.Cinema?.Id ?? 0,
            CinemaName = s.Room?.Cinema?.Name ?? "Chưa có rạp",
            CinemaAddress = s.Room?.Cinema?.Address ?? ""
        })
        .OrderBy(g => g.Key.CinemaName)
        .ToList();
}

<div class="booking-page">
    <div class="container-fluid px-4 px-lg-5 py-4">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 rounded-4 mb-4" role="alert"
                 style="background: rgba(229, 9, 20, 0.15); color: #ffb4ba;">
                <span class="material-symbols-outlined align-middle me-1">warning</span>
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 rounded-4 mb-4" role="alert"
                 style="background: rgba(25, 135, 84, 0.15); color: #b7ffd2;">
                <span class="material-symbols-outlined align-middle me-1">check_circle</span>
                @TempData["Success"]
            </div>
        }

        <div class="booking-hero mb-4">
            <div class="booking-movie-info">
                <div class="booking-poster">
                    @if (!string.IsNullOrWhiteSpace(movieImage))
                    {
                        <img src="@movieImage" alt="@movieTitle" />
                    }
                    else
                    {
                        <div class="poster-empty">
                            <span class="material-symbols-outlined">image_not_supported</span>
                        </div>
                    }
                </div>

                <div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="material-symbols-outlined text-danger">confirmation_number</span>
                        <span class="booking-eyebrow">Ticket Booking</span>
                    </div>

                    <h1 class="booking-title">@movieTitle</h1>

                    <p class="booking-subtitle mb-3">
                        Chọn ngày, rạp, suất chiếu và vị trí ghế yêu thích.
                    </p>

                    <div class="booking-badges">
                        @if (ViewBag.MovieGenres != null)
                        {
                            foreach (var mg in (IEnumerable<WebMTB.Models.MovieGenre>)ViewBag.MovieGenres)
                            {
                                <span class="movie-genre-badge">
                                    @mg.Genre?.Name
                                </span>
                            }
                        }
                        else
                        {
                            <span class="movie-genre-badge">Phim</span>
                        }

                        <span class="age-badge @ageClass">@displayAge</span>
                    </div>
                </div>
            </div>

            <a asp-controller="Home" asp-action="Index" class="btn booking-back-btn">
                <span class="material-symbols-outlined">arrow_back</span>
                Quay lại
            </a>
        </div>

        <form asp-action="Create" id="bookingForm" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" name="movieId" value="@ViewBag.MovieId" />
            <input type="hidden" name="showtimeId" value="@showtimeId" />
            <input type="hidden" name="selectedSeatIds" id="hiddenSeats" value="" />
            <input type="hidden" id="hiddenTotalAmount" value="0" />

            <div class="booking-flow">

                <div class="booking-card mb-4">
                    <div class="booking-card-header">
                        <div>
                            <h5>1. Chọn ngày chiếu</h5>
                            <p>Chọn ngày bạn muốn xem phim trong 7 ngày tới.</p>
                        </div>
                        <span class="material-symbols-outlined">calendar_month</span>
                    </div>

                    <div class="booking-card-body">
                        <div class="week-date-tabs horizontal-date-tabs">
                            @foreach (var day in weekDates)
                            {
                                bool isSelectedDay = day.Date == selectedDate.Date;
                                int showtimeCount = showtimes.Count(s => s.StartTime.Date == day.Date);

                                string dayLabel = day.Date == DateTime.Today
                                    ? "Hôm nay"
                                    : viCulture.TextInfo.ToTitleCase(day.ToString("dddd", viCulture));

                                <a asp-action="Create"
                                   asp-route-movieId="@ViewBag.MovieId"
                                   asp-route-selectedDate="@day.ToString("yyyy-MM-dd")"
                                   class="date-tab @(isSelectedDay ? "active" : "")">

                                    <span>@dayLabel</span>
                                    <strong>@day.ToString("dd/MM")</strong>

                                    @if (showtimeCount > 0)
                                    {
                                        <small>@showtimeCount suất</small>
                                    }
                                    else
                                    {
                                        <small>Không có</small>
                                    }
                                </a>
                            }
                        </div>
                    </div>
                </div>

                <div class="booking-card mb-4">
                    <div class="booking-card-header">
                        <div>
                            <h5>2. Chọn rạp và suất chiếu</h5>
                            <p>Chọn rạp, phòng chiếu và giờ chiếu phù hợp.</p>
                        </div>
                        <span class="material-symbols-outlined">theaters</span>
                    </div>

                    <div class="booking-card-body">
                        <div class="cinema-showtime-grid">
                            @if (cinemaGroups.Any())
                            {
                                foreach (var cinemaGroup in cinemaGroups)
                                {
                                    var dayShowtimes = cinemaGroup
                                        .Where(s => s.StartTime.Date == selectedDate.Date)
                                        .OrderBy(s => s.Room?.Name)
                                        .ThenBy(s => s.StartTime)
                                        .ToList();

                                    <div class="cinema-schedule-card">
                                        <div class="cinema-schedule-header">
                                            <div class="cinema-schedule-icon">
                                                <span class="material-symbols-outlined">location_on</span>
                                            </div>

                                            <div>
                                                <h6>@cinemaGroup.Key.CinemaName</h6>

                                                @if (!string.IsNullOrWhiteSpace(cinemaGroup.Key.CinemaAddress))
                                                {
                                                    <p>@cinemaGroup.Key.CinemaAddress</p>
                                                }
                                                else
                                                {
                                                    <p>Chưa cập nhật địa chỉ</p>
                                                }
                                            </div>
                                        </div>

                                        @if (dayShowtimes.Any())
                                        {
                                            var roomGroups = dayShowtimes
                                                .GroupBy(s => new
                                                {
                                                    RoomId = s.Room?.Id ?? 0,
                                                    RoomName = s.Room?.Name ?? "Chưa có phòng"
                                                })
                                                .OrderBy(g => g.Key.RoomName)
                                                .ToList();

                                            foreach (var roomGroup in roomGroups)
                                            {
                                                <div class="room-showtime-group">
                                                    <div class="room-label">
                                                        <span class="material-symbols-outlined">meeting_room</span>
                                                        @roomGroup.Key.RoomName · 2D Phụ Đề
                                                    </div>

                                                    <div class="time-chip-list">
                                                        @foreach (var item in roomGroup)
                                                        {
                                                            bool isActive = item.Id == showtimeId;

                                                            <a asp-action="Create"
                                                               asp-route-movieId="@ViewBag.MovieId"
                                                               asp-route-selectedDate="@selectedDate.ToString("yyyy-MM-dd")"
                                                               asp-route-showtimeId="@item.Id"
                                                               class="time-chip @(isActive ? "active" : "")">

                                                                <strong>@item.StartTime.ToString("HH:mm")</strong>
                                                                <small>@item.BasePrice.ToString("N0")đ</small>
                                                            </a>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="no-showtime-box">
                                                <span class="material-symbols-outlined">event_busy</span>
                                                Không có lịch chiếu trong ngày này.
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="no-showtime-box">
                                    <span class="material-symbols-outlined">event_busy</span>
                                    Phim này chưa có lịch chiếu trong 7 ngày tới.
                                </div>
                            }
                        </div>

                        <div class="booking-note mt-4">
                            <span class="material-symbols-outlined">info</span>
                            <p>
                                @if (showtime != null)
                                {
                                    <span>
                                        Suất đang chọn:
                                        <strong>@cinemaName · @roomName · @showtime.StartTime.ToString("HH:mm - dd/MM/yyyy")</strong>.
                                        Giá vé: <strong>@pricePerSeat.ToString("N0") VNĐ / ghế</strong>.
                                    </span>
                                }
                                else
                                {
                                    <span>
                                        Vui lòng chọn ngày và suất chiếu để tiếp tục chọn ghế.
                                    </span>
                                }
                            </p>
                        </div>
                    </div>
                </div>

                <div class="booking-card mb-4">
                    <div class="booking-card-header">
                        <div>
                            <h5>3. Chọn ghế</h5>
                            <p>Chọn vị trí ngồi yêu thích của bạn.</p>
                        </div>
                        <span class="material-symbols-outlined">event_seat</span>
                    </div>

                    <div class="booking-card-body seat-area">
                        @if (showtime == null)
                        {
                            <div class="empty-step-box">
                                <span class="material-symbols-outlined">event_busy</span>
                                <h5>Chưa có suất chiếu trong ngày này</h5>
                                <p>Vui lòng chọn ngày khác hoặc rạp khác có lịch chiếu.</p>
                            </div>
                        }
                        else
                        {
                            <div class="screen-wrap">
                                <div class="screen-glow"></div>
                                <div class="screen-line"></div>
                                <span>Màn hình</span>
                            </div>

                            <div class="seat-map">
                                @if (seats.Any())
                                {
                                    int maxRow = seats.Max(s => s.GridRow);
                                    int maxCol = seats.Max(s => s.GridColumn);

                                    for (int r = 1; r <= maxRow; r++)
                                    {
                                        var rowSeats = seats.Where(s => s.GridRow == r).ToList();
                                        string rowName = rowSeats.FirstOrDefault()?.Row ?? "";

                                        <div class="seat-row">
                                            <span class="row-label">@rowName</span>

                                            @for (int c = 1; c <= maxCol; c++)
                                            {
                                                var seat = seats.FirstOrDefault(s => s.GridRow == r && s.GridColumn == c);

                                                if (seat == null)
                                                {
                                                    <div class="seat-empty-space"></div>
                                                }
                                                else
                                                {
                                                    bool isSold = soldSeatIds.Contains(seat.Id);
                                                    bool isHeld = heldSeatIds.Contains(seat.Id);
                                                    bool isDisabled = isSold || isHeld;

                                                    string seatName = $"{seat.Row}{seat.Number}";
                                                    string seatTypeClass = seat.SeatType?.ToLower() ?? "normal";

                                                    <input type="checkbox"
                                                           class="seat-checkbox d-none"
                                                           id="seat-@seat.Id"
                                                           data-seat-id="@seat.Id"
                                                           data-seat-name="@seatName"
                                                           data-row="@seat.Row"
                                                           data-number="@seat.Number"
                                                           data-grid-row="@seat.GridRow"
                                                           data-grid-col="@seat.GridColumn"
                                                           data-status="@(isSold ? "Sold" : (isHeld ? "Held" : "Available"))"
                                                    @(isDisabled ? "disabled" : "") />

                                                    <label for="seat-@seat.Id"
                                                           class="seat-label @seatTypeClass @(isSold ? "sold" : "") @(isHeld ? "seat-holding" : "")"
                                                           data-seat-id="@seat.Id"
                                                           data-seat-name="@seatName"
                                                           data-row="@seat.Row"
                                                           data-number="@seat.Number"
                                                           data-grid-row="@seat.GridRow"
                                                           data-grid-col="@seat.GridColumn">
                                                        @seat.Number
                                                    </label>
                                                }
                                            }

                                            <span class="row-label">@rowName</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="empty-step-box">
                                        <span class="material-symbols-outlined">event_seat</span>
                                        <h5>Chưa có ghế trong phòng chiếu này</h5>
                                        <p>Admin cần tạo sơ đồ ghế cho phòng chiếu.</p>
                                    </div>
                                }
                            </div>

                            <div class="seat-legend-wrap">
                                <div class="legend-item">
                                    <span class="seat-legend available"></span>
                                    <p>Ghế thường</p>
                                </div>

                                <div class="legend-item">
                                    <span class="seat-legend vip"></span>
                                    <p>VIP</p>
                                </div>

                                <div class="legend-item">
                                    <span class="seat-legend couple"></span>
                                    <p>Ghế đôi</p>
                                </div>

                                <div class="legend-item">
                                    <span class="seat-legend selected"></span>
                                    <p>Đang chọn</p>
                                </div>

                                <div class="legend-item">
                                    <span class="seat-legend holding"></span>
                                    <p>Đang giữ</p>
                                </div>

                                <div class="legend-item">
                                    <span class="seat-legend sold"></span>
                                    <p>Đã bán</p>
                                </div>

                                <div class="legend-item">
                                    <span class="seat-legend empty"></span>
                                    <p>Lối đi</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="booking-card mb-4">
                    <div class="booking-card-header">
                        <div>
                            <h5>4. Combo bắp nước</h5>
                            <p>Phần này có thể phát triển thêm sau để bán kèm combo.</p>
                        </div>
                        <span class="material-symbols-outlined">local_drink</span>
                    </div>

                    <div class="booking-card-body">
                        <div class="combo-coming-box">
                            <span class="material-symbols-outlined">fastfood</span>
                            <div>
                                <h5>Combo bắp nước sẽ được bổ sung sau</h5>
                                <p>
                                    Sau này bạn có thể thêm combo bắp nước, voucher, điểm thành viên
                                    trước khi người dùng chuyển qua thanh toán.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="booking-checkout-bar">
                <div class="container-fluid px-4 px-lg-5">
                    <div class="checkout-inner">
                        <div class="checkout-left">
                            <div>
                                <p>Ghế đã chọn</p>
                                <h5 id="display-seats">---</h5>
                            </div>
                        </div>

                        <div class="checkout-right">
                            <div class="checkout-total">
                                <p>Tạm tính</p>
                                <h4 id="display-total">0 VNĐ</h4>
                            </div>

                            <button type="submit" class="btn checkout-btn" id="checkoutBtn" disabled>
                                <span class="material-symbols-outlined">payments</span>
                                Thanh toán
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>
</div>

<style>
    body {
        padding-bottom: 118px;
    }

    .booking-page {
        min-height: 100vh;
        color: #fff;
        background: radial-gradient(circle at top left, rgba(229, 9, 20, 0.16), transparent 30%), radial-gradient(circle at top right, rgba(229, 9, 20, 0.08), transparent 24%), #131313;
    }

    .booking-hero {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 26px;
        padding: 24px;
        background: radial-gradient(circle at top left, rgba(229, 9, 20, 0.24), transparent 34%), linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
    }

        .booking-hero::after {
            content: "";
            position: absolute;
            top: -90px;
            right: -80px;
            width: 240px;
            height: 240px;
            border-radius: 999px;
            background: rgba(229, 9, 20, 0.16);
            filter: blur(12px);
            pointer-events: none;
        }

    .booking-movie-info {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .booking-poster {
        width: 96px;
        height: 140px;
        border-radius: 18px;
        overflow: hidden;
        background: #222;
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 16px 38px rgba(0, 0, 0, 0.38);
        flex-shrink: 0;
    }

        .booking-poster img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .poster-empty {
        width: 100%;
        height: 100%;
        color: #777;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .poster-empty span {
            font-size: 34px;
        }

    .booking-eyebrow {
        color: #ff6b73;
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1.4px;
    }

    .booking-title {
        color: #fff;
        font-size: clamp(1.8rem, 4vw, 3.2rem);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -0.055em;
        margin-bottom: 8px;
    }

    .booking-subtitle {
        color: #a7a7a7;
        font-size: 0.95rem;
    }

    .booking-badges {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

    .movie-genre-badge,
    .age-badge {
        min-height: 28px;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 0.74rem;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        border: 1px solid currentColor;
    }

    .movie-genre-badge {
        color: #ff5964;
        background: rgba(229, 9, 20, 0.13);
    }

    .age-green {
        color: #37d67a;
        background: rgba(25, 135, 84, 0.12);
    }

    .age-blue {
        color: #49c7ff;
        background: rgba(13, 202, 240, 0.12);
    }

    .age-red {
        color: #ff5b66;
        background: rgba(229, 9, 20, 0.14);
    }

    .booking-back-btn {
        position: relative;
        z-index: 2;
        min-height: 44px;
        padding: 0 18px;
        border-radius: 999px;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
        white-space: nowrap;
    }

        .booking-back-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.12);
            transform: translateY(-2px);
        }

    .booking-flow {
        display: block;
    }

    .booking-card {
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(18, 18, 22, 0.88);
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
    }

    .booking-card-header {
        padding: 20px 22px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.015));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

        .booking-card-header h5 {
            color: #fff;
            font-weight: 900;
            letter-spacing: -0.02em;
            margin-bottom: 4px;
        }

        .booking-card-header p {
            color: #929292;
            font-size: 0.85rem;
            margin: 0;
        }

        .booking-card-header > span {
            color: #ff5964;
            font-size: 30px;
        }

    .booking-card-body {
        padding: 22px;
    }

    .horizontal-date-tabs {
        display: grid;
        grid-template-columns: repeat(7, minmax(130px, 1fr));
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 6px;
    }

    .date-tab {
        min-height: 88px;
        padding: 13px 12px;
        border-radius: 18px;
        color: #ddd;
        text-decoration: none;
        background: rgba(255,255,255,0.055);
        border: 1px solid rgba(255,255,255,0.08);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 4px;
        text-align: center;
    }

        .date-tab:hover {
            color: #fff;
            background: rgba(229,9,20,0.14);
            border-color: rgba(229,9,20,0.32);
        }

        .date-tab.active {
            color: #fff;
            background: linear-gradient(135deg, rgba(229,9,20,0.78), rgba(105,9,18,0.94));
            border-color: rgba(229,9,20,0.72);
            box-shadow: 0 12px 26px rgba(229,9,20,0.22);
        }

        .date-tab span {
            font-size: 0.76rem;
            font-weight: 950;
            text-transform: uppercase;
        }

        .date-tab strong {
            font-size: 1.05rem;
            font-weight: 950;
        }

        .date-tab small {
            color: rgba(255,255,255,0.72);
            font-size: 0.72rem;
            font-weight: 800;
        }

    .cinema-showtime-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .cinema-schedule-card {
        padding: 18px;
        border-radius: 22px;
        background: rgba(255,255,255,0.045);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .cinema-schedule-header {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding-bottom: 14px;
        margin-bottom: 14px;
