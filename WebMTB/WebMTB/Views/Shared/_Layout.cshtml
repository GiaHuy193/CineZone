                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">
                        CineZone
                    </a>

                    <p class="cz-footer-desc">
                        CineZone giúp bạn xem lịch chiếu, chọn ghế, đặt vé và quản lý vé xem phim
                        nhanh chóng trên một nền tảng trực tuyến hiện đại.
                    </p>

                    <div class="cz-footer-badges">
                        <span class="cz-footer-badge">
