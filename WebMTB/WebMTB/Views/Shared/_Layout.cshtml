                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Cinemas"
                               asp-action="Index">
                                Cụm rạp
                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Promotions"
                               asp-action="Index">
                                Khuyến mãi
                            </a>
