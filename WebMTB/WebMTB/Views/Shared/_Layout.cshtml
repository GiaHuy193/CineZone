                    </ul>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h6 class="cz-footer-title">Hỗ trợ</h6>

                    <ul class="cz-footer-list">
                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Policy"
                               asp-action="BookingGuide">
                                Hướng dẫn đặt vé
                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Policy"
                               asp-action="Payment">
                                Thanh toán & hoàn tiền
                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Policy"
                               asp-action="FAQ">
                                Câu hỏi thường gặp
                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Contact"
                               asp-action="Index">
                                Liên hệ hỗ trợ
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h6 class="cz-footer-title">Chính sách</h6>

                    <ul class="cz-footer-list">
                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Policy"
                               asp-action="Terms">
                                Điều khoản sử dụng
                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Policy"
                               asp-action="Privacy">
                                Bảo mật thông tin
                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Policy"
                               asp-action="Member">
                                Ưu đãi thành viên
                            </a>
                        </li>

                        <li>
                            <a class="cz-footer-link"
                               asp-area=""
                               asp-controller="Policy"
                               asp-action="CinemaRules">
                                Quy định rạp chiếu
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h6 class="cz-footer-title">Liên hệ</h6>

                    <div class="cz-footer-contact">
                        <div class="cz-footer-contact-item">
                            <span class="material-symbols-outlined">call</span>
                            <div>
                                Hotline<br />
                                <strong class="text-white">0776 683 204</strong>
                            </div>
                        </div>

                        <div class="cz-footer-contact-item">
                            <span class="material-symbols-outlined">mail</span>
                            <div>
                                Email<br />
                                <strong class="text-white">maidoangiahuy@gmail.com</strong>
                            </div>
                        </div>

                        <div class="cz-footer-contact-item">
                            <span class="material-symbols-outlined">location_on</span>
                            <div>
                                TP. Hồ Chí Minh,<br />
                                Việt Nam
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container-fluid px-4 px-lg-5 cz-footer-bottom">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <p>© 2026 CineZone. Hệ thống đặt vé xem phim trực tuyến.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>