<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineZone</title>

    <!-- Fonts & icons -->
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&family=Manrope:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Bootstrap and site styles -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/cine-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebMTB.styles.css" asp-append-version="true" />

    <style>
            :root {
                --cz-red: #e50914;
                --cz-red-2: #ff5964;
                --cz-bg: #0b0b0d;
                --cz-surface: #121216;
                --cz-border: rgba(255,255,255,0.10);
                --cz-muted: #9b9ba3;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'Manrope', sans-serif;
                background: var(--cz-bg);
                color: #fff;
                overflow-x: hidden;
            }

            .brand-font {
                font-family: 'Be Vietnam Pro', sans-serif;
            }

            /* =========================
                       HEADER
                    ========================= */

            .cz-navbar {
                background: rgba(8, 8, 10, 0.90);
                backdrop-filter: blur(18px);
                -webkit-backdrop-filter: blur(18px);
                border-bottom: 1px solid rgba(255,255,255,0.08);
                box-shadow: 0 12px 34px rgba(0,0,0,0.35);
            }

                .cz-navbar::before {
                    content: "";
                    position: absolute;
                    left: 0;
                    right: 0;
                    bottom: -1px;
                    height: 1px;
                    background: linear-gradient(90deg, transparent, rgba(229,9,20,0.65), transparent);
                    opacity: 0.65;
                }

            .cz-logo {
                color: var(--cz-red) !important;
                font-family: 'Be Vietnam Pro', sans-serif;
                font-weight: 950;
                font-style: italic;
                letter-spacing: -0.07em;
                text-decoration: none;
                text-shadow: 0 0 18px rgba(229,9,20,0.30), 0 0 34px rgba(229,9,20,0.16);
                transition: 0.22s ease;
            }

                .cz-logo:hover {
                    color: #ff2632 !important;
                    transform: translateY(-1px) scale(1.02);
                    text-shadow: 0 0 22px rgba(229,9,20,0.55), 0 0 48px rgba(229,9,20,0.25);
                }

            .cz-nav-link {
                min-height: 42px;
                padding: 0 16px !important;
                border-radius: 999px;
                color: #b8b8be !important;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                font-weight: 850;
                transition: 0.22s ease;
                border: 1px solid transparent;
            }

                .cz-nav-link:hover {
                    color: #fff !important;
                    background: rgba(255,255,255,0.065);
                    border-color: rgba(255,255,255,0.08);
                    transform: translateY(-1px);
                }

                .cz-nav-link.active {
                    color: #fff !important;
                    background: rgba(229,9,20,0.18);
                    border-color: rgba(229,9,20,0.48);
                    box-shadow: inset 0 -2px 0 var(--cz-red), 0 0 22px rgba(229,9,20,0.12);
                }

            .cz-dropdown {
                border-radius: 20px;
                padding: 10px;
                background: rgba(18,18,22,0.98);
                border: 1px solid rgba(255,255,255,0.11);
                box-shadow: 0 20px 48px rgba(0,0,0,0.45);
                min-width: 255px;
            }

                .cz-dropdown .dropdown-item {
                    color: #cfcfd5;
                    border-radius: 14px;
                    padding: 11px 14px;
                    font-weight: 760;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    transition: 0.2s ease;
                }

                    .cz-dropdown .dropdown-item span {
                        color: var(--cz-red-2);
                        font-size: 20px;
                    }

                    .cz-dropdown .dropdown-item:hover {
                        color: #fff;
                        background: rgba(229,9,20,0.18);
                    }

                .cz-dropdown .dropdown-divider {
                    border-color: rgba(255,255,255,0.08);
                }

            .page-wrapper {
                min-height: calc(100vh - 360px);
            }

            /* =========================
                       FOOTER
                    ========================= */

            .cz-footer {
                position: relative;
                overflow: hidden;
                background: radial-gradient(circle at 10% 8%, rgba(229,9,20,0.16), transparent 28%), radial-gradient(circle at 86% 18%, rgba(255,89,100,0.08), transparent 30%), linear-gradient(180deg, #101014 0%, #070708 100%);
                border-top: 1px solid rgba(255,255,255,0.09);
            }

                .cz-footer::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    pointer-events: none;
                    opacity: 0.22;
                    background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
                    background-size: 48px 48px;
                }

            .cz-footer-inner {
                position: relative;
                z-index: 1;
                padding: 58px 0 30px;
            }

            .cz-footer-logo {
                color: var(--cz-red) !important;
                font-family: 'Be Vietnam Pro', sans-serif;
                font-weight: 950;
                font-style: italic;
                letter-spacing: -0.07em;
                font-size: 1.8rem;
                text-decoration: none;
                display: inline-block;
                margin-bottom: 14px;
                text-shadow: 0 0 26px rgba(229,9,20,0.28);
            }

            .cz-footer-desc {
                color: #a1a1aa;
                max-width: 420px;
                line-height: 1.72;
                margin-bottom: 22px;
            }

            .cz-footer-badges {
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
            }

            .cz-footer-badge {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                padding: 9px 12px;
                border-radius: 999px;
                color: #d8d8de;
                background: rgba(255,255,255,0.07);
                border: 1px solid rgba(255,255,255,0.10);
                font-size: 0.82rem;
                font-weight: 800;
            }

                .cz-footer-badge .material-symbols-outlined {
                    color: var(--cz-red-2);
                    font-size: 18px;
                }

            .cz-footer-title {
                color: #fff;
                font-weight: 950;
                font-size: 0.98rem;
                margin-bottom: 18px;
                letter-spacing: -0.02em;
            }

            .cz-footer-list {
                list-style: none;
                padding: 0;
                margin: 0;
                display: grid;
                gap: 11px;
            }

            .cz-footer-link {
                color: #9d9da4;
                text-decoration: none;
                font-size: 0.9rem;
                font-weight: 750;
                transition: 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 7px;
            }

                .cz-footer-link:hover {
                    color: #fff;
                    transform: translateX(3px);
                }

            .cz-footer-contact {
                display: grid;
                gap: 13px;
            }

            .cz-footer-contact-item {
                display: flex;
                gap: 10px;
                color: #a1a1aa;
                font-size: 0.9rem;
                line-height: 1.55;
            }

                .cz-footer-contact-item .material-symbols-outlined {
                    width: 38px;
                    height: 38px;
                    border-radius: 13px;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    color: var(--cz-red-2);
                    background: rgba(229,9,20,0.13);
                    border: 1px solid rgba(229,9,20,0.25);
                    flex-shrink: 0;
                }

            .cz-footer-bottom {
                position: relative;
                z-index: 1;
                border-top: 1px solid rgba(255,255,255,0.08);
                padding: 18px 0;
            }

                .cz-footer-bottom p {
                    color: #83838b;
                    margin: 0;
                    font-size: 0.86rem;
                }

            .cz-footer-bottom-links {
                display: flex;
                flex-wrap: wrap;
                gap: 18px;
                justify-content: flex-end;
            }

                .cz-footer-bottom-links a {
                    color: #9d9da4;
                    text-decoration: none;
                    font-size: 0.86rem;
                    font-weight: 720;
                    transition: 0.2s ease;
                }

                    .cz-footer-bottom-links a:hover {
                        color: #fff;
                    }

            @@media (max-width: 991.98px) {
                .navbar-collapse {
                    padding-top: 16px;
                }

                .cz-nav-link {
                    justify-content: flex-start;
                    border-radius: 14px;
                    margin-bottom: 6px;
                    width: 100%;
                }

                .navbar-nav {
                    gap: 4px;
                }

                .cz-footer-bottom-links {
                    justify-content: flex-start;
                }
            }

            @@media (max-width: 575.98px) {
                .cz-footer-inner {
                    padding-top: 44px;
                }

                .cz-footer-logo {
                    font-size: 1.55rem;
                }
            }

            /* =========================
               MOVIE SEARCH
            ========================= */

            .cz-header-actions {
                flex-shrink: 0;
            }

            .cz-movie-search {
                width: 410px;
                max-width: 42vw;
            }

            .cz-search-box {
                height: 44px;
                display: flex;
                align-items: center;
                border-radius: 999px;
                overflow: hidden;
                background: rgba(255,255,255,0.075);
                border: 1px solid rgba(255,255,255,0.12);
                box-shadow: inset 0 0 0 1px rgba(255,255,255,0.02);
                transition: 0.22s ease;
            }

                .cz-search-box:focus-within {
                    border-color: rgba(229,9,20,0.62);
                    box-shadow: 0 0 0 4px rgba(229,9,20,0.13), 0 16px 34px rgba(0,0,0,0.25);
                }

            .cz-search-genre {
                width: 145px;
                height: 100%;
                color: #f4f4f5;
                background: rgba(229,9,20,0.18);
                border: none;
                border-right: 1px solid rgba(255,255,255,0.12);
                padding: 0 12px;
                font-size: 0.82rem;
                font-weight: 850;
                outline: none;
                cursor: pointer;
            }

                .cz-search-genre option {
                    background: #151518;
                    color: #fff;
                }

            .cz-search-input {
                flex: 1;
                min-width: 0;
                height: 100%;
                color: #fff;
                background: transparent;
                border: none;
                outline: none;
                padding: 0 12px;
                font-size: 0.88rem;
                font-weight: 700;
            }

                .cz-search-input::placeholder {
                    color: #8d8d95;
                }

            .cz-search-btn {
                width: 46px;
                height: 100%;
                border: none;
                color: #fff;
                background: linear-gradient(135deg, #ff7b83, #e50914);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                transition: 0.22s ease;
            }

                .cz-search-btn:hover {
                    filter: brightness(1.12);
                }

                .cz-search-btn .material-symbols-outlined {
                    font-size: 22px;
                }

            @@media (max-width: 1399.98px) {
                .cz-movie-search {
                    width: 340px;
                }

                .cz-search-genre {
                    width: 120px;
                }
            }

            @@media (max-width: 1199.98px) {
                .cz-movie-search {
                    width: 280px;
                }

                .cz-search-genre {
                    width: 105px;
                    font-size: 0.76rem;
                }

                .cz-search-input {
                    font-size: 0.82rem;
                }
            }

            @@media (max-width: 991.98px) {
                .cz-header-actions {
                    width: 100%;
                    flex-direction: column;
                    align-items: stretch !important;
                    gap: 12px !important;
                    margin-top: 10px;
                }

                .cz-movie-search {
                    width: 100%;
                    max-width: 100%;
                }

                .cz-search-box {
                    height: 46px;
                }

                .cz-search-genre {
                    width: 135px;
                }
            }

            @@media (max-width: 575.98px) {
                .cz-search-genre {
                    width: 118px;
                    padding: 0 9px;
                }

                .cz-search-input {
                    padding: 0 10px;
                }
            }

            /* =========================
               ACCOUNT DROPDOWN
            ========================= */

            .cz-auth-links {
                display: flex;
                align-items: center;
                gap: 12px;
                flex-shrink: 0;
            }

            .cz-register-link {
                min-height: 44px;
                padding: 0 24px;
                border-radius: 999px;
                color: #fff;
                background: linear-gradient(135deg, #ff9f99, #e50914);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 900;
                text-decoration: none;
                box-shadow: 0 14px 34px rgba(229, 9, 20, 0.28);
                transition: 0.22s ease;
            }

                .cz-register-link:hover {
                    color: #fff;
                    transform: translateY(-2px);
                    box-shadow: 0 18px 42px rgba(229, 9, 20, 0.42);
                }

            .cz-login-link {
                color: #bdbdc4;
                font-weight: 850;
                text-decoration: none;
                transition: 0.22s ease;
            }

                .cz-login-link:hover {
                    color: #fff;
                }

            .cz-account-dropdown {
                position: relative;
                flex-shrink: 0;
            }

            .cz-account-btn {
                min-height: 46px;
                padding: 5px 14px 5px 6px;
                border-radius: 999px;
                border: 1px solid rgba(255,255,255,0.14);
                background: rgba(229, 9, 20, 0.16);
                color: #fff;
                display: inline-flex;
                align-items: center;
                gap: 9px;
                font-weight: 900;
                transition: 0.22s ease;
            }

                .cz-account-btn:hover,
                .cz-account-btn.show {
                    background: rgba(229, 9, 20, 0.28);
                    border-color: rgba(229, 9, 20, 0.55);
                    box-shadow: 0 14px 34px rgba(229, 9, 20, 0.22);
                }

                .cz-account-btn::after {
                    margin-left: 2px;
                }

            .cz-account-avatar {
                width: 36px;
                height: 36px;
                border-radius: 999px;
                background: linear-gradient(135deg, #ff8b8b, #e50914);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 10px 26px rgba(229, 9, 20, 0.34);
            }

                .cz-account-avatar .material-symbols-outlined {
                    font-size: 22px;
                }

            .cz-account-name {
                max-width: 125px;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .cz-account-menu {
                min-width: 280px;
                padding: 12px;
                border-radius: 22px;
                background: radial-gradient(circle at top right, rgba(229,9,20,0.20), transparent 34%), rgba(18,18,22,0.98);
                border: 1px solid rgba(255,255,255,0.12);
                box-shadow: 0 24px 70px rgba(0,0,0,0.55);
                backdrop-filter: blur(18px);
            }

                .cz-account-menu .dropdown-divider {
                    border-color: rgba(255,255,255,0.10);
                    margin: 10px 0;
                }

            .cz-account-menu-head {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 8px 12px;
                color: #fff;
            }

            .cz-account-menu-avatar {
                width: 48px;
                height: 48px;
                border-radius: 16px;
                background: linear-gradient(135deg, #ff8b8b, #e50914);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

                .cz-account-menu-avatar .material-symbols-outlined {
                    font-size: 27px;
                }

            .cz-account-menu-head strong {
                display: block;
                max-width: 190px;
                color: #fff;
                font-weight: 950;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .cz-account-menu-head small {
                display: block;
                max-width: 190px;
                color: #9b9ba3;
                font-size: 0.78rem;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .cz-account-item {
                min-height: 44px;
                border-radius: 14px;
                color: #d9d9df;
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: 820;
                transition: 0.2s ease;
            }

                .cz-account-item .material-symbols-outlined {
                    color: #ff5964;
                    font-size: 21px;
                }

                .cz-account-item:hover {
                    color: #fff;
                    background: rgba(229,9,20,0.18);
                }

            .cz-logout-item {
                color: #ff9aa1;
            }

                .cz-logout-item:hover {
                    color: #fff;
                    background: rgba(229,9,20,0.30);
                }

            @@media (max-width: 1199.98px) {
                .cz-account-btn {
                    padding-right: 8px;
                }

                    .cz-account-btn::after {
                        display: none;
                    }
            }

            @@media (max-width: 575.98px) {
                .cz-account-menu {
                    min-width: 260px;
                }

                .cz-register-link {
                    padding: 0 18px;
                }
            }

            /* =========================
               BEAUTIFUL GENRE DROPDOWN
            ========================= */

            .cz-movie-search {
                width: 440px;
                max-width: 44vw;
                position: relative;
                z-index: 30;
            }

            .cz-search-box {
                height: 48px;
                display: flex;
                align-items: center;
                border-radius: 999px;
                overflow: visible;
                background: rgba(255,255,255,0.075);
                border: 1px solid rgba(255,255,255,0.12);
                box-shadow: inset 0 0 0 1px rgba(255,255,255,0.025), 0 14px 34px rgba(0,0,0,0.22);
                transition: 0.22s ease;
            }

                .cz-search-box:focus-within {
                    border-color: rgba(229,9,20,0.62);
                    box-shadow: 0 0 0 4px rgba(229,9,20,0.13), 0 18px 38px rgba(0,0,0,0.32);
                }

            .cz-genre-picker {
                height: 100%;
                flex-shrink: 0;
            }

            .cz-genre-trigger {
                height: 100%;
                min-width: 178px;
                border: none;
                border-radius: 999px 0 0 999px;
                color: #fff;
                background: radial-gradient(circle at top left, rgba(255,255,255,0.16), transparent 36%), linear-gradient(135deg, rgba(229,9,20,0.36), rgba(87,24,28,0.92));
                padding: 0 13px 0 16px;
                display: inline-flex;
                align-items: center;
                justify-content: space-between;
                gap: 10px;
                font-size: 0.86rem;
                font-weight: 900;
                border-right: 1px solid rgba(255,255,255,0.12);
                transition: 0.22s ease;
            }

                .cz-genre-trigger:hover,
                .cz-genre-trigger.show {
                    background: radial-gradient(circle at top left, rgba(255,255,255,0.20), transparent 36%), linear-gradient(135deg, rgba(229,9,20,0.58), rgba(95,18,24,0.98));
                }

            .cz-genre-label {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                min-width: 0;
            }

                .cz-genre-label .material-symbols-outlined {
                    font-size: 19px;
                    color: #ff8b92;
                }

            #genreText {
                display: inline-block;
                max-width: 108px;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .cz-genre-arrow {
                font-size: 20px;
                color: #d9d9df;
                transition: 0.22s ease;
            }

            .cz-genre-trigger.show .cz-genre-arrow {
                transform: rotate(180deg);
            }

            .cz-genre-menu {
                width: 260px;
                max-height: 390px;
                overflow-y: auto;
                margin-top: 12px !important;
                padding: 10px;
                border-radius: 22px;
                background: radial-gradient(circle at top right, rgba(229,9,20,0.22), transparent 34%), rgba(14,14,18,0.98);
                border: 1px solid rgba(255,255,255,0.12);
                box-shadow: 0 28px 80px rgba(0,0,0,0.62), inset 0 1px 0 rgba(255,255,255,0.06);
                backdrop-filter: blur(18px);
                z-index: 3000;
            }

                .cz-genre-menu::-webkit-scrollbar {
                    width: 7px;
                }

                .cz-genre-menu::-webkit-scrollbar-track {
                    background: rgba(255,255,255,0.04);
                    border-radius: 999px;
                }

                .cz-genre-menu::-webkit-scrollbar-thumb {
                    background: rgba(229,9,20,0.72);
                    border-radius: 999px;
                }

            .cz-genre-item {
                min-height: 44px;
                padding: 0 12px;
                border-radius: 15px;
                color: #d9d9df;
                display: flex;
                align-items: center;
                gap: 11px;
                font-weight: 820;
                transition: 0.18s ease;
                background: transparent;
            }

            .cz-genre-icon {
                width: 30px;
                height: 30px;
                border-radius: 11px;
                background: rgba(229,9,20,0.14);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

                .cz-genre-icon .material-symbols-outlined {
                    font-size: 18px;
                    color: #ff5964;
                }

            .cz-genre-item:hover {
                color: #fff;
                background: rgba(255,255,255,0.075);
                transform: translateX(3px);
            }

            .cz-genre-item.active {
                color: #fff;
                background: radial-gradient(circle at top left, rgba(255,255,255,0.18), transparent 34%), linear-gradient(135deg, rgba(229,9,20,0.72), rgba(119,12,20,0.86));
                box-shadow: 0 12px 26px rgba(229,9,20,0.20);
            }

                .cz-genre-item.active .cz-genre-icon {
                    background: rgba(255,255,255,0.16);
                }

            .cz-search-input {
                flex: 1;
                min-width: 0;
                height: 100%;
                color: #fff;
                background: rgba(12,12,15,0.82);
                border: none;
                outline: none;
                padding: 0 14px;
                font-size: 0.9rem;
                font-weight: 760;
            }

                .cz-search-input::placeholder {
                    color: #8c8c94;
                }

            .cz-search-btn {
                width: 52px;
                height: 48px;
                border: none;
                border-radius: 0 999px 999px 0;
                color: #fff;
                background: linear-gradient(135deg, #ff7b83, #e50914);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                transition: 0.22s ease;
                box-shadow: 0 10px 26px rgba(229,9,20,0.28);
            }

                .cz-search-btn:hover {
                    filter: brightness(1.12);
                }

                .cz-search-btn .material-symbols-outlined {
                    font-size: 23px;
                }

            @@media (max-width: 1399.98px) {
                .cz-movie-search {
                    width: 390px;
                }

                .cz-genre-trigger {
                    min-width: 160px;
                }
            }

            @@media (max-width: 1199.98px) {
                .cz-movie-search {
                    width: 320px;
                }

                .cz-genre-trigger {
                    min-width: 132px;
                    font-size: 0.78rem;
                    padding-left: 12px;
                }

                #genreText {
                    max-width: 74px;
                }

                .cz-genre-label .material-symbols-outlined {
                    display: none;
                }
            }

            @@media (max-width: 991.98px) {
                .cz-movie-search {
                    width: 100%;
                    max-width: 100%;
                }

                .cz-search-box {
                    height: 48px;
                }

                .cz-genre-trigger {
                    min-width: 150px;
                }

                #genreText {
                    max-width: 98px;
                }
            }

            @@media (max-width: 575.98px) {
                .cz-genre-trigger {
                    min-width: 126px;
                    padding: 0 10px;
                }

                #genreText {
                    max-width: 76px;
                }

                .cz-genre-menu {
                    width: 235px;
                }
            }

    </style>
</head>

@{
    string currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";

    bool isHome = currentController == "Home";
    bool isCinema = currentController == "Cinemas";
    bool isPromotion = currentController == "Promotions";
    bool isPolicy = currentController == "Policy";
    bool isContact = currentController == "Contact";
    bool isSupport = isPolicy || isContact;
}

<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top cz-navbar py-2 px-4 px-lg-5">
            <div class="container-fluid">
                <a class="navbar-brand cz-logo fs-4"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    CineZone
                </a>

                <button class="navbar-toggler border-0 shadow-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav"
                        aria-controls="navbarNav"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="material-symbols-outlined text-white">menu</span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 brand-font gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link cz-nav-link @(isHome ? "active" : "")"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Phim
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link cz-nav-link @(isCinema ? "active" : "")"
                               asp-area=""
                               asp-controller="Cinemas"
                               asp-action="Index">
                                Cụm Rạp
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link cz-nav-link @(isPromotion ? "active" : "")"
                               asp-area=""
                               asp-controller="Promotions"
                               asp-action="Index">
                                Khuyến Mãi
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link cz-nav-link dropdown-toggle @(isSupport ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Hỗ Trợ
                            </a>

                            <ul class="dropdown-menu dropdown-menu-dark cz-dropdown">
                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Policy"
                                       asp-action="Index">
                                        <span class="material-symbols-outlined">rule</span>
                                        Chính sách đặt vé
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Policy"
                                       asp-action="Payment">
                                        <span class="material-symbols-outlined">payments</span>
                                        Thanh toán
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Policy"
                                       asp-action="Privacy">
                                        <span class="material-symbols-outlined">shield</span>
                                        Bảo mật thông tin
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area=""
                                       asp-controller="Contact"
                                       asp-action="Index">
                                        <span class="material-symbols-outlined">support_agent</span>
                                        Liên hệ hỗ trợ
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3 cz-header-actions">
                        @await Component.InvokeAsync("MovieSearch")

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="cz-footer">
        <div class="container-fluid px-4 px-lg-5 cz-footer-inner">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
