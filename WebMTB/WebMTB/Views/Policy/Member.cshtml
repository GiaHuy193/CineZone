@{
    ViewData["Title"] = "Ưu đãi thành viên";
}

<section class="cz-info-page">
    <div class="cz-info-wrap">
        <div class="cz-info-hero">
            <span class="cz-info-kicker">
                <span class="material-symbols-outlined">workspace_premium</span>
                CineZone Member
            </span>
            <h1>Ưu đãi thành viên</h1>
            <p>Trở thành thành viên CineZone để nhận ưu đãi vé, combo bắp nước và quà tặng đặc biệt.</p>
        </div>

        <div class="cz-info-grid">
            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">military_tech</span>
                </div>
                <h3>Silver</h3>
                <p>Nhận ưu đãi cơ bản, thông báo phim mới và các chương trình khuyến mãi định kỳ.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">diamond</span>
                </div>
                <h3>Gold</h3>
                <p>Ưu đãi giá vé tốt hơn, combo tiết kiệm và quyền tham gia sự kiện thành viên.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">stars</span>
                </div>
                <h3>Platinum</h3>
                <p>Đặc quyền cao cấp, ưu tiên sự kiện, quà sinh nhật và ưu đãi độc quyền.</p>
            </div>
        </div>
    </div>
</section>