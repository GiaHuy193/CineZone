@{
    ViewData["Title"] = "Bảo mật thông tin";
}

<section class="cz-info-page">
    <div class="cz-info-wrap">
        <div class="cz-info-hero">
            <span class="cz-info-kicker">
                <span class="material-symbols-outlined">shield_lock</span>
                Privacy Policy
            </span>
            <h1>Bảo mật thông tin</h1>
            <p>CineZone cam kết bảo vệ dữ liệu tài khoản, thông tin đặt vé và lịch sử giao dịch của người dùng.</p>
        </div>

        <div class="cz-info-grid">
            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">database</span>
                </div>
                <h3>Dữ liệu sử dụng</h3>
                <p>Thông tin được dùng để xử lý đặt vé, quản lý giao dịch và nâng cao trải nghiệm người dùng.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">lock</span>
                </div>
                <h3>Bảo vệ tài khoản</h3>
                <p>Người dùng nên sử dụng mật khẩu mạnh và không chia sẻ tài khoản với người khác.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">verified_user</span>
                </div>
                <h3>Cam kết bảo mật</h3>
                <p>CineZone không công khai thông tin cá nhân của người dùng cho bên thứ ba khi không cần thiết.</p>
            </div>
        </div>
    </div>
</section>