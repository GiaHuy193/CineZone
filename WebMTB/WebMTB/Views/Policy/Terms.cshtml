@{
    ViewData["Title"] = "Điều khoản sử dụng";
}

<section class="cz-info-page">
    <div class="cz-info-wrap">
        <div class="cz-info-hero">
            <span class="cz-info-kicker">
                <span class="material-symbols-outlined">gavel</span>
                CineZone Terms
            </span>
            <h1>Điều khoản sử dụng</h1>
            <p>Những quy định chung khi truy cập, đăng ký tài khoản và sử dụng dịch vụ đặt vé tại CineZone.</p>
        </div>

        <div class="cz-info-grid">
            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">person_check</span>
                </div>
                <h3>Tài khoản</h3>
                <p>Người dùng cần cung cấp thông tin chính xác và chịu trách nhiệm bảo mật tài khoản của mình.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">rule</span>
                </div>
                <h3>Quy định sử dụng</h3>
                <p>Không sử dụng CineZone cho các hành vi gian lận, phá hoại hệ thống hoặc gây ảnh hưởng người dùng khác.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">block</span>
                </div>
                <h3>Từ chối dịch vụ</h3>
                <p>CineZone có quyền từ chối dịch vụ nếu phát hiện hành vi vi phạm điều khoản sử dụng.</p>
            </div>
        </div>
    </div>
</section>