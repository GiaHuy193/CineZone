@{
    ViewData["Title"] = "Quy định rạp chiếu";
}

<section class="cz-info-page">
    <div class="cz-info-wrap">
        <div class="cz-info-hero">
            <span class="cz-info-kicker">
                <span class="material-symbols-outlined">theaters</span>
                Cinema Rules
            </span>
            <h1>Quy định rạp chiếu</h1>
            <p>Một số quy định cần tuân thủ để đảm bảo trải nghiệm xem phim văn minh và an toàn tại CineZone.</p>
        </div>

        <div class="cz-info-grid">
            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">videocam_off</span>
                </div>
                <h3>Không quay phim</h3>
                <p>Không quay phim, chụp ảnh màn hình hoặc phát tán nội dung phim trong rạp.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">phone_disabled</span>
                </div>
                <h3>Giữ yên lặng</h3>
                <p>Tắt chuông điện thoại và hạn chế gây tiếng ồn ảnh hưởng đến người xem khác.</p>
            </div>

            <div class="cz-info-card">
                <div class="cz-info-icon">
                    <span class="material-symbols-outlined">cleaning_services</span>
                </div>
                <h3>Giữ vệ sinh</h3>
                <p>Giữ vệ sinh khu vực ghế ngồi, không hút thuốc và tuân thủ hướng dẫn của nhân viên rạp.</p>
            </div>
        </div>
    </div>
</section>