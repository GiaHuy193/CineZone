@{
    ViewData["Title"] = "Hướng dẫn đặt vé";
}

<section class="cz-info-page">
    <div class="cz-info-wrap">
        <div class="cz-info-hero">
            <span class="cz-info-kicker">
                <span class="material-symbols-outlined">confirmation_number</span>
                CineZone Guide
            </span>
            <h1>Hướng dẫn đặt vé</h1>
            <p>Đặt vé xem phim tại CineZone chỉ với vài bước đơn giản: chọn phim, chọn suất chiếu, chọn ghế và thanh toán.</p>
        </div>

        <div class="cz-wide-card">
            <div class="cz-step-list">
                <div class="cz-step">
                    <div class="cz-step-number">01</div>
                    <div>
                        <h3>Chọn phim</h3>
                        <p>Truy cập trang Phim, xem thông tin phim, thời lượng, độ tuổi và trailer trước khi đặt vé.</p>
                    </div>
                </div>

                <div class="cz-step">
                    <div class="cz-step-number">02</div>
                    <div>
                        <h3>Chọn rạp và suất chiếu</h3>
                        <p>Chọn cụm rạp phù hợp, ngày chiếu và suất chiếu còn chỗ trống.</p>
                    </div>
                </div>

                <div class="cz-step">
                    <div class="cz-step-number">03</div>
                    <div>
                        <h3>Chọn ghế</h3>
                        <p>Chọn ghế thường, VIP hoặc ghế đôi trên sơ đồ ghế trực quan của CineZone.</p>
                    </div>
                </div>

                <div class="cz-step">
                    <div class="cz-step-number">04</div>
                    <div>
                        <h3>Thanh toán và nhận vé</h3>
                        <p>Sau khi thanh toán thành công, vé sẽ được lưu trong tài khoản và gửi thông tin qua email.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>