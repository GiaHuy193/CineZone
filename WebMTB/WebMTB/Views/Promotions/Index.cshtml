@{
    ViewData["Title"] = "Khuyến mãi";
}

<section class="cz-info-page">
    <div class="cz-info-wrap">
        <div class="cz-info-hero">
            <span class="cz-info-kicker">
                <span class="material-symbols-outlined">local_offer</span>
                CineZone Deals
            </span>
            <h1>Khuyến mãi CineZone</h1>
            <p>Khám phá các ưu đãi vé xem phim, combo bắp nước và quyền lợi thành viên đang diễn ra tại CineZone.</p>
        </div>

        <div class="cz-promo-grid">
            <div class="cz-promo-card">
                <img src="https://images.unsplash.com/photo-1585647347384-2593bc35786b?q=80&w=1200&auto=format&fit=crop" alt="Combo Popcorn" />

                <div class="cz-promo-content">
                    <span class="cz-promo-tag">Combo</span>
                    <h3>Combo Bắp Nước Tiết Kiệm</h3>
                    <p>Đặt vé online và mua kèm combo để nhận ưu đãi đến 20%.</p>
                    <div class="cz-promo-code">COMBO20</div>
                </div>
            </div>

            <div class="cz-promo-card">
                <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?q=80&w=1200&auto=format&fit=crop" alt="Movie Tickets" />

                <div class="cz-promo-content">
                    <span class="cz-promo-tag">Member</span>
                    <h3>Ưu Đãi Thành Viên Mới</h3>
                    <p>Đăng ký tài khoản CineZone và nhận mã giảm giá cho lần đặt vé đầu tiên.</p>
                    <div class="cz-promo-code">WELCOME</div>
                </div>
            </div>

            <div class="cz-promo-card">
                <img src="https://images.unsplash.com/photo-1536440136628-849c177e76a1?q=80&w=1200&auto=format&fit=crop" alt="IMAX" />

                <div class="cz-promo-content">
                    <span class="cz-promo-tag">Premium</span>
                    <h3>Ngày Hội Phòng Chiếu VIP</h3>
                    <p>Trải nghiệm ghế đẹp, âm thanh sống động với giá ưu đãi vào các ngày đặc biệt.</p>
                    <div class="cz-promo-code">VIPDAY</div>
                </div>
            </div>
        </div>

        <div class="cz-wide-card">
            <h3 class="fw-bold mb-3">Điều kiện áp dụng</h3>
            <p class="text-secondary mb-0">
                Mã khuyến mãi có thể thay đổi theo từng thời điểm và số lượng ưu đãi.
                CineZone có quyền điều chỉnh chương trình để phù hợp với tình hình thực tế.
            </p>
        </div>
    </div>
</section>