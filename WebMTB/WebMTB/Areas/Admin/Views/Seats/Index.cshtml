@model IEnumerable<WebMTB.Models.Seat>

@{
    ViewData["Title"] = "Sơ đồ ghế";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var rooms = ViewBag.Rooms as List<WebMTB.Models.Room> ?? new List<WebMTB.Models.Room>();
    int? currentRoomId = ViewBag.CurrentRoomId as int?;
    var currentRoom = ViewBag.CurrentRoom as WebMTB.Models.Room;

    var seats = Model?.ToList() ?? new List<WebMTB.Models.Seat>();

    int totalSeats = seats.Count;
    int normalSeats = seats.Count(s => (s.SeatType ?? "Normal").ToLower() == "normal");
    int vipSeats = seats.Count(s => (s.SeatType ?? "").ToLower() == "vip");
    int coupleSeats = seats.Count(s => (s.SeatType ?? "").ToLower() == "couple");

    int maxRow = seats.Any() ? seats.Max(s => s.GridRow) : 0;
    int maxCol = seats.Any() ? seats.Max(s => s.GridColumn) : 0;

    int emptySlots = 0;

    if (seats.Any())
    {
        emptySlots = (maxRow * maxCol) - totalSeats;
        if (emptySlots < 0) emptySlots = 0;
    }

    decimal premiumRatio = totalSeats > 0
        ? Math.Round((decimal)(vipSeats + coupleSeats) / totalSeats * 100, 0)
        : 0;
}

<div class="seat-admin-page">
    <section class="seat-hero mb-4">
        <div class="hero-left">
            <div class="seat-eyebrow">
                <span class="material-symbols-outlined">event_seat</span>
                CineZone Seat Mapping
            </div>

            <h1>Sơ đồ ghế</h1>

            <p>
                Quản lý layout ghế theo từng phòng chiếu, xem nhanh ghế thường, ghế VIP,
                ghế đôi và các vị trí lối đi.
            </p>
        </div>

        @if (currentRoom != null)
        {
            <a asp-area="Admin"
               asp-controller="Rooms"
               asp-action="SeatDesigner"
               asp-route-id="@currentRoom.Id"
               class="btn designer-btn">
                <span class="material-symbols-outlined">edit_square</span>
                Chỉnh sơ đồ ghế
            </a>
        }
    </section>

    <section class="seat-toolbar mb-4">
        <div class="room-current-card">
            <div class="room-current-icon">
                <span class="material-symbols-outlined">theaters</span>
            </div>

            <div>
                <small>Phòng đang xem</small>

                @if (currentRoom != null)
                {
                    <strong>@currentRoom.Name</strong>
                    <span>@(currentRoom.Cinema?.Name ?? "Chưa có rạp")</span>
                }
                else
                {
                    <strong>Chưa chọn phòng</strong>
                    <span>Vui lòng chọn phòng chiếu</span>
                }
            </div>
        </div>

        <form method="get" class="room-filter-form">
            <label for="roomId">Lọc theo phòng</label>

            <div class="room-select-wrap">
                <span class="material-symbols-outlined">meeting_room</span>

                <select id="roomId" name="roomId" class="room-select">
                    @foreach (var room in rooms)
                    {
                        if (currentRoomId == room.Id)
                        {
                            <option value="@room.Id" selected>
                                @room.Name - @room.Cinema?.Name
                            </option>
                        }
                        else
                        {
                            <option value="@room.Id">
                                @room.Name - @room.Cinema?.Name
                            </option>
                        }
                    }
                </select>

                <span class="material-symbols-outlined select-arrow">expand_more</span>
            </div>
        </form>

        @if (currentRoom != null)
        {
            <a asp-area="Admin"
               asp-controller="Rooms"
               asp-action="Index"
               class="btn back-room-btn">
                <span class="material-symbols-outlined">arrow_back</span>
                Quản lý phòng
            </a>
        }
    </section>

    <section class="seat-stats-grid mb-4">
        <div class="seat-stat-card stat-red">
            <div class="stat-icon">
                <span class="material-symbols-outlined">event_seat</span>
            </div>

            <div>
                <p>Tổng ghế</p>
                <h3>@totalSeats</h3>
            </div>
        </div>

        <div class="seat-stat-card stat-gray">
            <div class="stat-icon">
                <span class="material-symbols-outlined">chair</span>
            </div>

            <div>
                <p>Ghế thường</p>
                <h3>@normalSeats</h3>
            </div>
        </div>

        <div class="seat-stat-card stat-gold">
            <div class="stat-icon">
                <span class="material-symbols-outlined">workspace_premium</span>
            </div>

            <div>
                <p>Ghế VIP</p>
                <h3>@vipSeats</h3>
            </div>
        </div>

        <div class="seat-stat-card stat-purple">
            <div class="stat-icon">
                <span class="material-symbols-outlined">favorite</span>
            </div>

            <div>
                <p>Ghế đôi</p>
                <h3>@coupleSeats</h3>
            </div>
        </div>

        <div class="seat-stat-card stat-blue">
            <div class="stat-icon">
                <span class="material-symbols-outlined">grid_view</span>
            </div>

            <div>
                <p>Kích thước</p>
                <h3>@maxRow × @maxCol</h3>
            </div>
        </div>

        <div class="seat-stat-card stat-yellow">
            <div class="stat-icon">
                <span class="material-symbols-outlined">percent</span>
            </div>

            <div>
                <p>Tỉ lệ premium</p>
                <h3>@premiumRatio%</h3>
            </div>
        </div>
    </section>

    <section class="seat-map-panel">
        <div class="seat-map-header">
            <div>
                <div class="panel-eyebrow">
                    <span class="material-symbols-outlined">map</span>
                    Preview layout
                </div>

                <h4>
                    @(currentRoom != null ? currentRoom.Name : "Sơ đồ ghế")
                </h4>

                @if (currentRoom != null)
                {
                    <p>
                        Rạp: <strong>@currentRoom.Cinema?.Name</strong>
                        <span>•</span>
                        Tổng ghế: <strong>@totalSeats</strong>
                        <span>•</span>
                        Trống/lối đi: <strong>@emptySlots</strong>
                    </p>
                }
                else
                {
                    <p>Chọn phòng chiếu để xem layout ghế.</p>
                }
            </div>

            @if (currentRoom != null)
            {
                <a asp-area="Admin"
                   asp-controller="Rooms"
                   asp-action="SeatDesigner"
                   asp-route-id="@currentRoom.Id"
                   class="btn mini-designer-btn">
                    <span class="material-symbols-outlined">edit</span>
                    Thiết kế
                </a>
            }
        </div>

        @if (seats.Any())
        {
            <div class="cinema-canvas">
                <div class="screen-preview">
                    <div class="screen-glow"></div>
                    <div class="screen-curve">
                        <span>Màn hình</span>
                    </div>
                </div>

                <div class="seat-scroll-area">
                    <div class="seat-column-guide">
                        <span class="guide-spacer"></span>

                        @for (int c = 1; c <= maxCol; c++)
                        {
                            <span>@c</span>
                        }

                        <span class="guide-spacer"></span>
                    </div>

                    <div class="seat-preview">
                        @for (int r = 1; r <= maxRow; r++)
                        {
                            var rowSeats = seats.Where(s => s.GridRow == r).ToList();
                            string rowName = rowSeats.FirstOrDefault()?.Row ?? ((char)('A' + r - 1)).ToString();

                            <div class="seat-preview-row">
                                <span class="row-label">@rowName</span>

                                @for (int c = 1; c <= maxCol; c++)
                                {
                                    var seat = seats.FirstOrDefault(s => s.GridRow == r && s.GridColumn == c);

                                    if (seat == null)
                                    {
                                        <span class="seat-empty" title="Lối đi / Trống"></span>
                                    }
                                    else
                                    {
                                        string rawType = seat.SeatType ?? "Normal";
                                        string seatClass = rawType.ToLower();

                                        if (seatClass != "normal" && seatClass != "vip" && seatClass != "couple")
                                        {
                                            seatClass = "normal";
                                        }

                                        string seatLabel = $"{seat.Row}{seat.Number}";

                                        <span class="seat-box @seatClass" title="@seatLabel - @rawType">
                                            @if (seatClass == "vip")
                                            {
                                                <span class="material-symbols-outlined seat-mini-icon">star</span>
                                            }
                                            else if (seatClass == "couple")
                                            {
                                                <span class="material-symbols-outlined seat-mini-icon">favorite</span>
                                            }

                                            <span>@seatLabel</span>
                                        </span>
                                    }
                                }

                                <span class="row-label">@rowName</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="seat-legend-card">
                    <div class="legend-title">
                        <span class="material-symbols-outlined">palette</span>
                        Chú thích ghế
                    </div>

                    <div class="legend-list">
                        <div class="legend-item">
                            <span class="legend-box normal"></span>
                            <div>
                                <strong>Ghế thường</strong>
                                <small>@normalSeats ghế</small>
                            </div>
                        </div>

                        <div class="legend-item">
                            <span class="legend-box vip"></span>
                            <div>
                                <strong>Ghế VIP</strong>
                                <small>@vipSeats ghế</small>
                            </div>
                        </div>

                        <div class="legend-item">
                            <span class="legend-box couple"></span>
                            <div>
                                <strong>Ghế đôi</strong>
                                <small>@coupleSeats ghế</small>
                            </div>
                        </div>

                        <div class="legend-item">
                            <span class="legend-box empty"></span>
                            <div>
                                <strong>Lối đi / trống</strong>
                                <small>@emptySlots ô</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="seat-note-row">
                    <div>
                        <span class="material-symbols-outlined">visibility</span>
                        Đây là bản preview layout ghế cho admin.
                    </div>

                    <div>
                        <span class="material-symbols-outlined">touch_app</span>
                        Muốn chỉnh vị trí ghế, vào mục Thiết kế.
                    </div>

                    <div>
                        <span class="material-symbols-outlined">auto_awesome</span>
                        Ghế VIP và ghế đôi được tô màu riêng để dễ kiểm tra.
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="empty-seat-box">
                <div class="empty-icon">
                    <span class="material-symbols-outlined">event_seat</span>
                </div>

                <h4>Phòng này chưa có sơ đồ ghế</h4>
                <p>Hãy vào phần thiết kế sơ đồ ghế để tạo layout cho phòng này.</p>

                @if (currentRoom != null)
                {
                    <a asp-area="Admin"
                       asp-controller="Rooms"
                       asp-action="SeatDesigner"
                       asp-route-id="@currentRoom.Id"
                       class="btn designer-btn">
                        <span class="material-symbols-outlined">edit_square</span>
                        Thiết kế sơ đồ ghế
                    </a>
                }
            </div>
        }
    </section>
</div>

<style>
    .seat-admin-page {
        color: #fff;
        min-height: 100vh;
        padding: 28px;
        background: radial-gradient(circle at 8% 0%, rgba(145, 0, 24, 0.34), transparent 30%), radial-gradient(circle at 95% 10%, rgba(229, 9, 20, 0.18), transparent 26%), radial-gradient(circle at 45% 100%, rgba(255, 89, 100, 0.07), transparent 34%), linear-gradient(135deg, #08080a 0%, #101014 48%, #070708 100%);
    }

    .seat-hero {
        position: relative;
        overflow: hidden;
        min-height: 170px;
        padding: 28px 30px;
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.09);
        background: radial-gradient(circle at 13% 18%, rgba(160, 0, 25, 0.46), transparent 31%), radial-gradient(circle at 92% 18%, rgba(120, 0, 20, 0.48), transparent 27%), linear-gradient(90deg, #33070f 0%, #0c0c12 42%, #090910 72%, #3b0710 100%);
        box-shadow: 0 20px 55px rgba(0, 0, 0, 0.34), inset 0 1px 0 rgba(255,255,255,0.035);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 22px;
    }

        .seat-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 42px 42px;
            opacity: 0.18;
            pointer-events: none;
        }

    .hero-left,
    .designer-btn {
        position: relative;
        z-index: 2;
    }

    .seat-eyebrow {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        color: #ff8b92;
        background: rgba(229,9,20,0.18);
        border: 1px solid rgba(229,9,20,0.34);
        box-shadow: 0 10px 26px rgba(229,9,20,0.12);
        font-size: 0.72rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 13px;
    }

    .seat-hero h1 {
        font-size: clamp(2rem, 3.4vw, 3.4rem);
        font-weight: 950;
        letter-spacing: -0.055em;
        line-height: 1;
        margin-bottom: 10px;
        text-shadow: 0 12px 28px rgba(0,0,0,0.32);
    }

    .seat-hero p {
        color: rgba(255,255,255,0.78);
        max-width: 760px;
        line-height: 1.55;
        margin: 0;
        font-size: 0.98rem;
        font-weight: 650;
    }

    .designer-btn,
    .mini-designer-btn,
    .back-room-btn {
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        color: #fff;
        border: none;
        background: linear-gradient(135deg, #ff8b8b 0%, #f4212d 45%, #b80012 100%);
        box-shadow: 0 16px 36px rgba(229,9,20,0.34), inset 0 1px 0 rgba(255,255,255,0.22);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 950;
        white-space: nowrap;
    }

        .designer-btn:hover,
        .mini-designer-btn:hover,
        .back-room-btn:hover {
            color: #fff;
            transform: translateY(-2px);
            background: linear-gradient(135deg, #ffa1a1 0%, #ff1d2b 52%, #d00016 100%);
            box-shadow: 0 20px 48px rgba(229,9,20,0.44);
        }

    .seat-toolbar {
        padding: 16px;
        border-radius: 26px;
        border: 1px solid rgba(255,255,255,0.09);
        background: radial-gradient(circle at top right, rgba(229,9,20,0.10), transparent 30%), linear-gradient(135deg, rgba(255,255,255,0.050), rgba(255,255,255,0.018)), rgba(18,18,22,0.96);
        box-shadow: 0 18px 46px rgba(0,0,0,0.26);
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(300px, 460px) auto;
        gap: 14px;
        align-items: center;
    }

    .room-current-card {
        min-height: 64px;
        padding: 10px 14px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(0,0,0,0.24);
        display: flex;
        align-items: center;
        gap: 13px;
    }

    .room-current-icon {
        width: 44px;
        height: 44px;
        border-radius: 16px;
        color: #ff5964;
        background: rgba(229,9,20,0.16);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .room-current-card small,
    .room-filter-form label {
        display: block;
        color: #a7a7af;
        font-size: 0.68rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 2px;
    }

    .room-current-card strong {
        display: block;
        font-size: 1rem;
        font-weight: 950;
    }

    .room-current-card span {
        color: #a0a0a8;
        font-size: 0.82rem;
        font-weight: 750;
    }

    .room-filter-form {
        min-height: 64px;
        padding: 9px 14px;
        border-radius: 20px;
        border: 1px solid rgba(229,9,20,0.28);
        background: radial-gradient(circle at top right, rgba(229,9,20,0.20), transparent 35%), linear-gradient(135deg, rgba(229,9,20,0.17), rgba(255,255,255,0.045)), rgba(0,0,0,0.24);
    }

    .room-select-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .room-select-wrap > span:first-child {
            color: #ff5964;
        }

    .room-select {
        width: 100%;
        color: #fff;
        border: none;
        outline: none;
        background: transparent;
        font-weight: 950;
        appearance: none;
        cursor: pointer;
    }

        .room-select option {
            color: #fff;
            background: #151519;
            font-weight: 800;
        }

    .select-arrow {
        color: #ff9ca3;
        pointer-events: none;
    }

    .back-room-btn {
        min-width: 160px;
        background: linear-gradient(135deg, rgba(255,255,255,0.090), rgba(255,255,255,0.035));
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: none;
    }

    .seat-stats-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 16px;
    }

    .seat-stat-card {
        position: relative;
        overflow: hidden;
        min-height: 116px;
        padding: 18px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.09);
        background: radial-gradient(circle at bottom right, rgba(229,9,20,0.16), transparent 36%), linear-gradient(135deg, rgba(255,255,255,0.055), rgba(255,255,255,0.018)), rgba(18,18,22,0.96);
        box-shadow: 0 18px 46px rgba(0,0,0,0.30);
        display: flex;
        align-items: center;
        gap: 14px;
    }

        .seat-stat-card.stat-gray {
            background: radial-gradient(circle at bottom right, rgba(148,163,184,0.14), transparent 36%), linear-gradient(135deg, rgba(30,30,35,0.98), rgba(18,18,22,0.96));
        }

        .seat-stat-card.stat-gold {
            background: radial-gradient(circle at bottom right, rgba(255,193,7,0.20), transparent 36%), linear-gradient(135deg, rgba(42,31,12,0.98), rgba(18,18,22,0.96));
        }

        .seat-stat-card.stat-purple {
            background: radial-gradient(circle at bottom right, rgba(147,51,234,0.20), transparent 36%), linear-gradient(135deg, rgba(27,18,42,0.98), rgba(18,18,22,0.96));
        }

        .seat-stat-card.stat-blue {
            background: radial-gradient(circle at bottom right, rgba(14,165,233,0.18), transparent 36%), linear-gradient(135deg, rgba(12,27,40,0.98), rgba(18,18,22,0.96));
        }

        .seat-stat-card.stat-yellow {
            background: radial-gradient(circle at bottom right, rgba(245,158,11,0.20), transparent 36%), linear-gradient(135deg, rgba(42,31,12,0.98), rgba(18,18,22,0.96));
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 17px;
        background: rgba(229,9,20,0.16);
        color: #ff5964;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-gray .stat-icon {
        color: #cbd5e1;
        background: rgba(148,163,184,0.12);
    }

    .stat-gold .stat-icon,
    .stat-yellow .stat-icon {
        color: #ffc94a;
        background: rgba(255,193,7,0.13);
    }

    .stat-purple .stat-icon {
        color: #c084fc;
        background: rgba(147,51,234,0.16);
    }

    .stat-blue .stat-icon {
        color: #38bdf8;
        background: rgba(14,165,233,0.14);
    }

    .stat-icon span {
        font-size: 29px;
    }

    .seat-stat-card p {
        color: #b9b9c1;
        font-size: 0.70rem;
        font-weight: 850;
        text-transform: uppercase;
        margin: 0 0 6px;
    }

    .seat-stat-card h3 {
        color: #fff;
        font-size: 1.65rem;
        font-weight: 950;
        margin: 0;
        white-space: nowrap;
    }

    .seat-map-panel {
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.09);
        background: radial-gradient(circle at top right, rgba(229,9,20,0.08), transparent 30%), linear-gradient(135deg, rgba(255,255,255,0.045), rgba(255,255,255,0.015)), rgba(18,18,22,0.97);
        box-shadow: 0 24px 68px rgba(0,0,0,0.34);
        overflow: hidden;
    }

    .seat-map-header {
        padding: 22px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(135deg, rgba(255,255,255,0.060), rgba(255,255,255,0.018)), rgba(10,10,12,0.45);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
    }

    .panel-eyebrow {
        width: fit-content;
        padding: 7px 12px;
        margin-bottom: 10px;
        border-radius: 999px;
        color: #ff8b92;
        background: rgba(229,9,20,0.14);
        border: 1px solid rgba(229,9,20,0.24);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.68rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .seat-map-header h4 {
        font-weight: 950;
        font-size: 1.55rem;
        margin-bottom: 4px;
    }

    .seat-map-header p {
        color: #999;
        margin: 0;
        font-size: 0.9rem;
    }

        .seat-map-header p strong {
            color: #fff;
        }

        .seat-map-header p span {
            color: #555;
            margin: 0 6px;
        }

    .mini-designer-btn {
        min-height: 42px;
        padding: 0 18px;
    }

    .cinema-canvas {
        position: relative;
        min-height: 620px;
        padding: 34px 26px 28px;
        background: radial-gradient(circle at top center, rgba(255,255,255,0.08), transparent 24%), radial-gradient(circle at bottom left, rgba(229,9,20,0.13), transparent 32%), radial-gradient(circle at bottom right, rgba(229,9,20,0.10), transparent 30%), #0c0c10;
    }

        .cinema-canvas::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(rgba(255,255,255,0.020) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.020) 1px, transparent 1px);
            background-size: 42px 42px;
            opacity: 0.22;
            pointer-events: none;
        }

