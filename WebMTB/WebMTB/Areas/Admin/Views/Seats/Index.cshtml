@model IEnumerable<WebMTB.Models.Seat>

@{
    ViewData["Title"] = "Sơ đồ ghế";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var rooms = ViewBag.Rooms as List<WebMTB.Models.Room> ?? new List<WebMTB.Models.Room>();
    int? currentRoomId = ViewBag.CurrentRoomId as int?;
    var currentRoom = ViewBag.CurrentRoom as WebMTB.Models.Room;

    var seats = Model?.ToList() ?? new List<WebMTB.Models.Seat>();

    int totalSeats = seats.Count;
    int normalSeats = seats.Count(s => (s.SeatType ?? "Normal").ToLower() == "normal");
    int vipSeats = seats.Count(s => (s.SeatType ?? "").ToLower() == "vip");
    int coupleSeats = seats.Count(s => (s.SeatType ?? "").ToLower() == "couple");
    int emptySlots = 0;

    int maxRow = seats.Any() ? seats.Max(s => s.GridRow) : 0;
    int maxCol = seats.Any() ? seats.Max(s => s.GridColumn) : 0;

    if (seats.Any())
    {
        emptySlots = (maxRow * maxCol) - totalSeats;
        if (emptySlots < 0) emptySlots = 0;
    }

    decimal vipRatio = totalSeats > 0 ? Math.Round((decimal)(vipSeats + coupleSeats) / totalSeats * 100, 0) : 0;
}

<div class="seat-admin-page">
    <div class="seat-hero mb-4">
        <div>
            <div class="seat-eyebrow">
                <span class="material-symbols-outlined">event_seat</span>
                CineZone Seat Mapping
            </div>

            <h1>Sơ đồ ghế</h1>
            <p>
                Xem layout ghế theo từng phòng chiếu, bao gồm ghế thường, VIP, ghế đôi và lối đi/trống.
            </p>
        </div>

        @if (currentRoom != null)
        {
            <a asp-area="Admin"
               asp-controller="Rooms"
               asp-action="SeatDesigner"
               asp-route-id="@currentRoom.Id"
               class="btn designer-btn">
                <span class="material-symbols-outlined">edit_square</span>
                Chỉnh sơ đồ ghế
            </a>
        }
    </div>

    <div class="seat-stats-grid mb-4">
        <div class="seat-stat-card highlight">
            <span class="material-symbols-outlined">event_seat</span>
            <p>Tổng ghế</p>
            <h3>@totalSeats</h3>
        </div>

        <div class="seat-stat-card">
            <span class="material-symbols-outlined">workspace_premium</span>
            <p>Ghế VIP</p>
            <h3>@vipSeats</h3>
        </div>

        <div class="seat-stat-card">
            <span class="material-symbols-outlined">favorite</span>
            <p>Ghế đôi</p>
            <h3>@coupleSeats</h3>
        </div>

        <div class="seat-stat-card premium">
            <span class="material-symbols-outlined">percent</span>
            <p>Tỉ lệ premium</p>
            <h3>@vipRatio%</h3>
        </div>
    </div>

    <div class="seat-layout">
        <aside class="seat-sidebar">
            <div class="side-panel mb-4">
                <div class="side-panel-header">
                    <div>
                        <h5>Lọc theo phòng</h5>
                        <p>Chọn phòng chiếu để xem layout ghế.</p>
                    </div>

                    <span class="material-symbols-outlined">filter_list</span>
                </div>

                <form method="get" class="filter-form">
                    <label class="form-label">Phòng chiếu</label>

                    <select name="roomId" class="form-select cinema-select">
                        @foreach (var room in rooms)
                        {
                            if (currentRoomId == room.Id)
                            {
                                <option value="@room.Id" selected>
                                    @room.Name - @room.Cinema?.Name
                                </option>
                            }
                            else
                            {
                                <option value="@room.Id">
                                    @room.Name - @room.Cinema?.Name
                                </option>
                            }
                        }
                    </select>

                    <button type="submit" class="btn filter-btn">
                        <span class="material-symbols-outlined">manage_search</span>
                        Lọc phòng
                    </button>
                </form>
            </div>

            <div class="side-panel mb-4">
                <div class="side-panel-header">
                    <div>
                        <h5>Thông tin phòng</h5>
                        <p>Thông tin tổng quan layout hiện tại.</p>
                    </div>

                    <span class="material-symbols-outlined">info</span>
                </div>

                <div class="room-info-box">
                    @if (currentRoom != null)
                    {
                        <div class="room-avatar">
                            <span class="material-symbols-outlined">theaters</span>
                        </div>

                        <h5>@currentRoom.Name</h5>
                        <p>@(currentRoom.Cinema?.Name ?? "Chưa có rạp")</p>

                        <div class="room-info-list">
                            <div>
                                <span class="material-symbols-outlined">event_seat</span>
                                <div>
                                    <small>Sức chứa</small>
                                    <strong>@totalSeats ghế</strong>
                                </div>
                            </div>

                            <div>
                                <span class="material-symbols-outlined">grid_view</span>
                                <div>
                                    <small>Kích thước layout</small>
                                    <strong>@maxRow hàng × @maxCol cột</strong>
                                </div>
                            </div>

                            <div>
                                <span class="material-symbols-outlined">space_bar</span>
                                <div>
                                    <small>Lối đi / trống</small>
                                    <strong>@emptySlots ô</strong>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-side">
                            <span class="material-symbols-outlined">meeting_room</span>
                            <p>Chưa chọn phòng chiếu.</p>
                        </div>
                    }
                </div>
            </div>

        </aside>

        <main class="seat-main">
            <div class="seat-map-panel">
                <div class="seat-map-header">
                    <div>
                        <h4>
                            @(currentRoom != null ? currentRoom.Name : "Sơ đồ ghế")
                        </h4>

                        <p>
                            @if (currentRoom != null)
                            {
                                <span>Rạp: @currentRoom.Cinema?.Name · Tổng ghế: @totalSeats</span>
                            }
                            else
                            {
                                <span>Chọn phòng để xem layout ghế.</span>
                            }
                        </p>
                    </div>

                    @if (currentRoom != null)
                    {
                        <a asp-area="Admin"
                           asp-controller="Rooms"
                           asp-action="SeatDesigner"
                           asp-route-id="@currentRoom.Id"
                           class="btn mini-designer-btn">
                            <span class="material-symbols-outlined">edit</span>
                            Thiết kế
                        </a>
                    }
                </div>

                @if (seats.Any())
                {
                    <div class="cinema-canvas">
                        <div class="screen-preview">
                            <div class="screen-light"></div>
                            <div class="screen-line"></div>
                            <span>Màn hình</span>
                        </div>

                        <div class="seat-preview-wrapper">
                            <div class="seat-preview">
                                @for (int r = 1; r <= maxRow; r++)
                                {
                                    var rowSeats = seats.Where(s => s.GridRow == r).ToList();
                                    string rowName = rowSeats.FirstOrDefault()?.Row ?? ((char)('A' + r - 1)).ToString();

                                    <div class="seat-preview-row">
                                        <span class="row-label">@rowName</span>

                                        @for (int c = 1; c <= maxCol; c++)
                                        {
                                            var seat = seats.FirstOrDefault(s => s.GridRow == r && s.GridColumn == c);

                                            if (seat == null)
                                            {
                                                <span class="seat-empty" title="Lối đi / Trống"></span>
                                            }
                                            else
                                            {
                                                string seatClass = seat.SeatType?.ToLower() ?? "normal";
                                                string seatLabel = $"{seat.Row}{seat.Number}";

                                                <span class="seat-box @seatClass" title="@seatLabel - @seat.SeatType">
                                                    @seatLabel
                                                </span>
                                            }
                                        }

                                        <span class="row-label">@rowName</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="seat-legend-inline">
                            <div class="seat-legend-head">
                                <span class="material-symbols-outlined">palette</span>
                                <span>Chú thích ghế</span>
                            </div>

                            <div class="seat-legend-list">
                                <div class="legend-item-inline">
                                    <span class="legend-box normal"></span>
                                    <div>
                                        <strong>Ghế thường</strong>
                                        <small>@normalSeats ghế</small>
                                    </div>
                                </div>

                                <div class="legend-item-inline">
                                    <span class="legend-box vip"></span>
                                    <div>
                                        <strong>VIP</strong>
                                        <small>@vipSeats ghế</small>
                                    </div>
                                </div>

                                <div class="legend-item-inline">
                                    <span class="legend-box couple"></span>
                                    <div>
                                        <strong>Ghế đôi</strong>
                                        <small>@coupleSeats ghế</small>
                                    </div>
                                </div>

                                <div class="legend-item-inline">
                                    <span class="legend-box empty"></span>
                                    <div>
                                        <strong>Lối đi / Trống</strong>
                                        <small>@emptySlots ô</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="seat-bottom-info">
                            <div>
                                <span class="material-symbols-outlined">visibility</span>
                                Preview layout ghế theo phòng chiếu
                            </div>

                            <div>
                                <span class="material-symbols-outlined">touch_app</span>
                                Chỉnh sửa tại Seat Designer
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-seat-box">
                        <div class="empty-icon">
                            <span class="material-symbols-outlined">event_seat</span>
                        </div>

                        <h4>Phòng này chưa có sơ đồ ghế</h4>
                        <p>Hãy vào phần thiết kế sơ đồ ghế để tạo layout cho phòng này.</p>

                        @if (currentRoom != null)
                        {
                            <a asp-area="Admin"
                               asp-controller="Rooms"
                               asp-action="SeatDesigner"
                               asp-route-id="@currentRoom.Id"
                               class="btn designer-btn">
                                <span class="material-symbols-outlined">edit_square</span>
                                Thiết kế sơ đồ ghế
                            </a>
                        }
                    </div>
                }
            </div>
        </main>
    </div>
</div>

<style>
    .seat-admin-page {
        color: #fff;
        min-height: 100vh;
        padding: 28px;
        background: radial-gradient(circle at 5% 5%, rgba(229, 9, 20, 0.16), transparent 26%), radial-gradient(circle at 95% 15%, rgba(255,255,255,0.05), transparent 24%), #101012;
    }

    .seat-hero {
        position: relative;
        overflow: hidden;
        padding: 30px;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.09);
        background: linear-gradient(90deg, rgba(0,0,0,0.84), rgba(0,0,0,0.48)), radial-gradient(circle at top right, rgba(229,9,20,0.35), transparent 34%), linear-gradient(135deg, #1b1b20, #09090b);
        box-shadow: 0 22px 60px rgba(0,0,0,0.35);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 22px;
    }

    .seat-eyebrow {
        color: #ff5964;
        font-size: 0.78rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 1.4px;
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 12px;
    }

    .seat-hero h1 {
        font-size: clamp(2.2rem, 5vw, 4.1rem);
        font-weight: 950;
        letter-spacing: -0.065em;
        line-height: 1;
        margin-bottom: 12px;
    }

    .seat-hero p {
        color: #aaa;
        max-width: 780px;
        line-height: 1.7;
        margin: 0;
    }

    .designer-btn,
    .filter-btn,
    .mini-designer-btn {
        border-radius: 999px;
        color: #fff;
        border: none;
        background: linear-gradient(135deg, #ff8a85 0%, #e50914 60%, #a9050d 100%);
        box-shadow: 0 14px 32px rgba(229,9,20,0.28);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 950;
        white-space: nowrap;
    }

    .designer-btn {
        min-height: 48px;
        padding: 0 22px;
    }

        .designer-btn:hover,
        .filter-btn:hover,
        .mini-designer-btn:hover {
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 18px 42px rgba(229,9,20,0.38);
        }

    .seat-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .seat-stat-card {
        position: relative;
        overflow: hidden;
        padding: 20px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.09);
        background: rgba(22,22,27,0.92);
        box-shadow: 0 18px 46px rgba(0,0,0,0.26);
    }

        .seat-stat-card.highlight {
            border-left: 4px solid #e50914;
        }

        .seat-stat-card::after {
            content: "";
            position: absolute;
            right: -34px;
            top: -34px;
            width: 96px;
            height: 96px;
            border-radius: 999px;
            background: rgba(229,9,20,0.10);
        }

        .seat-stat-card > span {
            color: #ff5964;
            font-size: 32px;
            margin-bottom: 12px;
            position: relative;
            z-index: 2;
        }

        .seat-stat-card p {
            color: #aaa;
            font-size: 0.76rem;
            font-weight: 850;
            text-transform: uppercase;
            margin: 0 0 6px;
            position: relative;
            z-index: 2;
        }

        .seat-stat-card h3 {
            font-size: 1.9rem;
            font-weight: 950;
            margin: 0;
            position: relative;
            z-index: 2;
        }

        .seat-stat-card.premium h3 {
            color: #ffc94a;
        }

    .seat-layout {
        display: grid;
        grid-template-columns: 330px minmax(0, 1fr);
        gap: 22px;
        align-items: start;
    }

    .seat-sidebar {
        position: sticky;
        top: 90px;
    }

    .side-panel,
    .seat-map-panel {
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.09);
        background: rgba(18,18,22,0.94);
        box-shadow: 0 22px 60px rgba(0,0,0,0.30);
        overflow: hidden;
    }

    .side-panel-header,
    .seat-map-header {
        padding: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(135deg, rgba(255,255,255,0.055), rgba(255,255,255,0.015));
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 14px;
    }

        .side-panel-header h5,
        .seat-map-header h4 {
            font-weight: 950;
            margin-bottom: 4px;
        }

        .side-panel-header p,
        .seat-map-header p {
            color: #999;
            margin: 0;
            font-size: 0.86rem;
        }

        .side-panel-header > span {
            color: #ff5964;
            font-size: 30px;
        }

    .filter-form {
        padding: 18px;
    }

        .filter-form label {
            color: #aaa;
            font-weight: 850;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

    .cinema-select {
        min-height: 48px;
        border-radius: 16px;
        color: #fff;
        background-color: rgba(0,0,0,0.28);
        border: 1px solid rgba(255,255,255,0.12);
        margin-bottom: 12px;
    }

        .cinema-select:focus {
            color: #fff;
            background-color: rgba(0,0,0,0.36);
            border-color: rgba(229,9,20,0.45);
            box-shadow: 0 0 0 0.2rem rgba(229,9,20,0.14);
        }

    .filter-btn {
        min-height: 46px;
        width: 100%;
    }

    .room-info-box {
        padding: 20px;
        text-align: center;
    }

    .room-avatar {
        width: 76px;
        height: 76px;
        margin: 0 auto 14px;
        border-radius: 24px;
        color: #ff5964;
        background: rgba(229,9,20,0.16);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .room-avatar span {
            font-size: 44px;
        }

    .room-info-box h5 {
        font-weight: 950;
        margin-bottom: 4px;
    }

    .room-info-box > p {
        color: #999;
        margin-bottom: 16px;
    }

    .room-info-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        text-align: left;
    }

        .room-info-list > div {
            padding: 12px;
            border-radius: 16px;
            background: rgba(0,0,0,0.22);
            border: 1px solid rgba(255,255,255,0.065);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .room-info-list > div > span {
                color: #ff5964;
                font-size: 24px;
            }

        .room-info-list small {
            color: #888;
            display: block;
            font-size: 0.72rem;
            font-weight: 850;
            text-transform: uppercase;
            margin-bottom: 2px;
        }

        .room-info-list strong {
            color: #fff;
            font-weight: 900;
        }

    .legend-box {
        width: 24px;
        height: 24px;
        border-radius: 8px;
        flex-shrink: 0;
        display: inline-block;
    }

        .legend-box.normal {
            background: linear-gradient(180deg, #444, #2f2f2f);
            border: 1px solid rgba(255,255,255,0.10);
        }

        .legend-box.vip {
            background: linear-gradient(180deg, #fbbf24, #d97706);
            box-shadow: 0 0 18px rgba(245,158,11,0.25);
        }

        .legend-box.couple {
            width: 42px;
            background: linear-gradient(180deg, #a855f7, #7e22ce);
            box-shadow: 0 0 18px rgba(147,51,234,0.25);
        }

        .legend-box.empty {
            background: transparent;
            border: 1px dashed rgba(255,255,255,0.35);
        }

    .seat-map-header {
        padding: 22px 24px;
        align-items: center;
    }

    .mini-designer-btn {
        min-height: 40px;
        padding: 0 16px;
        box-shadow: none;
    }

    .cinema-canvas {
        padding: 34px 26px 26px;
        min-height: 620px;
        background: radial-gradient(circle at top, rgba(255,255,255,0.07), transparent 22%), radial-gradient(circle at bottom, rgba(229,9,20,0.10), transparent 28%), #111116;
    }

    .screen-preview {
        position: relative;
        width: min(100%, 840px);
        margin: 0 auto 54px;
        text-align: center;
        padding-top: 16px;
    }

    .screen-light {
        position: absolute;
        top: -6px;
        left: 50%;
        width: 72%;
        height: 70px;
        transform: translateX(-50%);
        background: radial-gradient(ellipse at center, rgba(255,255,255,0.22), transparent 66%);
        pointer-events: none;
    }

    .screen-line {
        position: relative;
        width: 72%;
        height: 6px;
        margin: 0 auto 12px;
        border-radius: 999px;
        background: linear-gradient(90deg, transparent, #fff, transparent);
        box-shadow: 0 8px 34px rgba(255, 255, 255, 0.58);
    }

    .screen-preview span {
        color: #9c9c9c;
        font-size: 0.76rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 2.8px;
    }

    .seat-preview-wrapper {
        overflow-x: auto;
        padding: 18px 0 28px;
    }

    .seat-preview {
        min-width: max-content;
        display: flex;
        flex-direction: column;
        gap: 10px;
        align-items: center;
        perspective: 1000px;
        transform-origin: top center;
    }

    .seat-preview-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .row-label {
        width: 28px;
        color: #777;
        font-weight: 950;
        text-align: center;
        font-size: 0.78rem;
    }

    .seat-box,
    .seat-empty {
        width: 46px;
        height: 38px;
        border-radius: 12px 12px 8px 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.68rem;
        font-weight: 950;
        transition: all 0.18s ease;
        user-select: none;
    }

        .seat-box:hover {
            transform: translateY(-3px) scale(1.04);
            filter: brightness(1.12);
        }

    .seat-empty {
        border: 1px dashed rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.01);
        opacity: 0.5;
    }

    .seat-box.normal {
        color: #fff;
        background: linear-gradient(180deg, #444, #2f2f2f);
        border: 1px solid rgba(255,255,255,0.10);
        border-bottom: 4px solid #1c1c1c;
    }

    .seat-box.vip {
        color: #fff;
        background: linear-gradient(180deg, #fbbf24, #d97706);
        border: 1px solid rgba(251,191,36,0.70);
        border-bottom: 4px solid #92400e;
        box-shadow: 0 10px 24px rgba(245,158,11,0.14);
    }

    .seat-box.couple {
        color: #fff;
        min-width: 40px;
        background: linear-gradient(180deg, #a855f7, #7e22ce);
        border: 1px solid rgba(168,85,247,0.72);
        border-bottom: 4px solid #581c87;
        box-shadow: 0 10px 24px rgba(147,51,234,0.16);
    }

    .seat-bottom-info {
        margin-top: 22px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.08);
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

        .seat-bottom-info div {
            color: #999;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 0.82rem;
            font-weight: 800;
        }

        .seat-bottom-info span {
            color: #ff5964;
            font-size: 20px;
        }

    .empty-seat-box {
        padding: 90px 20px;
        text-align: center;
    }

    .empty-icon {
        width: 88px;
        height: 88px;
        margin: 0 auto 18px;
        border-radius: 28px;
        background: rgba(229,9,20,0.16);
        color: #ff5964;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .empty-icon span {
            font-size: 52px;
        }

    .empty-seat-box h4 {
        font-weight: 950;
    }

    .empty-seat-box p {
        color: #999;
        margin-bottom: 22px;
    }

    .empty-side {
        color: #999;
        text-align: center;
        padding: 24px 0;
