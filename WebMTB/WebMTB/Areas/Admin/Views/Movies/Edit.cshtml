@model WebMTB.Models.Movie

@{
    ViewData["Title"] = "Chỉnh sửa phim";

    string posterUrl = !string.IsNullOrWhiteSpace(Model.ImageUrl) ? Model.ImageUrl : "";
    string coverUrl = !string.IsNullOrWhiteSpace(Model.CoverImageUrl) ? Model.CoverImageUrl : "";

    string displayStatus = !Model.IsActive
        ? "Hidden"
        : (Model.ReleaseDate.Date > DateTime.Today ? "Upcoming" : "NowShowing");
}

<div class="movie-edit-page container-fluid px-4 px-lg-5 py-4">

    <div class="edit-hero mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-danger">edit_square</span>
                <span class="edit-eyebrow">Movie Editor</span>
            </div>

            <h1 class="edit-title mb-2">Chỉnh sửa phim</h1>
            <p class="edit-subtitle mb-0">
                Cập nhật thông tin, hình ảnh, trailer, thể loại và trạng thái hiển thị của phim
                <span class="text-white fw-bold">@Model.Title</span>.
            </p>
        </div>

        <a asp-action="Index" class="btn edit-back-btn">
            <span class="material-symbols-outlined">arrow_back</span>
            Quay lại
        </a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" class="movie-edit-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <div class="row g-4">

            <div class="col-xl-8">
                <div class="edit-card">
                    <div class="edit-card-header">
                        <div>
                            <h5>Thông tin phim</h5>
                            <p>Nhập nội dung cơ bản sẽ hiển thị cho người xem.</p>
                        </div>
                        <span class="material-symbols-outlined">local_movies</span>
                    </div>

                    <div class="edit-card-body">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label edit-label">Tên phim</label>
                            <input asp-for="Title" class="form-control edit-input" placeholder="Nhập tên phim..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label edit-label">Mô tả nội dung</label>
                            <textarea asp-for="Description" class="form-control edit-input" rows="5" placeholder="Nhập tóm tắt nội dung phim..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Director" class="form-label edit-label">Đạo diễn</label>
                                <input asp-for="Director" class="form-control edit-input" placeholder="Ví dụ: Christopher Nolan" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Cast" class="form-label edit-label">Diễn viên chính</label>
                                <input asp-for="Cast" class="form-control edit-input" placeholder="Ví dụ: Tom Holland, Zendaya..." />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Duration" class="form-label edit-label">Thời lượng</label>
                                <div class="input-icon-wrap">
                                    <span class="material-symbols-outlined">schedule</span>
                                    <input asp-for="Duration" class="form-control edit-input ps-5" type="number" placeholder="120" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Rating" class="form-label edit-label">Đánh giá</label>
                                <div class="input-icon-wrap">
                                    <span class="material-symbols-outlined text-warning">star</span>
                                    <input asp-for="Rating" class="form-control edit-input ps-5" type="number" step="0.1" max="10" placeholder="8.5" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="ReleaseDate" class="form-label edit-label">Ngày khởi chiếu</label>
                                <input asp-for="ReleaseDate" class="form-control edit-input" type="date" />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="AgeRating" class="form-label edit-label text-warning">Giới hạn độ tuổi</label>
                                <select asp-for="AgeRating" class="form-select edit-input">
                                    <option value="P">P - Mọi lứa tuổi</option>
                                    <option value="K">K - Dưới 13 tuổi cần phụ huynh</option>
                                    <option value="13+">T13 - Khán giả từ 13 trở lên</option>
                                    <option value="16+">T16 - Khán giả từ 16 trở lên</option>
                                    <option value="18+">T18 - Khán giả từ 18 trở lên</option>
                                </select>
                            </div>

                            <div class="col-md-8">
                                <label class="form-label edit-label">Thể loại phim</label>
                                <select name="SelectedGenreIds" id="genreSelect" class="form-control" multiple="multiple" style="width: 100%;">
                                    @if (ViewBag.Genres != null)
                                    {
                                        foreach (var genre in (IEnumerable<SelectListItem>)ViewBag.Genres)
                                        {
                                            if (genre.Selected)
                                            {
                                                <option value="@genre.Value" selected>@genre.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@genre.Value">@genre.Text</option>
                                            }
                                        }
                                    }
                                </select>
                                <small class="edit-help-text">
                                    <span class="material-symbols-outlined">info</span>
                                    Chọn nhiều thể loại hoặc gõ thể loại mới rồi nhấn Enter.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="edit-card mt-4">
                    <div class="edit-card-header">
                        <div>
                            <h5>Hình ảnh & Trailer</h5>
                            <p>Cập nhật poster dọc, ảnh bìa ngang và trailer YouTube.</p>
                        </div>
                        <span class="material-symbols-outlined">perm_media</span>
                    </div>

                    <div class="edit-card-body">
                        <div class="mb-3">
                            <label asp-for="CoverImageUrl" class="form-label edit-label text-warning">Đường dẫn ảnh bìa ngang</label>
                            <input asp-for="CoverImageUrl" id="coverInput" class="form-control edit-input" placeholder="Dán link ảnh cover/hero..." />

                            <div class="cover-preview mt-3">
                                <img id="coverPreview"
                                     src="@coverUrl"
                                     alt="Cover Preview"
                                     style="@(string.IsNullOrEmpty(coverUrl) ? "display: none;" : "")" />

                                <div id="coverPlaceholder" class="preview-placeholder" style="@(!string.IsNullOrEmpty(coverUrl) ? "display: none;" : "")">
                                    <span class="material-symbols-outlined">panorama</span>
                                    <p>Xem trước ảnh bìa ngang</p>
                                </div>
                            </div>
                        </div>

                        <div class="mb-0">
                            <label asp-for="TrailerUrl" class="form-label edit-label">Đường dẫn Trailer YouTube</label>
                            <div class="input-icon-wrap">
                                <span class="material-symbols-outlined text-danger">play_circle</span>
                                <input asp-for="TrailerUrl" class="form-control edit-input ps-5" placeholder="https://www.youtube.com/watch?v=..." />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4">
                <div class="edit-side sticky-xl-top">

                    <div class="edit-card poster-card">
                        <div class="edit-card-header">
                            <div>
                                <h5>Poster phim</h5>
                                <p>Ảnh dọc hiển thị ở danh sách phim.</p>
                            </div>
                            <span class="material-symbols-outlined">portrait</span>
                        </div>

                        <div class="edit-card-body">
                            <label asp-for="ImageUrl" class="form-label edit-label text-danger">Đường dẫn poster dọc</label>
                            <input asp-for="ImageUrl" id="imageInput" class="form-control edit-input" placeholder="Dán link poster..." />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>

                            <div class="poster-preview mt-3">
                                <img id="imagePreview"
                                     src="@posterUrl"
                                     alt="Poster Preview"
                                     style="@(string.IsNullOrEmpty(posterUrl) ? "display: none;" : "")" />

                                <div id="previewPlaceholder" class="preview-placeholder" style="@(!string.IsNullOrEmpty(posterUrl) ? "display: none;" : "")">
                                    <span class="material-symbols-outlined">portrait</span>
                                    <p>Xem trước poster</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="edit-card mt-4">
                        <div class="edit-card-header">
                            <div>
                                <h5>Trạng thái</h5>
                                <p>Điều khiển phim ngoài trang chủ.</p>
                            </div>
                            <span class="material-symbols-outlined">tune</span>
                        </div>

                        <div class="edit-card-body">
                            <label class="status-toggle-card mb-3">
                                <input class="form-check-input" asp-for="IsHot" />
                                <div>
                                    <strong>Phim hot</strong>
                                    <small>Hiển thị ở khu vực phim nổi bật.</small>
                                </div>
                                <span class="material-symbols-outlined text-danger">local_fire_department</span>
                            </label>

                            <input type="hidden" asp-for="IsActive" id="isActiveInput" />

                            <div class="movie-status-group">
                                <label class="status-toggle-card status-radio-card mb-3">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="DisplayStatus"
                                           value="NowShowing"
                                           checked="@(displayStatus == "NowShowing")" />

                                    <div>
                                        <strong>Đang chiếu</strong>
                                        <small>Hiển thị ở mục Phim Đang Chiếu và cho phép đặt vé.</small>
                                    </div>

                                    <span class="material-symbols-outlined text-success">play_circle</span>
                                </label>

                                <label class="status-toggle-card status-radio-card mb-3">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="DisplayStatus"
                                           value="Upcoming"
                                           checked="@(displayStatus == "Upcoming")" />

                                    <div>
                                        <strong>Phim sắp chiếu</strong>
                                        <small>Hiển thị ở mục Phim Sắp Chiếu ngoài trang chủ.</small>
                                    </div>

                                    <span class="material-symbols-outlined text-warning">event_upcoming</span>
                                </label>

                                <label class="status-toggle-card status-radio-card">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="DisplayStatus"
                                           value="Hidden"
                                           checked="@(displayStatus == "Hidden")" />

                                    <div>
                                        <strong>Ẩn phim</strong>
                                        <small>Không hiển thị phim ngoài trang người dùng.</small>
                                    </div>

                                    <span class="material-symbols-outlined text-secondary">visibility_off</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="edit-submit-panel mt-4">
                        <button type="submit" class="btn save-btn">
                            <span class="material-symbols-outlined">save</span>
                            Lưu thay đổi
                        </button>

                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn preview-btn">
                            <span class="material-symbols-outlined">visibility</span>
                            Xem chi tiết
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </form>
</div>

<style>
    .movie-edit-page {
        color: #fff;
    }

    .edit-hero {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 28px;
        background: radial-gradient(circle at top left, rgba(229, 9, 20, 0.22), transparent 34%), linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
    }

        .edit-hero::after {
            content: "";
            position: absolute;
            top: -90px;
            right: -80px;
            width: 240px;
            height: 240px;
            border-radius: 999px;
            background: rgba(229, 9, 20, 0.16);
            filter: blur(12px);
            pointer-events: none;
        }

    .edit-eyebrow {
        color: #ff6b73;
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1.4px;
    }

    .edit-title {
        color: #fff;
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        font-weight: 950;
        letter-spacing: -0.05em;
        text-transform: uppercase;
    }

    .edit-subtitle {
        color: #a7a7a7;
        max-width: 820px;
        font-size: 0.95rem;
    }

    .edit-back-btn {
        position: relative;
        z-index: 2;
        min-height: 44px;
        padding: 0 18px;
        border-radius: 999px;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
        white-space: nowrap;
    }

        .edit-back-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.12);
            transform: translateY(-2px);
        }

    .edit-card {
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(18, 18, 22, 0.88);
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
    }

    .edit-card-header {
        padding: 20px 22px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.015));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

        .edit-card-header h5 {
            color: #fff;
            font-weight: 900;
            letter-spacing: -0.02em;
            margin-bottom: 4px;
        }

        .edit-card-header p {
            color: #929292;
            font-size: 0.85rem;
            margin: 0;
        }

        .edit-card-header > span {
            color: #ff5964;
            font-size: 30px;
        }

    .edit-card-body {
        padding: 22px;
    }

    .edit-label {
        color: #dcdcdc;
        font-size: 0.82rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
    }

    .edit-input {
        min-height: 46px;
        color: #fff !important;
        background: rgba(255, 255, 255, 0.055) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 14px !important;
        box-shadow: none !important;
        transition: all 0.2s ease;
    }

    textarea.edit-input {
        resize: vertical;
    }

    .edit-input::placeholder {
        color: #777;
    }

    .edit-input:focus {
        color: #fff !important;
        background: rgba(255, 255, 255, 0.08) !important;
        border-color: rgba(229, 9, 20, 0.65) !important;
        box-shadow: 0 0 0 0.2rem rgba(229, 9, 20, 0.12) !important;
    }

    .movie-edit-form select option {
        background-color: #1a1a1a !important;
        color: #fff !important;
    }

    .input-icon-wrap {
        position: relative;
    }

        .input-icon-wrap > span {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 3;
            color: #9a9a9a;
            font-size: 20px;
            pointer-events: none;
        }

    .edit-help-text {
        color: #8e8e8e;
        font-size: 0.78rem;
        display: flex;
        align-items: center;
        gap: 5px;
        margin-top: 8px;
    }

        .edit-help-text .material-symbols-outlined {
            font-size: 16px;
        }

    .cover-preview,
    .poster-preview {
        position: relative;
        overflow: hidden;
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
        border: 1px dashed rgba(255, 255, 255, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cover-preview {
        width: 100%;
        height: 210px;
    }

    .poster-preview {
        width: 100%;
        max-width: 300px;
        aspect-ratio: 2 / 3;
        margin-left: auto;
        margin-right: auto;
    }

        .cover-preview img,
        .poster-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .preview-placeholder {
        color: #8f8f8f;
        text-align: center;
        padding: 18px;
    }

        .preview-placeholder span {
            color: #666;
            font-size: 42px;
            display: block;
            margin-bottom: 8px;
        }

        .preview-placeholder p {
            margin: 0;
            font-size: 0.88rem;
        }

    .status-toggle-card {
        min-height: 76px;
        padding: 16px;
        border-radius: 18px;
        color: #fff;
        background: rgba(255, 255, 255, 0.045);
        border: 1px solid rgba(255, 255, 255, 0.08);
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .status-toggle-card:hover {
            background: rgba(255, 255, 255, 0.07);
            border-color: rgba(229, 9, 20, 0.24);
            transform: translateY(-2px);
        }

        .status-toggle-card input {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .status-toggle-card strong {
            display: block;
            font-size: 0.95rem;
            font-weight: 900;
            margin-bottom: 2px;
        }

        .status-toggle-card small {
            color: #929292;
            font-size: 0.78rem;
        }

        .status-toggle-card > span {
            font-size: 26px;
        }

    .edit-submit-panel {
        padding: 18px;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(18, 18, 22, 0.88);
        display: grid;
        gap: 10px;
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.24);
    }

    .save-btn,
    .preview-btn {
        min-height: 48px;
        border-radius: 999px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.35px;
        transition: all 0.25s ease;
    }

    .save-btn {
        color: #fff;
        background: linear-gradient(135deg, #ff8a85 0%, #e50914 60%, #a9050d 100%);
        box-shadow: 0 12px 28px rgba(229, 9, 20, 0.28);
    }

        .save-btn:hover {
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 18px 38px rgba(229, 9, 20, 0.4);
        }

    .preview-btn {
        color: #fff;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

        .preview-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.12);
            transform: translateY(-2px);
        }

    /* Select2 Dark Theme */
    .select2-container--default .select2-selection--multiple {
        min-height: 46px;
        color: #fff !important;
        background: rgba(255, 255, 255, 0.055) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 14px !important;
        padding: 4px 8px;
    }

    .select2-container--default.select2-container--focus .select2-selection--multiple {
        border-color: rgba(229, 9, 20, 0.65) !important;
        box-shadow: 0 0 0 0.2rem rgba(229, 9, 20, 0.12) !important;
    }

    .select2-container--default .select2-selection--multiple .select2-selection__choice {
        color: #fff !important;
        background: linear-gradient(135deg, #e50914, #a9050d) !important;
        border: none !important;
        border-radius: 999px !important;
        padding: 4px 10px !important;
        margin-top: 5px !important;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
        color: #fff !important;
        margin-right: 6px !important;
        border: none !important;
    }

    .select2-container--default .select2-search--inline .select2-search__field {
        color: #fff !important;
        margin-top: 8px !important;
        font-family: inherit !important;
    }

    .select2-dropdown {
        color: #fff !important;
        background: #151515 !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        border-radius: 14px !important;
        overflow: hidden;
    }

    .select2-results__option {
        padding: 10px 12px !important;
    }

    .select2-container--default .select2-results__option--highlighted[aria-selected] {
        background-color: #e50914 !important;
        color: #fff !important;
    }

    .select2-container--default .select2-results__option[aria-selected=true] {
        background-color: rgba(229, 9, 20, 0.25) !important;
        color: #fff !important;
    }


    .movie-status-group {
        display: grid;
        gap: 0;
    }

    .status-radio-card {
        position: relative;
    }

        .status-radio-card input[type="radio"] {
            accent-color: #e50914;
        }

        .status-radio-card:has(input[type="radio"]:checked) {
            background: linear-gradient(135deg, rgba(229, 9, 20, 0.22), rgba(255,255,255,0.055));
            border-color: rgba(229, 9, 20, 0.55);
            box-shadow: 0 14px 34px rgba(229, 9, 20, 0.14);
        }

        .status-radio-card:has(input[value="Upcoming"]:checked) {
            background: linear-gradient(135deg, rgba(255, 193, 7, 0.18), rgba(255,255,255,0.055));
            border-color: rgba(255, 193, 7, 0.5);
        }

        .status-radio-card:has(input[value="Hidden"]:checked) {
            background: linear-gradient(135deg, rgba(108, 117, 125, 0.22), rgba(255,255,255,0.045));
            border-color: rgba(108, 117, 125, 0.5);
        }

    @@media (max-width: 991.98px) {
        .edit-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .edit-back-btn {
            width: 100%;
            justify-content: center;
        }

        .edit-side {
            position: static !important;
        }
    }

    @@media (max-width: 575.98px) {
        .movie-edit-page {
            padding-left: 16px !important;
            padding-right: 16px !important;
        }

        .edit-hero {
            padding: 22px;
            border-radius: 20px;
        }

        .edit-title {
            font-size: 1.55rem;
        }

        .edit-card,
        .edit-submit-panel {
            border-radius: 20px;
        }

        .edit-card-body {
            padding: 18px;
        }

        .cover-preview {
            height: 160px;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
        $('#genreSelect').select2({
        tags: true,
        placeholder: "Chọn hoặc nhập thể loại...",
        allowClear: true,
        width: '100%'
        });

        function setupImagePreview(inputId, previewImgId, placeholderId) {
        const $input = $('#' + inputId);
        const $preview = $('#' + previewImgId);
        const $placeholder = $('#' + placeholderId);

        function showPlaceholder(html) {
        $preview.hide();
        $placeholder.show();

        if (html) {
        $placeholder.html(html);
        }
        }

        function updatePreview() {
        const url = $input.val().trim();

        if (url !== "") {
        $preview.attr('src', url);
        $preview.show();
        $placeholder.hide();
        } else {
        showPlaceholder();
        }
        }

        $input.on('input propertychange', updatePreview);

        $preview.on('error', function () {
        showPlaceholder(
        '<span class="material-symbols-outlined text-danger">broken_image</span>' +
        '<p class="text-danger small m-0">Link ảnh lỗi!</p>'
        );
        });

        if ($input.val()) {
        updatePreview();
        }
        }

        setupImagePreview('imageInput', 'imagePreview', 'previewPlaceholder');
        setupImagePreview('coverInput', 'coverPreview', 'coverPlaceholder');

        function formatDate(date) {
        return date.toISOString().split('T')[0];
        }

        function syncMovieStatus() {
        const selected = document.querySelector('input[name="DisplayStatus"]:checked');
        const isActiveInput = document.getElementById('isActiveInput');
        const releaseDateInput = document.querySelector('input[name="ReleaseDate"]');

        if (!selected || !isActiveInput) return;

        const today = new Date();
        today.setHours(0, 0, 0, 0);

        if (selected.value === 'Hidden') {
        isActiveInput.value = 'false';
        return;
        }

        isActiveInput.value = 'true';

        if (!releaseDateInput) return;

        const currentValue = releaseDateInput.value;
        const currentDate = currentValue ? new Date(currentValue + 'T00:00:00') : null;

        if (selected.value === 'Upcoming') {
        if (!currentDate || currentDate <= today) {
        const nextMonth = new Date(today);
        nextMonth.setDate(nextMonth.getDate() + 30);
        releaseDateInput.value = formatDate(nextMonth);
        }
        }

        if (selected.value === 'NowShowing') {
        if (!currentDate || currentDate > today) {
        releaseDateInput.value = formatDate(today);
        }
        }
        }

        document.querySelectorAll('input[name="DisplayStatus"]').forEach(function (radio) {
        radio.addEventListener('change', syncMovieStatus);
        });

        syncMovieStatus();

        });
    </script>
}