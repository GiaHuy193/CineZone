@section Scripts {
    <script>
        const movieSearchInput = document.getElementById("movieSearchInput");
        const movieRows = document.querySelectorAll("#movieTable tbody tr.movie-row");
        const noMovieRow = document.getElementById("noMovieRow");
        const filterButtons = document.querySelectorAll(".movie-filter-btn, .stat-filter");
        const tableTitle = document.getElementById("tableTitle");
        const tableSubtitle = document.getElementById("tableSubtitle");

        let currentFilter = "all";

        const filterText = {
            all: {
                title: "Tất cả phim",
                subtitle: "Hiển thị toàn bộ phim đang có trong hệ thống."
            },
            now: {
                title: "Phim đang chiếu",
                subtitle: "Những phim đang active và ngày khởi chiếu không lớn hơn hôm nay."
            },
            upcoming: {
                title: "Phim sắp chiếu",
                subtitle: "Những phim đang active nhưng ngày khởi chiếu ở tương lai."
            },
            paused: {
                title: "Phim tạm dừng",
                subtitle: "Những phim đã bị ẩn khỏi trang người dùng."
            },
            hot: {
                title: "Phim hot",
                subtitle: "Những phim được đánh dấu nổi bật trong hệ thống."
            }
        };

        function setActiveFilterButton(filter) {
            filterButtons.forEach(button => {
                button.classList.toggle("active", button.dataset.filter === filter);
            });
        }

        function applyMovieFilter() {
            const keyword = movieSearchInput ? movieSearchInput.value.toLowerCase().trim() : "";
            let visibleCount = 0;

            movieRows.forEach(row => {
                const text = row.innerText.toLowerCase();
                const status = row.dataset.status;
                const isHot = row.dataset.hot === "true";

                const matchKeyword = keyword === "" || text.includes(keyword);

                let matchFilter = true;

                if (currentFilter === "now") {
                    matchFilter = status === "now";
                }
                else if (currentFilter === "upcoming") {
                    matchFilter = status === "upcoming";
                }
                else if (currentFilter === "paused") {
                    matchFilter = status === "paused";
                }
                else if (currentFilter === "hot") {
                    matchFilter = isHot;
                }

                const shouldShow = matchKeyword && matchFilter;
                row.style.display = shouldShow ? "" : "none";

                if (shouldShow) {
                    visibleCount++;
                }
            });

            if (noMovieRow) {
                noMovieRow.style.display = visibleCount === 0 ? "" : "none";
            }

            if (tableTitle && tableSubtitle && filterText[currentFilter]) {
                tableTitle.textContent = filterText[currentFilter].title;
                tableSubtitle.textContent = filterText[currentFilter].subtitle;
            }
        }

        filterButtons.forEach(button => {
            button.addEventListener("click", function () {
                currentFilter = this.dataset.filter || "all";
                setActiveFilterButton(currentFilter);
                applyMovieFilter();
            });
        });

        if (movieSearchInput) {
            movieSearchInput.addEventListener("input", applyMovieFilter);
        }
    </script>
}
