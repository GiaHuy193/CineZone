<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin CineZone</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
          rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            :root {
                --admin-bg: #0d0d0f;
                --admin-sidebar: #151517;
                --admin-border: rgba(255, 255, 255, 0.08);
                --admin-text: #ffffff;
                --admin-muted: #9b9b9b;
                --admin-red: #e50914;
                --admin-red-soft: rgba(229, 9, 20, 0.15);
                --sidebar-collapsed: 76px;
                --sidebar-expanded: 260px;
            }

            html,
            body {
                min-height: 100%;
            }

            body {
                margin: 0;
                background: radial-gradient(circle at top left, rgba(229, 9, 20, 0.12), transparent 32%), var(--admin-bg);
                color: var(--admin-text);
                font-family: 'Be Vietnam Pro', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                overflow-x: hidden;
            }

            a {
                text-decoration: none;
            }

            .admin-shell {
                min-height: 100vh;
                display: flex;
            }

            /* ================= SIDEBAR ================= */

            #sidebar {
                width: var(--sidebar-collapsed);
                min-height: 100vh;
                background: linear-gradient(180deg, #171719 0%, #101012 100%);
                border-right: 1px solid var(--admin-border);
                position: fixed;
                left: 0;
                top: 0;
                z-index: 1050;
                overflow: hidden;
                white-space: nowrap;
                transition: width 0.25s ease, box-shadow 0.25s ease;
                box-shadow: 10px 0 34px rgba(0, 0, 0, 0.28);
            }

                #sidebar:hover {
                    width: var(--sidebar-expanded);
                    box-shadow: 18px 0 50px rgba(0, 0, 0, 0.42);
                }

            .sidebar-brand {
                height: 72px;
                padding: 0 20px;
                display: flex;
                align-items: center;
                color: #fff;
                background: radial-gradient(circle at top left, rgba(255,255,255,0.18), transparent 34%), linear-gradient(135deg, #e50914 0%, #8a050c 100%);
                border-bottom: 1px solid rgba(255,255,255,0.08);
            }

                .sidebar-brand:hover {
                    color: #fff;
                }

                .sidebar-brand .material-symbols-outlined {
                    font-size: 34px;
                    flex: 0 0 34px;
                }

            .sidebar-brand-text {
                margin-left: 15px;
                font-size: 1.1rem;
                font-weight: 950;
                letter-spacing: -0.03em;
                opacity: 0;
                transform: translateX(-8px);
                transition: opacity 0.2s ease, transform 0.2s ease;
            }

            #sidebar:hover .sidebar-brand-text {
                opacity: 1;
                transform: translateX(0);
            }

            .sidebar-menu {
                list-style: none;
                margin: 0;
                padding: 14px 0;
            }

                .sidebar-menu li {
                    margin: 2px 10px;
                }

                    .sidebar-menu li a {
                        min-height: 48px;
                        padding: 0 15px;
                        border-radius: 14px;
                        display: flex;
                        align-items: center;
                        color: #bdbdbd;
                        transition: all 0.18s ease;
                        border: 1px solid transparent;
                    }

                        .sidebar-menu li a:hover {
                            color: #fff;
                            background: rgba(255,255,255,0.06);
                            border-color: rgba(255,255,255,0.08);
                        }

                    .sidebar-menu li.active a {
                        color: #fff;
                        background: var(--admin-red-soft);
                        border-color: rgba(229, 9, 20, 0.35);
                        box-shadow: inset 3px 0 0 var(--admin-red);
                    }

                .sidebar-menu .material-symbols-outlined {
                    font-size: 26px;
                    flex: 0 0 28px;
                }

            .menu-text {
                margin-left: 15px;
                font-size: 0.9rem;
                font-weight: 750;
                opacity: 0;
                transform: translateX(-8px);
                transition: opacity 0.2s ease, transform 0.2s ease;
            }

            #sidebar:hover .menu-text {
                opacity: 1;
                transform: translateX(0);
            }

            .sidebar-divider-item {
                margin: 0 !important;
            }

            .sidebar-divider {
                height: 1px;
                margin: 12px 18px;
                background: rgba(255,255,255,0.09);
            }

            /* ================= CONTENT ================= */

            #content {
                width: calc(100% - var(--sidebar-collapsed));
                margin-left: var(--sidebar-collapsed);
                min-height: 100vh;
                padding: 22px 24px 28px;
                transition: margin-left 0.25s ease, width 0.25s ease;
            }

            #sidebar:hover + #content {
                margin-left: var(--sidebar-expanded);
                width: calc(100% - var(--sidebar-expanded));
            }

            .admin-topbar {
                min-height: 58px;
                margin-bottom: 22px;
                padding: 0 4px;
                display: flex;
                align-items: center;
                justify-content: flex-end;
                gap: 14px;
            }

            .admin-user-pill {
                min-height: 40px;
                padding: 0 14px;
                border-radius: 999px;
                color: #fff;
                background: rgba(255,255,255,0.055);
                border: 1px solid rgba(255,255,255,0.1);
                display: inline-flex;
                align-items: center;
                gap: 8px;
                font-size: 0.82rem;
                font-weight: 850;
                letter-spacing: 0.5px;
                text-transform: uppercase;
            }

            .logout-btn {
                min-height: 40px;
                border-radius: 999px;
                padding: 0 16px;
                font-weight: 800;
            }

            main {
                min-height: calc(100vh - 100px);
            }

            .admin-card {
                background: rgba(18,18,22,0.9);
                border: 1px solid rgba(255,255,255,0.09);
                border-radius: 22px;
                box-shadow: 0 20px 50px rgba(0,0,0,0.28);
            }

            /* ================= RESPONSIVE ================= */

            @@media (max-width: 991.98px) {
                #sidebar {
                    width: var(--sidebar-collapsed);
                }

                    #sidebar:hover {
                        width: var(--sidebar-expanded);
                    }

                #content {
                    width: calc(100% - var(--sidebar-collapsed));
                    margin-left: var(--sidebar-collapsed);
                    padding: 18px 16px 24px;
                }

                #sidebar:hover + #content {
                    margin-left: var(--sidebar-expanded);
                    width: calc(100% - var(--sidebar-expanded));
                }

                .admin-topbar {
                    justify-content: space-between;
                }
            }

            @@media (max-width: 575.98px) {
                :root {
                    --sidebar-collapsed: 64px;
                    --sidebar-expanded: 230px;
                }

                .sidebar-brand {
                    padding: 0 15px;
                }

                .sidebar-menu li {
                    margin: 2px 8px;
                }

                    .sidebar-menu li a {
                        padding: 0 12px;
                    }

                .admin-user-pill {
                    display: none;
                }
            }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    @{
        string currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    }

    <div class="admin-shell">
        <nav id="sidebar">
            <a class="sidebar-brand"
               asp-area="Admin"
               asp-controller="Dashboard"
               asp-action="Index">
                <span class="material-symbols-outlined">movie_filter</span>
                <span class="sidebar-brand-text">CINEZONE</span>
            </a>

            <ul class="sidebar-menu">
                <li class="@(currentController == "Dashboard" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <span class="material-symbols-outlined">dashboard</span>
                        <span class="menu-text">Dashboard</span>
                    </a>
                </li>

                <li class="@(currentController == "Movies" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Movies" asp-action="Index">
                        <span class="material-symbols-outlined">movie</span>
                        <span class="menu-text">Quản lý phim</span>
                    </a>
                </li>

                <li class="@(currentController == "Cinemas" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Cinemas" asp-action="Index">
                        <span class="material-symbols-outlined">apartment</span>
                        <span class="menu-text">Rạp chiếu</span>
                    </a>
                </li>

                <li class="@(currentController == "Rooms" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Rooms" asp-action="Index">
                        <span class="material-symbols-outlined">meeting_room</span>
                        <span class="menu-text">Phòng chiếu</span>
                    </a>
                </li>

                <li class="@(currentController == "Seats" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Seats" asp-action="Index">
                        <span class="material-symbols-outlined">event_seat</span>
                        <span class="menu-text">Ghế ngồi</span>
                    </a>
                </li>

                <li class="@(currentController == "Showtimes" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Showtimes" asp-action="Index">
                        <span class="material-symbols-outlined">schedule</span>
                        <span class="menu-text">Suất chiếu</span>
                    </a>
                </li>

                @* Nếu bạn chưa có Admin/BookingsController thì tạm comment mục này *@
                <li class="@(currentController == "Bookings" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Bookings" asp-action="Index">
                        <span class="material-symbols-outlined">confirmation_number</span>
                        <span class="menu-text">Quản lý vé</span>
                    </a>
                </li>

                @* Liên hệ hỗ trợ *@
                <li class="@(currentController == "ContactMessages" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index">
                        <span class="material-symbols-outlined">support_agent</span>
                        <span class="menu-text">Liên hệ hỗ trợ</span>
                    </a>
                </li>

                @* Nếu bạn chưa có Admin/UsersController thì tạm comment mục này *@
                <li class="@(currentController == "Users" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <span class="material-symbols-outlined">person</span>
                        <span class="menu-text">Người dùng</span>
                    </a>
                </li>

                <li class="sidebar-divider-item">
                    <div class="sidebar-divider"></div>
                </li>

                <li>
                    <a asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="material-symbols-outlined">home</span>
                        <span class="menu-text">Quay lại Website</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div id="content">
            <nav class="admin-topbar">
                <div></div>

                <div class="d-flex align-items-center gap-2">
                    <span class="admin-user-pill">
                        <span class="material-symbols-outlined fs-6">admin_panel_settings</span>
                        Admin
                    </span>

                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger logout-btn">
                            Đăng xuất
                        </button>
                    </form>
                </div>
            </nav>

            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>