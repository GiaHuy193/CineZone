</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const mapFrame = document.getElementById("roomCinemaMap");
        const openMapLink = document.getElementById("openRoomMapLink");
        const searchInput = document.getElementById("roomSearchInput");
        const noRoomResult = document.getElementById("noRoomResult");

        const dropdown = document.getElementById("cinemaDropdown");
        const dropdownBtn = document.getElementById("cinemaDropdownBtn");
        const selectedCinemaText = document.getElementById("selectedCinemaText");
        const selectedCinemaCount = document.getElementById("selectedCinemaCount");

        const mapLoader = document.getElementById("mapLoader");
        const mapSection = document.getElementById("roomMapSection");

        let activeCinema = "all";
        let currentMapQuery = "@firstMapQuery";

        function scrollToMapSection() {
            if (!mapSection) {
                return;
            }

            const adminOffset = 90;
            const targetTop = mapSection.getBoundingClientRect().top + window.pageYOffset - adminOffset;

            window.scrollTo({
                top: targetTop,
                behavior: "smooth"
            });
        }

        function buildMapUrl(query) {
            return `https://www.google.com/maps?q=${query}&output=embed`;
        }

        function updateMap(query) {
            if (!query || !mapFrame) {
                scrollToMapSection();
                return;
            }

            if (openMapLink) {
                openMapLink.href = `https://www.google.com/maps/search/?api=1&query=${query}`;
            }

            scrollToMapSection();

            if (query === currentMapQuery) {
                return;
            }

            currentMapQuery = query;

            if (mapLoader) {
                mapLoader.classList.add("active");
            }

            mapFrame.src = buildMapUrl(query);
        }

        if (mapFrame) {
            mapFrame.addEventListener("load", function () {
                if (mapLoader) {
                    mapLoader.classList.remove("active");
                }
            });
        }

        function applyFilters() {
            const keyword = (searchInput?.value || "").trim().toLowerCase();
            let visibleRoomCount = 0;

            document.querySelectorAll(".room-group").forEach(group => {
                const groupCinema = group.getAttribute("data-cinema-group");
                const matchCinema = activeCinema === "all" || groupCinema === activeCinema;

                let groupHasVisibleRoom = false;

                group.querySelectorAll(".room-row").forEach(row => {
                    const searchText = row.getAttribute("data-search") || "";
                    const matchKeyword = !keyword || searchText.includes(keyword);

                    const isVisible = matchCinema && matchKeyword;

                    row.style.display = isVisible ? "" : "none";

                    if (isVisible) {
                        groupHasVisibleRoom = true;
                        visibleRoomCount++;
                    }
                });

                group.style.display = groupHasVisibleRoom ? "" : "none";
            });

            if (noRoomResult) {
                noRoomResult.classList.toggle("d-none", visibleRoomCount > 0);
            }
        }

        if (dropdown && dropdownBtn) {
            dropdownBtn.addEventListener("click", function () {
                const isOpen = dropdown.classList.toggle("open");
                dropdownBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
            });

            document.querySelectorAll(".cinema-option").forEach(option => {
                option.addEventListener("click", function () {
                    activeCinema = this.getAttribute("data-cinema") || "all";

                    document.querySelectorAll(".cinema-option").forEach(btn => {
                        btn.classList.remove("active");
                    });

                    this.classList.add("active");

                    if (selectedCinemaText) {
                        selectedCinemaText.textContent = this.getAttribute("data-label") || "Tất cả rạp";
                    }

                    if (selectedCinemaCount) {
                        selectedCinemaCount.textContent = this.getAttribute("data-count") || "";
                    }

                    dropdown.classList.remove("open");
                    dropdownBtn.setAttribute("aria-expanded", "false");

                    applyFilters();
                });
            });

            document.addEventListener("click", function (event) {
                if (!dropdown.contains(event.target)) {
                    dropdown.classList.remove("open");
                    dropdownBtn.setAttribute("aria-expanded", "false");
                }
            });

            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape") {
                    dropdown.classList.remove("open");
                    dropdownBtn.setAttribute("aria-expanded", "false");
                }
            });
        }

        document.querySelectorAll(".map-pin-btn").forEach(button => {
            button.addEventListener("click", function () {
                const query = this.getAttribute("data-map-query");
                updateMap(query);
            });
        });

        if (searchInput) {
            searchInput.addEventListener("input", applyFilters);
        }

        applyFilters();
    });
</script>