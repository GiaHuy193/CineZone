@model IEnumerable<WebMTB.Models.Room>

@{
    ViewData["Title"] = "Quản lý phòng chiếu";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var rooms = Model?.ToList() ?? new List<WebMTB.Models.Room>();

    int totalRooms = rooms.Count;

    int totalCinemas = rooms
        .Where(r => r.Cinema != null)
        .Select(r => r.Cinema!.Id)
        .Distinct()
        .Count();

    int totalSeats = rooms.Sum(r => r.Seats?.Count ?? 0);

    int roomsWithoutSeats = rooms.Count(r => (r.Seats?.Count ?? 0) == 0);

    var firstCinema = rooms.FirstOrDefault(r => r.Cinema != null)?.Cinema;

    string firstMapQuery = firstCinema != null
        ? Uri.EscapeDataString($"{firstCinema.Name} {firstCinema.Address}")
        : Uri.EscapeDataString("Ho Chi Minh City Vietnam");

    var groupedRooms = rooms
        .GroupBy(r => r.Cinema?.Name ?? "Chưa có rạp")
        .OrderBy(g => g.Key)
        .ToList();

    Func<string, string> makeKey = value =>
        (value ?? "unknown")
            .Replace(" ", "-")
            .Replace(".", "")
            .Replace(",", "")
            .Replace("/", "-")
            .Replace("(", "")
            .Replace(")", "")
            .ToLowerInvariant();
}

<div class="room-admin-page">
    <div class="room-hero mb-4">
        <div class="hero-content">
            <div class="room-eyebrow">
                <span class="material-symbols-outlined">meeting_room</span>
                CineZone Admin
            </div>

            <h1>Quản lý phòng chiếu</h1>

            <p>
                Theo dõi toàn bộ phòng chiếu theo từng rạp, kiểm tra sức chứa,
                trạng thái ghế và truy cập nhanh vào sơ đồ ghế.
            </p>
        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success admin-alert">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger admin-alert">
            <span class="material-symbols-outlined">warning</span>
            @TempData["Error"]
        </div>
    }

    <div class="room-stats-grid mb-4">
        <div class="room-stat-card stat-red">
            <div class="stat-icon">
                <span class="material-symbols-outlined">meeting_room</span>
            </div>
            <div>
                <p>Tổng phòng</p>
                <h3>@totalRooms</h3>
            </div>
        </div>

        <div class="room-stat-card stat-purple">
            <div class="stat-icon">
                <span class="material-symbols-outlined">apartment</span>
            </div>
            <div>
                <p>Cụm rạp</p>
                <h3>@totalCinemas</h3>
            </div>
        </div>

        <div class="room-stat-card stat-blue">
            <div class="stat-icon">
                <span class="material-symbols-outlined">event_seat</span>
            </div>
            <div>
                <p>Tổng ghế</p>
                <h3>@totalSeats</h3>
            </div>
        </div>

        <div class="room-stat-card stat-yellow">
            <div class="stat-icon">
                <span class="material-symbols-outlined">warning</span>
            </div>
            <div>
                <p>Chưa có ghế</p>
                <h3>@roomsWithoutSeats</h3>
            </div>
        </div>
    </div>

    <div class="room-toolbar mb-4">
        <div class="search-box">
            <span class="material-symbols-outlined">search</span>
            <input type="text"
                   id="roomSearchInput"
                   placeholder="Tìm phòng, rạp hoặc địa chỉ..." />
        </div>

        <div class="cinema-dropdown" id="cinemaDropdown">
            <button type="button"
                    class="cinema-dropdown-btn"
                    id="cinemaDropdownBtn"
                    aria-expanded="false">
                <div class="cinema-select-icon">
                    <span class="material-symbols-outlined">apartment</span>
                </div>

                <div class="cinema-select-text">
                    <label>Lọc theo rạp</label>
                    <strong id="selectedCinemaText">Tất cả rạp</strong>
                    <small id="selectedCinemaCount">@totalRooms phòng</small>
                </div>

                <span class="material-symbols-outlined dropdown-arrow">expand_more</span>
            </button>

            <div class="cinema-dropdown-menu" id="cinemaDropdownMenu">
                <button type="button"
                        class="cinema-option active"
                        data-cinema="all"
                        data-label="Tất cả rạp"
                        data-count="@totalRooms phòng">
                    <span class="material-symbols-outlined">apps</span>
                    <div>
                        <strong>Tất cả rạp</strong>
                        <small>@totalRooms phòng chiếu</small>
                    </div>
                </button>

                @foreach (var group in groupedRooms)
                {
                    string cinemaKey = makeKey(group.Key);
                    int groupSeatCount = group.Sum(r => r.Seats?.Count ?? 0);

                    <button type="button"
                            class="cinema-option"
                            data-cinema="@cinemaKey"
                            data-label="@group.Key"
                            data-count="@group.Count() phòng">
                        <span class="material-symbols-outlined">apartment</span>
                        <div>
                            <strong>@group.Key</strong>
                            <small>@group.Count() phòng · @groupSeatCount ghế</small>
                        </div>
                    </button>
                }
            </div>
        </div>

        <a asp-action="Create" class="btn create-room-btn toolbar-create-btn">
            <span class="material-symbols-outlined">add</span>
            Tạo phòng mới
        </a>
    </div>

    <div class="map-strip mb-4" id="roomMapSection">
        <div class="map-info">
            <div class="map-icon">
                <span class="material-symbols-outlined">map</span>
            </div>

            <div>
                <h5>Bản đồ rạp</h5>
                <p>Bấm biểu tượng vị trí ở từng rạp hoặc phòng, hệ thống sẽ tự kéo lên bản đồ.</p>
            </div>
        </div>

        <div class="map-frame" id="mapFrameBox">
            <div class="map-loader" id="mapLoader">
                <span class="material-symbols-outlined">progress_activity</span>
                Đang tải bản đồ...
            </div>

            <iframe id="roomCinemaMap"
                    src="https://www.google.com/maps?q=@firstMapQuery&output=embed"
                    loading="lazy"
                    allowfullscreen
                    referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>

        <a id="openRoomMapLink"
           href="https://www.google.com/maps/search/?api=1&query=@firstMapQuery"
           target="_blank"
           class="btn open-map-btn">
            <span class="material-symbols-outlined">open_in_new</span>
            Mở Maps
        </a>
    </div>

    <div class="room-panel">
        <div class="room-panel-header">
            <div>
                <h4>Danh sách phòng chiếu</h4>
                <p>Danh sách được gom theo rạp để admin dễ kiểm tra khi một rạp có nhiều phòng.</p>
            </div>

            <span class="material-symbols-outlined">theaters</span>
        </div>

        @if (rooms.Any())
        {
            <div class="room-group-list">
                @for (int groupIndex = 0; groupIndex < groupedRooms.Count; groupIndex++)
                {
                    var group = groupedRooms[groupIndex];

                    string cinemaKey = makeKey(group.Key);
                    string themeClass = $"theme-{groupIndex % 5}";

                    var cinema = group.FirstOrDefault()?.Cinema;
                    string cinemaAddress = cinema?.Address ?? "Chưa cập nhật địa chỉ";

                    string mapQuery = cinema != null
                        ? Uri.EscapeDataString($"{cinema.Name} {cinema.Address}")
                        : Uri.EscapeDataString(group.Key);

                    int groupSeatCount = group.Sum(r => r.Seats?.Count ?? 0);
                    int groupRoomCount = group.Count();

                    <section class="room-group @themeClass" data-cinema-group="@cinemaKey">
                        <div class="cinema-group-header">
                            <div class="cinema-main-info">
                                <div class="cinema-logo">
                                    <span class="material-symbols-outlined">apartment</span>
                                </div>

                                <div>
                                    <div class="cinema-title-line">
                                        <span class="cinema-tag">Rạp chiếu</span>
                                        <h5>@group.Key</h5>
                                    </div>

                                    <p>@cinemaAddress</p>
                                </div>
                            </div>

                            <div class="cinema-summary">
                                <span>
                                    <strong>@groupRoomCount</strong>
                                    phòng
                                </span>

                                <span>
                                    <strong>@groupSeatCount</strong>
                                    ghế
                                </span>

                                <button type="button"
                                        class="map-pin-btn"
                                        data-map-query="@mapQuery"
                                        title="Xem vị trí rạp">
                                    <span class="material-symbols-outlined">location_on</span>
                                </button>
                            </div>
                        </div>

                        <div class="room-table">
                            <div class="room-table-head">
                                <div>Phòng chiếu</div>
                                <div>Loại phòng</div>
                                <div>Sức chứa</div>
                                <div>Trạng thái</div>
                                <div class="text-end">Thao tác</div>
                            </div>

                            @foreach (var item in group.OrderBy(r => r.Name))
                            {
                                int seatCount = item.Seats?.Count ?? 0;

                                string roomType = seatCount >= 150
                                    ? "IMAX"
                                    : seatCount >= 80
                                        ? "Standard"
                                        : seatCount > 0
                                            ? "Mini"
                                            : "Chưa có ghế";

                                string roomClass = seatCount >= 150
                                    ? "imax"
                                    : seatCount >= 80
                                        ? "standard"
                                        : seatCount > 0
                                            ? "mini"
                                            : "empty";

                                string statusText = seatCount > 0 ? "Đã cấu hình ghế" : "Cần tạo ghế";
                                string statusClass = seatCount > 0 ? "active" : "warning";

                                string searchText =
                                    $"{item.Name} {item.Cinema?.Name} {item.Cinema?.Address} {roomType}"
                                        .ToLowerInvariant();

                                <article class="room-row" data-search="@searchText">
                                    <div class="room-name-cell">
                                        <div class="room-mini-icon @roomClass">
                                            <span class="material-symbols-outlined">meeting_room</span>
                                        </div>

                                        <div>
                                            <h6>@item.Name</h6>
                                            <p>@(item.Cinema?.Name ?? "Chưa có rạp")</p>
                                        </div>
                                    </div>

                                    <div>
                                        <span class="room-type-badge @roomClass">
                                            @roomType
                                        </span>
                                    </div>

                                    <div class="capacity-cell">
                                        <span class="material-symbols-outlined">event_seat</span>
                                        <strong>@seatCount</strong>
                                        <small>ghế</small>
                                    </div>

                                    <div>
                                        <span class="room-status-badge @statusClass">
                                            <span></span>
                                            @statusText
                                        </span>
                                    </div>

                                    <div class="room-actions">
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn configure-btn">
                                            <span class="material-symbols-outlined">event_seat</span>
                                            Sơ đồ ghế
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn icon-action-btn"
                                           title="Sửa phòng">
                                            <span class="material-symbols-outlined">edit</span>
                                        </a>

                                        <button type="button"
                                                class="btn icon-action-btn map-row-btn map-pin-btn"
                                                data-map-query="@mapQuery"
                                                title="Xem vị trí rạp">
                                            <span class="material-symbols-outlined">location_on</span>
                                        </button>
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }
            </div>

            <div id="noRoomResult" class="empty-room-box d-none">
                <div class="empty-icon">
                    <span class="material-symbols-outlined">search_off</span>
                </div>

                <h4>Không tìm thấy phòng phù hợp</h4>
                <p>Thử đổi từ khóa tìm kiếm hoặc chọn lại bộ lọc rạp.</p>
            </div>
        }
        else
        {
            <div class="empty-room-box">
                <div class="empty-icon">
                    <span class="material-symbols-outlined">meeting_room</span>
                </div>

                <h4>Chưa có phòng chiếu nào</h4>
                <p>Hãy tạo phòng chiếu trước, sau đó sinh ghế và thiết kế sơ đồ ghế.</p>

                <a asp-action="Create" class="btn create-room-btn">
                    <span class="material-symbols-outlined">add</span>
                    Tạo phòng đầu tiên
                </a>
            </div>
        }
    </div>
</div>

<style>
    .room-admin-page {
        color: #fff;
        min-height: 100vh;
        padding: 28px;
        background: radial-gradient(circle at 8% 0%, rgba(145, 0, 24, 0.34), transparent 30%), radial-gradient(circle at 95% 10%, rgba(229, 9, 20, 0.18), transparent 26%), radial-gradient(circle at 45% 100%, rgba(255, 89, 100, 0.07), transparent 34%), linear-gradient(135deg, #08080a 0%, #101014 48%, #070708 100%);
    }

    .room-hero {
        position: relative;
        overflow: hidden;
        min-height: 170px;
        padding: 28px 30px;
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.09);
        background: radial-gradient(circle at 13% 18%, rgba(160, 0, 25, 0.46), transparent 31%), radial-gradient(circle at 92% 18%, rgba(120, 0, 20, 0.48), transparent 27%), linear-gradient(90deg, #33070f 0%, #0c0c12 42%, #090910 72%, #3b0710 100%);
        box-shadow: 0 20px 55px rgba(0, 0, 0, 0.34), inset 0 1px 0 rgba(255,255,255,0.035);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 22px;
    }

        .room-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 42px 42px;
            opacity: 0.18;
            pointer-events: none;
        }

    .hero-content,
    .hero-create-btn {
        position: relative;
        z-index: 2;
    }

    .room-eyebrow {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        color: #ff8b92;
        background: rgba(229,9,20,0.18);
        border: 1px solid rgba(229,9,20,0.34);
        box-shadow: 0 10px 26px rgba(229,9,20,0.12);
        font-size: 0.72rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 13px;
    }

    .room-hero h1 {
        font-size: clamp(2rem, 3.4vw, 3.4rem);
        font-weight: 950;
        letter-spacing: -0.055em;
        line-height: 1;
        margin-bottom: 10px;
        text-shadow: 0 12px 28px rgba(0,0,0,0.32);
    }

    .room-hero p {
        color: rgba(255,255,255,0.78);
        max-width: 760px;
        line-height: 1.55;
        margin: 0;
        font-size: 0.98rem;
        font-weight: 650;
    }

    .create-room-btn {
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        color: #fff;
        border: none;
        background: linear-gradient(135deg, #ff8b8b 0%, #f4212d 45%, #b80012 100%);
        box-shadow: 0 16px 36px rgba(229,9,20,0.34), inset 0 1px 0 rgba(255,255,255,0.22);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 950;
        white-space: nowrap;
    }

        .create-room-btn:hover {
            color: #fff;
            transform: translateY(-2px);
            background: linear-gradient(135deg, #ffa1a1 0%, #ff1d2b 52%, #d00016 100%);
            box-shadow: 0 20px 48px rgba(229,9,20,0.44);
        }

    .admin-alert {
        border-radius: 18px;
        border: none;
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 750;
    }

    .room-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .room-stat-card {
        position: relative;
        overflow: hidden;
        min-height: 128px;
        padding: 20px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.09);
        background: radial-gradient(circle at bottom right, rgba(229,9,20,0.16), transparent 36%), linear-gradient(135deg, rgba(255,255,255,0.055), rgba(255,255,255,0.018)), rgba(18,18,22,0.96);
        box-shadow: 0 18px 46px rgba(0,0,0,0.30);
        display: flex;
        align-items: center;
        gap: 16px;
    }

        .room-stat-card.stat-purple {
            background: radial-gradient(circle at bottom right, rgba(147,51,234,0.20), transparent 36%), linear-gradient(135deg, rgba(27,18,42,0.98), rgba(18,18,22,0.96));
        }

        .room-stat-card.stat-blue {
            background: radial-gradient(circle at bottom right, rgba(14,165,233,0.18), transparent 36%), linear-gradient(135deg, rgba(12,27,40,0.98), rgba(18,18,22,0.96));
        }

        .room-stat-card.stat-yellow {
            background: radial-gradient(circle at bottom right, rgba(255,193,7,0.20), transparent 36%), linear-gradient(135deg, rgba(42,31,12,0.98), rgba(18,18,22,0.96));
        }

    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        background: rgba(229,9,20,0.16);
        color: #ff5964;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-purple .stat-icon {
        color: #c084fc;
        background: rgba(147,51,234,0.16);
    }

    .stat-blue .stat-icon {
        color: #38bdf8;
        background: rgba(14,165,233,0.14);
    }

    .stat-yellow .stat-icon {
        color: #ffc94a;
        background: rgba(255,193,7,0.13);
    }

    .stat-icon span {
        font-size: 32px;
    }

    .room-stat-card p {
        color: #b9b9c1;
        font-size: 0.76rem;
        font-weight: 850;
        text-transform: uppercase;
        margin: 0 0 6px;
    }

    .room-stat-card h3 {
        color: #fff;
        font-size: 1.9rem;
        font-weight: 950;
        margin: 0;
    }

    .room-toolbar {
        padding: 16px;
        border-radius: 26px;
        border: 1px solid rgba(255,255,255,0.09);
        background: radial-gradient(circle at top right, rgba(229,9,20,0.10), transparent 30%), linear-gradient(135deg, rgba(255,255,255,0.050), rgba(255,255,255,0.018)), rgba(18,18,22,0.96);
        box-shadow: 0 18px 46px rgba(0,0,0,0.26);
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(280px, 420px) auto;
        gap: 14px;
        align-items: center;
    }

    .search-box {
        min-height: 54px;
        padding: 0 16px;
        border-radius: 18px;
        background: rgba(0,0,0,0.26);
        border: 1px solid rgba(255,255,255,0.10);
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .search-box span {
            color: #ff5964;
        }

        .search-box input {
            width: 100%;
            color: #fff;
            background: transparent;
            border: none;
            outline: none;
            font-weight: 850;
        }

            .search-box input::placeholder {
                color: #777;
            }

    .cinema-dropdown {
        position: relative;
        z-index: 20;
    }

    .cinema-dropdown-btn {
        width: 100%;
        min-height: 58px;
        padding: 8px 14px;
        border-radius: 20px;
        border: 1px solid rgba(229,9,20,0.28);
        color: #fff;
        background: radial-gradient(circle at top right, rgba(229,9,20,0.20), transparent 35%), linear-gradient(135deg, rgba(229,9,20,0.17), rgba(255,255,255,0.045)), rgba(0,0,0,0.24);
        display: flex;
        align-items: center;
        gap: 12px;
        text-align: left;
        cursor: pointer;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

        .cinema-dropdown-btn:hover,
        .cinema-dropdown.open .cinema-dropdown-btn {
            border-color: rgba(229,9,20,0.52);
            box-shadow: 0 12px 26px rgba(229,9,20,0.16);
        }

    .cinema-select-icon {
        width: 42px;
        height: 42px;
        border-radius: 15px;
        background: rgba(229,9,20,0.18);
        color: #ff5964;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .cinema-select-text {
        flex: 1;
        min-width: 0;
    }

        .cinema-select-text label {
            display: block;
            color: #a7a7af;
            font-size: 0.68rem;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 2px;
        }

        .cinema-select-text strong {
            display: block;
            color: #fff;
            font-size: 0.96rem;
            font-weight: 950;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .cinema-select-text small {
            display: block;
            color: #ffadb3;
            font-size: 0.72rem;
            font-weight: 850;
            margin-top: 1px;
        }

    .dropdown-arrow {
        color: #ff9ca3;
        transition: transform 0.18s ease;
    }

    .cinema-dropdown.open .dropdown-arrow {
        transform: rotate(180deg);
    }

    .cinema-dropdown-menu {
        position: absolute;
        top: calc(100% + 10px);
        left: 0;
        right: 0;
        max-height: 320px;
        overflow-y: auto;
        padding: 10px;
        border-radius: 22px;
        background: radial-gradient(circle at top right, rgba(229,9,20,0.12), transparent 32%), rgba(16,16,20,0.98);
        border: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 24px 60px rgba(0,0,0,0.55);
        display: none;
    }

    .cinema-dropdown.open .cinema-dropdown-menu {
        display: block;
    }

    .cinema-option {
        width: 100%;
        min-height: 58px;
        padding: 10px 12px;
        border-radius: 16px;
        border: 1px solid transparent;
        color: #ddd;
        background: transparent;
        display: flex;
        align-items: center;
        gap: 11px;
        text-align: left;
        cursor: pointer;
    }

        .cinema-option:hover {
            color: #fff;
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.08);
        }

        .cinema-option.active {
            color: #fff;
