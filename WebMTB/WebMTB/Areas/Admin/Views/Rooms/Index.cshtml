<script>
    document.addEventListener("DOMContentLoaded", function () {
        const mapFrame = document.getElementById("roomCinemaMap");
        const openMapLink = document.getElementById("openRoomMapLink");

        document.querySelectorAll(".map-pin-btn").forEach(button => {
            button.addEventListener("click", function () {
                const query = this.getAttribute("data-map-query");

                if (!query || !mapFrame) {
                    return;
                }

                mapFrame.src = `https://www.google.com/maps?q=${query}&output=embed`;

                if (openMapLink) {
                    openMapLink.href = `https://www.google.com/maps/search/?api=1&query=${query}`;
                }

                document.querySelector(".map-panel")?.scrollIntoView({
                    behavior: "smooth",
                    block: "center"
                });
            });
        });

        document.querySelectorAll(".cinema-filter").forEach(button => {
            button.addEventListener("click", function () {
                const cinema = this.getAttribute("data-cinema");

                document.querySelectorAll(".cinema-filter").forEach(btn => {
                    btn.classList.remove("active");

                    const icon = btn.querySelector(".material-symbols-outlined");
                    if (icon) {
                        icon.textContent = "radio_button_unchecked";
                    }
                });

                this.classList.add("active");

                const activeIcon = this.querySelector(".material-symbols-outlined");
                if (activeIcon) {
                    activeIcon.textContent = "radio_button_checked";
                }

                document.querySelectorAll(".room-group").forEach(group => {
                    const groupCinema = group.getAttribute("data-cinema-group");

                    if (cinema === "all" || groupCinema === cinema) {
                        group.style.display = "";
                    } else {
                        group.style.display = "none";
                    }
                });
            });
        });
    });
</script>