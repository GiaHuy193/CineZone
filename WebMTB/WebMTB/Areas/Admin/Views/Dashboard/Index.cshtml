@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        flatpickr("#fromDatePicker", {
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d/m/Y",
        altInputClass: "filter-input dashboard-date-alt",
        locale: "vn",
        allowInput: false,
        disableMobile: true
        });

        flatpickr("#toDatePicker", {
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d/m/Y",
        altInputClass: "filter-input dashboard-date-alt",
        locale: "vn",
        allowInput: false,
        disableMobile: true
        });
        });

        const chartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels));
        const revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueLast7Days));
        const bookingData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.BookingLast7Days));

        const statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusLabels));
        const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusData));

        const commonGridColor = 'rgba(255, 255, 255, 0.08)';
        const commonTextColor = '#a7a7a7';

        const revenueCtx = document.getElementById('revenueChart');

        if (revenueCtx) {
        new Chart(revenueCtx, {
        type: 'line',
        data: {
        labels: chartLabels,
        datasets: [
        {
        label: 'Doanh thu',
        data: revenueData,
        tension: 0.42,
        fill: true,
        borderWidth: 3,
        borderColor: '#ff5964',
        backgroundColor: 'rgba(229, 9, 20, 0.16)',
        pointRadius: 4,
        pointHoverRadius: 6,
        pointBackgroundColor: '#ff5964'
        },
        {
        label: 'Booking',
        data: bookingData,
        tension: 0.42,
        borderWidth: 2,
        borderColor: '#f59e0b',
        backgroundColor: 'rgba(245, 158, 11, 0.14)',
        pointRadius: 3,
        pointHoverRadius: 5,
        pointBackgroundColor: '#f59e0b',
        yAxisID: 'y1'
        }
        ]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
        mode: 'index',
        intersect: false
        },
        plugins: {
        legend: {
        labels: {
        color: commonTextColor,
        usePointStyle: true,
        boxWidth: 8,
        font: {
        weight: '700'
        }
        }
        },
        tooltip: {
        backgroundColor: 'rgba(15, 15, 18, 0.95)',
        borderColor: 'rgba(255,255,255,0.12)',
        borderWidth: 1,
        titleColor: '#fff',
        bodyColor: '#ddd',
        padding: 12,
        callbacks: {
        label: function (context) {
        if (context.dataset.label === 'Doanh thu') {
        return ' Doanh thu: ' + Number(context.raw).toLocaleString('vi-VN') + ' VNĐ';
        }

        return ' Booking: ' + context.raw;
        }
        }
        }
        },
        scales: {
        x: {
        ticks: {
        color: commonTextColor
        },
        grid: {
        color: commonGridColor
        }
        },
        y: {
        beginAtZero: true,
        ticks: {
        color: commonTextColor,
        callback: function (value) {
        return Number(value).toLocaleString('vi-VN');
        }
        },
        grid: {
        color: commonGridColor
        }
        },
        y1: {
        beginAtZero: true,
        position: 'right',
        ticks: {
        color: commonTextColor,
        precision: 0
        },
        grid: {
        drawOnChartArea: false
        }
        }
        }
        }
        });
        }

        const statusCtx = document.getElementById('statusChart');

        if (statusCtx) {
        new Chart(statusCtx, {
        type: 'doughnut',
        data: {
        labels: statusLabels,
        datasets: [{
        data: statusData,
        borderWidth: 2,
        borderColor: '#151519',
        backgroundColor: [
        '#ffc94a',
        '#37d67a',
        '#ff5964'
        ],
        hoverOffset: 8
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '68%',
        plugins: {
        legend: {
        position: 'bottom',
        labels: {
        color: commonTextColor,
        usePointStyle: true,
        boxWidth: 8,
        padding: 18,
        font: {
        weight: '700'
        }
        }
        },
        tooltip: {
        backgroundColor: 'rgba(15, 15, 18, 0.95)',
        borderColor: 'rgba(255,255,255,0.12)',
        borderWidth: 1,
        titleColor: '#fff',
        bodyColor: '#ddd',
        padding: 12
        }
        }
        }
        });
        }

        document.addEventListener("DOMContentLoaded", function () {
        const cinemaInput = document.getElementById("cinemaIdInput");
        const cinemaText = document.getElementById("cinemaText");

        document.querySelectorAll(".cz-cinema-item").forEach(function (item) {
        item.addEventListener("click", function () {
        const cinemaId = this.dataset.cinemaId || "";
        const cinemaName = this.dataset.cinemaName || "Tất cả rạp";

        if (cinemaInput) {
        cinemaInput.value = cinemaId;
        }

        if (cinemaText) {
        cinemaText.textContent = cinemaName;
        }

        document.querySelectorAll(".cz-cinema-item").forEach(function (x) {
        x.classList.remove("active");
        });

        this.classList.add("active");
        });
        });
        });

    </script>
}