@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="password-page">
    <div class="password-hero">
        <div>
            <div class="password-eyebrow">
                <span class="material-symbols-outlined">lock_reset</span>
                CINEZONE SECURITY
            </div>

            <h1>Đổi mật khẩu</h1>
            <p>
                Cập nhật mật khẩu tài khoản để bảo vệ thông tin đặt vé, thanh toán và lịch sử giao dịch của bạn.
            </p>
        </div>

        <a asp-area="" asp-controller="Home" asp-action="Index" class="home-btn">
            <span class="material-symbols-outlined">home</span>
            Về trang chủ
        </a>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="password-layout">
        <section class="password-form-card">
            <div class="card-head">
                <div>
                    <h3>Thông tin mật khẩu</h3>
                    <p>Nhập mật khẩu hiện tại và mật khẩu mới của bạn.</p>
                </div>

                <span class="material-symbols-outlined">admin_panel_settings</span>
            </div>

            <form id="change-password-form" method="post" class="password-form">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="form-group mb-4">
                    <label asp-for="Input.OldPassword" class="form-label">
                        <span class="material-symbols-outlined">key</span>
                        Mật khẩu hiện tại
                    </label>

                    <div class="password-input-wrap">
                        <input asp-for="Input.OldPassword"
                               id="oldPasswordInput"
                               class="form-control cine-input"
                               type="password"
                               autocomplete="current-password"
                               aria-required="true"
                               placeholder="Nhập mật khẩu hiện tại" />

                        <button type="button"
                                class="password-toggle"
                                data-target="oldPasswordInput"
                                aria-label="Hiện hoặc ẩn mật khẩu">
                            <span class="material-symbols-outlined eye-icon">visibility</span>
                        </button>
                    </div>

                    <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Input.NewPassword" class="form-label">
                        <span class="material-symbols-outlined">lock</span>
                        Mật khẩu mới
                    </label>

                    <div class="password-input-wrap">
                        <input asp-for="Input.NewPassword"
                               id="newPasswordInput"
                               class="form-control cine-input"
                               type="password"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="Nhập mật khẩu mới" />

                        <button type="button"
                                class="password-toggle"
                                data-target="newPasswordInput"
                                aria-label="Hiện hoặc ẩn mật khẩu mới">
                            <span class="material-symbols-outlined eye-icon">visibility</span>
                        </button>
                    </div>

                    <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label">
                        <span class="material-symbols-outlined">verified_user</span>
                        Xác nhận mật khẩu mới
                    </label>

                    <div class="password-input-wrap">
                        <input asp-for="Input.ConfirmPassword"
                               id="confirmPasswordInput"
                               class="form-control cine-input"
                               type="password"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="Nhập lại mật khẩu mới" />

                        <button type="button"
                                class="password-toggle"
                                data-target="confirmPasswordInput"
                                aria-label="Hiện hoặc ẩn mật khẩu xác nhận">
                            <span class="material-symbols-outlined eye-icon">visibility</span>
                        </button>
                    </div>

                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="security-note mb-4">
                    <span class="material-symbols-outlined">shield</span>
                    <div>
                        <strong>Gợi ý bảo mật</strong>
                        <p>
                            Nên dùng mật khẩu có chữ hoa, chữ thường, số và ký tự đặc biệt. Không nên dùng lại mật khẩu cũ hoặc mật khẩu quá dễ đoán.
                        </p>
                    </div>
                </div>

                <button type="submit" class="submit-password-btn">
                    <span class="material-symbols-outlined">save</span>
                    Cập nhật mật khẩu
                </button>
            </form>
        </section>

        <aside class="password-side-card">
            <div class="security-icon">
                <span class="material-symbols-outlined">enhanced_encryption</span>
            </div>

            <h4>Bảo vệ tài khoản CineZone</h4>

            <p>
                Mật khẩu mạnh giúp bảo vệ lịch sử đặt vé, thông tin thanh toán và dữ liệu cá nhân của bạn.
            </p>

            <div class="security-list">
                <div>
                    <span class="material-symbols-outlined">check_circle</span>
                    Không chia sẻ mật khẩu cho người khác.
                </div>

                <div>
                    <span class="material-symbols-outlined">check_circle</span>
                    Đổi mật khẩu nếu nghi ngờ tài khoản bị lộ.
                </div>

                <div>
                    <span class="material-symbols-outlined">check_circle</span>
                    Đăng xuất khỏi thiết bị công cộng sau khi sử dụng.
                </div>
            </div>
        </aside>
    </div>
</div>

<style>
    .password-page {
        color: #fff;
        min-height: 100vh;
    }

    .password-hero {
        position: relative;
        overflow: hidden;
        padding: 36px;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.09);
        background: linear-gradient(90deg, rgba(0,0,0,0.84), rgba(0,0,0,0.48)), radial-gradient(circle at top right, rgba(229,9,20,0.35), transparent 34%), linear-gradient(135deg, #1b1b20, #09090b);
        box-shadow: 0 22px 60px rgba(0,0,0,0.35);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 22px;
        margin-bottom: 26px;
    }

    .password-eyebrow {
        color: #ff5964;
        font-size: 0.78rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 1.4px;
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 12px;
    }

    .password-hero h1 {
        font-size: clamp(2.3rem, 5vw, 4.2rem);
        font-weight: 950;
        letter-spacing: -0.065em;
        line-height: 1;
        margin-bottom: 12px;
    }

    .password-hero p {
        color: #aaa;
        max-width: 760px;
        line-height: 1.7;
        margin: 0;
    }

    .home-btn {
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        color: #fff;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.08);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 900;
        white-space: nowrap;
    }

        .home-btn:hover {
            color: #fff;
            background: rgba(255,255,255,0.14);
            transform: translateY(-2px);
        }

    .password-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 24px;
        align-items: start;
    }

    .password-form-card,
    .password-side-card {
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.09);
        background: rgba(18,18,22,0.94);
        box-shadow: 0 22px 60px rgba(0,0,0,0.30);
        overflow: hidden;
    }

    .card-head {
        padding: 22px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(135deg, rgba(255,255,255,0.055), rgba(255,255,255,0.015));
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 14px;
    }

        .card-head h3 {
            font-weight: 950;
            margin-bottom: 4px;
        }

        .card-head p {
            color: #999;
            margin: 0;
        }

        .card-head > span {
            color: #ff5964;
            font-size: 34px;
        }

    .password-form {
        padding: 26px;
    }

    .form-label {
        color: #ddd;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
    }

        .form-label span {
            color: #ff5964;
            font-size: 21px;
        }

    .password-input-wrap {
        position: relative;
    }

    .cine-input {
        min-height: 54px;
        border-radius: 17px;
        color: #fff;
        background-color: rgba(0,0,0,0.30);
        border: 1px solid rgba(255,255,255,0.12);
        padding: 0 58px 0 16px;
        font-weight: 750;
    }

        .cine-input::placeholder {
            color: #777;
        }

        .cine-input:focus {
            color: #fff;
            background-color: rgba(0,0,0,0.42);
            border-color: rgba(229,9,20,0.50);
            box-shadow: 0 0 0 0.2rem rgba(229,9,20,0.14);
        }

    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear {
        display: none;
    }

    .password-toggle {
        position: absolute;
        top: 50%;
        right: 14px;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: #9ca3af;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 20;
    }

        .password-toggle:hover {
            color: #fff;
            background: rgba(255,255,255,0.08);
        }

        .password-toggle .eye-icon {
            font-size: 22px;
            line-height: 1;
        }

        .security-note > span {
            color: #ffc94a;
            font-size: 26px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .security-note strong {
            color: #ffc94a;
            display: block;
            margin-bottom: 3px;
        }

        .security-note p {
            margin: 0;
            color: #bbb;
        }

    .submit-password-btn {
        width: 100%;
        min-height: 52px;
        border-radius: 999px;
        color: #fff;
        border: none;
        background: linear-gradient(135deg, #ff8a85 0%, #e50914 60%, #a9050d 100%);
        box-shadow: 0 14px 32px rgba(229,9,20,0.28);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 950;
    }

        .submit-password-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 42px rgba(229,9,20,0.38);
        }

    .password-side-card {
        position: sticky;
        top: 100px;
        padding: 26px;
    }

    .security-icon {
        width: 76px;
        height: 76px;
        border-radius: 24px;
        background: rgba(229,9,20,0.15);
        color: #ff5964;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 18px;
    }

        .security-icon span {
            font-size: 44px;
        }

    .password-side-card h4 {
        font-weight: 950;
        margin-bottom: 10px;
    }

    .password-side-card p {
        color: #aaa;
        line-height: 1.65;
        margin-bottom: 18px;
    }

    .security-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

        .security-list div {
            padding: 12px;
            border-radius: 16px;
            color: #ccc;
            background: rgba(255,255,255,0.045);
            border: 1px solid rgba(255,255,255,0.075);
            display: flex;
            align-items: flex-start;
            gap: 8px;
            line-height: 1.5;
        }

        .security-list span {
            color: #37d67a;
            font-size: 21px;
            flex-shrink: 0;
        }

    @@media (max-width: 991.98px) {
        .password-layout {
            grid-template-columns: 1fr;
        }

        .password-side-card {
            position: static;
        }
    }

    @@media (max-width: 575.98px) {
        .password-hero {
            flex-direction: column;
            padding: 24px;
        }

        .home-btn {
            width: 100%;
        }

        .password-form {
            padding: 20px;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".password-toggle").forEach(function (button) {
                button.addEventListener("click", function () {
                    const targetId = this.getAttribute("data-target");
                    const input = document.getElementById(targetId);
                    const icon = this.querySelector(".eye-icon");

                    if (!input || !icon) return;

                    if (input.type === "password") {
                        input.type = "text";
                        icon.textContent = "visibility_off";
                    } else {
                        input.type = "password";
                        icon.textContent = "visibility";
                    }
                });
            });
        });
    </script>
}