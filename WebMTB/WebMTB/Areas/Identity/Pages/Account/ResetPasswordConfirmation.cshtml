@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu thành công";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu thành công | CineZone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@900&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            :root {
                --cine-red: #e50914;
                --cine-green: #22c55e;
            }

            body, html {
                margin: 0;
                padding: 0;
                height: 100%;
                background-color: #000;
                font-family: 'Manrope', sans-serif;
                overflow: hidden;
            }

            .auth-page {
                position: fixed;
                inset: 0;
                z-index: 1;
            }

            .auth-bg {
                position: absolute;
                inset: 0;
                background-image: url('https://wallpaperaccess.com/full/329633.jpg');
                background-size: cover;
                background-position: center;
                filter: brightness(0.46);
                z-index: -2;
                transform: scale(1.05);
            }

            .auth-overlay {
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 50% 45%, rgba(34, 197, 94, 0.16), transparent 28%), radial-gradient(circle at 50% 55%, rgba(229, 9, 20, 0.14), transparent 34%), rgba(0, 0, 0, 0.38);
                z-index: -1;
            }

            .auth-card {
                background: rgba(0, 0, 0, 0.88);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.15);
                border-radius: 18px;
                width: 100%;
                max-width: 500px;
                box-shadow: 0 25px 50px rgba(0,0,0,0.8);
                z-index: 10;
                text-align: center;
            }

            .brand-font {
                font-family: 'Be Vietnam Pro', sans-serif;
                font-weight: 900;
                letter-spacing: 1px;
            }

            .success-icon {
                width: 88px;
                height: 88px;
                margin: 0 auto 20px;
                border-radius: 30px;
                background: radial-gradient(circle at top left, rgba(255,255,255,0.22), transparent 36%), linear-gradient(135deg, #7ee787 0%, #22c55e 60%, #15803d 100%);
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 18px 40px rgba(34, 197, 94, 0.30);
            }

                .success-icon i {
                    font-size: 3rem;
                }

            .auth-card h2 {
                color: #fff;
                font-weight: 900;
                letter-spacing: -0.8px;
            }

            .auth-card p {
                color: #aaa;
                line-height: 1.7;
            }

            .success-box {
                padding: 14px 15px;
                border-radius: 15px;
                background: rgba(34, 197, 94, 0.10);
                border: 1px solid rgba(34, 197, 94, 0.22);
                color: #d8ffe4;
                font-size: 0.9rem;
                line-height: 1.6;
                display: flex;
                gap: 10px;
                text-align: left;
            }

                .success-box i {
                    color: #22c55e;
                    font-size: 1.2rem;
                    margin-top: 2px;
                    flex-shrink: 0;
                }

            .btn-gradient {
                background: linear-gradient(135deg, #ffb4aa 0%, var(--cine-red) 100%);
                border: none;
                color: white;
                transition: 0.3s ease;
                border-radius: 999px;
                min-height: 48px;
                padding: 0 24px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                text-decoration: none;
                font-weight: 800;
                box-shadow: 0 14px 32px rgba(229, 9, 20, 0.28);
            }

                .btn-gradient:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 8px 20px rgba(229, 9, 20, 0.5);
                    color: white;
                }

            .btn-soft {
                color: #fff;
                border: 1px solid rgba(255,255,255,0.16);
                background: rgba(255,255,255,0.07);
                border-radius: 999px;
                min-height: 48px;
                padding: 0 22px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                text-decoration: none;
                font-weight: 800;
                transition: 0.2s ease;
            }

                .btn-soft:hover {
                    color: #fff;
                    background: rgba(255,255,255,0.13);
                    transform: translateY(-2px);
                }

            .action-row {
                display: flex;
                justify-content: center;
                gap: 10px;
                flex-wrap: wrap;
            }

            @@media (max-width: 575.98px) {
                body, html {
                    overflow: auto;
                }

                .auth-page {
                    position: relative;
                    min-height: 100vh;
                }

                .auth-card {
                    max-width: calc(100% - 28px);
                }

                .action-row {
                    flex-direction: column;
                }

                .btn-gradient,
                .btn-soft {
                    width: 100%;
                }
            }
    </style>
</head>

<body>
    <div class="auth-page">
        <div class="auth-bg"></div>
        <div class="auth-overlay"></div>

        <div class="container d-flex align-items-center justify-content-center min-vh-100">
            <div class="auth-card p-4 p-md-5">
                <h1 class="brand-font text-danger fs-1 mb-3">CineZone</h1>

                <div class="success-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>

                <h2 class="mb-3">Đặt lại mật khẩu thành công</h2>

                <p class="mb-4">
                    Mật khẩu tài khoản của bạn đã được cập nhật. Bây giờ bạn có thể đăng nhập lại bằng mật khẩu mới.
                </p>

                <div class="success-box mb-4">
                    <i class="bi bi-shield-check"></i>
                    <div>
                        Vì lý do bảo mật, hãy đăng nhập lại và không chia sẻ mật khẩu mới cho người khác.
                    </div>
                </div>

                <div class="action-row">
                    <a asp-page="./Login" class="btn-gradient">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Đăng nhập ngay
                    </a>

                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn-soft">
                        <i class="bi bi-house-door-fill"></i>
                        Về trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>