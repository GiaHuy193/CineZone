@page
@model LockoutModel
@{
    Layout = null;
    ViewData["Title"] = "Tài khoản bị khóa";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tài khoản bị khóa | CineZone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@800;900&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            :root {
                --cine-red: #e50914;
                --cine-orange: #ff9f1c;
                --cine-dark: #101010;
            }

            body, html {
                margin: 0;
                padding: 0;
                min-height: 100%;
                background-color: #000;
                font-family: 'Manrope', sans-serif;
                color: #fff;
            }

            .lockout-page {
                position: relative;
                min-height: 100vh;
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 32px 18px;
            }

            .lockout-bg {
                position: absolute;
                inset: 0;
                background-image: url('https://wallpaperaccess.com/full/329633.jpg');
                background-size: cover;
                background-position: center;
                filter: brightness(0.42);
                transform: scale(1.05);
                z-index: 0;
            }

            .lockout-overlay {
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 50% 45%, rgba(255, 159, 28, 0.16), transparent 28%), radial-gradient(circle at 50% 55%, rgba(229, 9, 20, 0.16), transparent 32%), linear-gradient(180deg, rgba(0,0,0,0.22), rgba(0,0,0,0.86));
                z-index: 1;
            }

            .lockout-card {
                position: relative;
                z-index: 2;
                width: min(100%, 560px);
                padding: 42px;
                border-radius: 26px;
                background: rgba(0, 0, 0, 0.86);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255,255,255,0.14);
                box-shadow: 0 28px 80px rgba(0,0,0,0.75);
                text-align: center;
            }

            .brand-font {
                font-family: 'Be Vietnam Pro', sans-serif;
                font-weight: 900;
                letter-spacing: 1px;
            }

            .brand-title {
                color: var(--cine-red);
                font-size: 2rem;
                margin-bottom: 22px;
            }

            .lock-icon-wrap {
                width: 96px;
                height: 96px;
                margin: 0 auto 24px;
                border-radius: 30px;
                background: radial-gradient(circle at top left, rgba(255,255,255,0.18), transparent 36%), linear-gradient(135deg, #ffd166, #ff9f1c 48%, #e50914);
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 20px 42px rgba(255, 159, 28, 0.26);
            }

                .lock-icon-wrap i {
                    font-size: 3rem;
                    color: #fff;
                }

            .lockout-card h1 {
                font-size: clamp(2rem, 5vw, 3.2rem);
                font-weight: 900;
                letter-spacing: -1.4px;
                margin-bottom: 12px;
            }

            .lockout-card p {
                color: #b8b8b8;
                line-height: 1.7;
                margin-bottom: 26px;
            }

            .lockout-note {
                padding: 14px 16px;
                border-radius: 18px;
                background: rgba(255, 159, 28, 0.10);
                border: 1px solid rgba(255, 159, 28, 0.24);
                color: #ffe4b8;
                font-size: 0.92rem;
                line-height: 1.6;
                margin-bottom: 26px;
            }

            .lockout-actions {
                display: flex;
                justify-content: center;
                flex-wrap: wrap;
                gap: 12px;
            }

            .btn-cine-primary {
                min-height: 48px;
                padding: 0 22px;
                border-radius: 999px;
                color: #fff;
                border: none;
                background: linear-gradient(135deg, #ffb4aa 0%, var(--cine-red) 100%);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                font-weight: 800;
                text-decoration: none;
                box-shadow: 0 14px 32px rgba(229, 9, 20, 0.28);
                transition: 0.2s ease;
            }

                .btn-cine-primary:hover {
                    color: #fff;
                    transform: translateY(-2px);
                    box-shadow: 0 18px 42px rgba(229, 9, 20, 0.42);
                }

            .btn-cine-outline {
                min-height: 48px;
                padding: 0 22px;
                border-radius: 999px;
                color: #fff;
                border: 1px solid rgba(255,255,255,0.18);
                background: rgba(255,255,255,0.07);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                font-weight: 800;
                text-decoration: none;
                transition: 0.2s ease;
            }

                .btn-cine-outline:hover {
                    color: #fff;
                    background: rgba(255,255,255,0.13);
                    transform: translateY(-2px);
                }

            .mini-info {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 10px;
                margin-bottom: 26px;
            }

            .mini-info-item {
                padding: 12px;
                border-radius: 16px;
                background: rgba(255,255,255,0.045);
                border: 1px solid rgba(255,255,255,0.08);
                text-align: left;
            }

                .mini-info-item i {
                    color: var(--cine-orange);
                    margin-right: 6px;
                }

                .mini-info-item strong {
                    display: block;
                    color: #fff;
                    font-size: 0.88rem;
                    margin-bottom: 3px;
                }

                .mini-info-item span {
                    color: #999;
                    font-size: 0.8rem;
                }

            @@media (max-width: 575.98px) {
                .lockout-card {
                    padding: 30px 22px;
                    border-radius: 22px;
                }

                .mini-info {
                    grid-template-columns: 1fr;
                }

                .lockout-actions {
                    flex-direction: column;
                }

                .btn-cine-primary,
                .btn-cine-outline {
                    width: 100%;
                }
            }
    </style>
</head>

<body>
    <div class="lockout-page">
        <div class="lockout-bg"></div>
        <div class="lockout-overlay"></div>

        <div class="lockout-card">
            <div class="brand-font brand-title">CineZone</div>

            <div class="lock-icon-wrap">
                <i class="bi bi-lock-fill"></i>
            </div>

            <h1>Tài khoản bị khóa</h1>

            <p>
                Tài khoản này hiện đang bị khóa tạm thời. Vui lòng thử lại sau hoặc liên hệ quản trị viên nếu bạn cho rằng đây là nhầm lẫn.
            </p>

            <div class="mini-info">
                <div class="mini-info-item">
                    <strong><i class="bi bi-clock-fill"></i> Khóa tạm thời</strong>
                    <span>Hãy chờ một thời gian rồi đăng nhập lại.</span>
                </div>

                <div class="mini-info-item">
                    <strong><i class="bi bi-shield-exclamation"></i> Bảo mật</strong>
                    <span>Hệ thống khóa để bảo vệ tài khoản.</span>
                </div>
            </div>

            <div class="lockout-note">
                Nếu bạn nhập sai mật khẩu quá nhiều lần, hệ thống có thể tự động khóa tài khoản để tránh truy cập bất thường.
            </div>

            <div class="lockout-actions">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn-cine-primary">
                    <i class="bi bi-house-door-fill"></i>
                    Về trang chủ
                </a>

                <a asp-page="./Login" class="btn-cine-outline">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Thử đăng nhập lại
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>