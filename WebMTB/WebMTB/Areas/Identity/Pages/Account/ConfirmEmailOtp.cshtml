@page
@model ConfirmEmailOtpModel
@{
    Layout = null;
    ViewData["Title"] = "Xác thực OTP";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Xác thực OTP | CineZone</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-dark text-white">
    <div class="container min-vh-100 d-flex align-items-center justify-content-center">
        <div class="card bg-black text-white border-danger p-4 rounded-4" style="max-width:460px;width:100%;">
            <h2 class="fw-bold text-danger text-center mb-3">CineZone</h2>
            <h4 class="fw-bold text-center">Nhập mã OTP</h4>

            <p class="text-secondary text-center">
                Mã OTP đã được gửi đến email của bạn.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert alert-success">@Model.StatusMessage</div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <input asp-for="Input.Email" type="hidden" />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input value="@Model.Input.Email" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.OtpCode" class="form-label">Mã OTP</label>
                    <input asp-for="Input.OtpCode"
                           maxlength="6"
                           class="form-control text-center fs-3 fw-bold"
                           placeholder="000000" />
                    <span asp-validation-for="Input.OtpCode" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 fw-bold py-2">
                    Xác thực tài khoản
                </button>

                <button type="submit"
                        asp-page-handler="Resend"
                        class="btn btn-outline-light w-100 fw-bold py-2 mt-3">
                    Gửi lại mã OTP
                </button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>