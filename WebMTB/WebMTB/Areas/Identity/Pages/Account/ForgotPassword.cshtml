@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu | CineZone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@900&family=Manrope:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            :root {
                --cine-red: #e50914;
                --cine-red-2: #ff5964;
                --cine-dark: #070708;
                --cine-card: rgba(12, 12, 15, 0.88);
            }

            * {
                box-sizing: border-box;
            }

            html,
            body {
                margin: 0;
                min-height: 100%;
                background: #050506;
                font-family: 'Manrope', sans-serif;
                color: #fff;
                overflow-x: hidden;
            }

            .cz-auth-page {
                position: relative;
                min-height: 100svh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 94px 20px 52px;
                overflow: hidden;
                isolation: isolate;
                background: radial-gradient(circle at 18% 24%, rgba(229, 9, 20, 0.34), transparent 28%), radial-gradient(circle at 82% 18%, rgba(255, 255, 255, 0.08), transparent 26%), linear-gradient(135deg, #070708 0%, #111114 48%, #050505 100%);
            }

            .cz-auth-bg {
                position: absolute;
                inset: 0;
                z-index: -4;
                background-image: url('https://wallpaperaccess.com/full/329633.jpg');
                background-size: cover;
                background-position: center;
                opacity: 0.48;
                filter: brightness(0.56) saturate(1.08);
                transform: scale(1.04);
                animation: czBgDrift 18s ease-in-out infinite alternate;
            }

            .cz-auth-page::before {
                content: "";
                position: absolute;
                inset: 0;
                z-index: -3;
                background: linear-gradient(90deg, rgba(0,0,0,0.82), rgba(0,0,0,0.38), rgba(0,0,0,0.84)), radial-gradient(circle at 50% 40%, rgba(229,9,20,0.22), transparent 34%);
            }

            .cz-auth-page::after {
                content: "";
                position: absolute;
                inset: 0;
                z-index: -2;
                opacity: 0.22;
                background-image: linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
                background-size: 46px 46px;
                mask-image: linear-gradient(to bottom, transparent, #000 18%, #000 82%, transparent);
            }

            .cz-light-orb {
                position: absolute;
                width: 480px;
                height: 480px;
                border-radius: 999px;
                background: rgba(229,9,20,0.22);
                filter: blur(90px);
                z-index: -1;
                animation: czOrbMove 8s ease-in-out infinite alternate;
            }

                .cz-light-orb.orb-1 {
                    left: -140px;
                    top: 10%;
                }

                .cz-light-orb.orb-2 {
                    right: -160px;
                    bottom: 8%;
                    background: rgba(255,89,100,0.16);
                    animation-delay: 1.2s;
                }

            .cz-auth-shell {
                width: min(1080px, 100%);
                display: grid;
                grid-template-columns: 0.95fr 1fr;
                gap: 28px;
                align-items: center;
                position: relative;
                z-index: 3;
            }

            .cz-showcase {
                position: relative;
                min-height: 500px;
                padding: 34px;
                border-radius: 34px;
                overflow: hidden;
                border: 1px solid rgba(255,255,255,0.12);
                background: radial-gradient(circle at 18% 20%, rgba(229,9,20,0.30), transparent 34%), linear-gradient(145deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
                box-shadow: 0 28px 80px rgba(0,0,0,0.45);
                animation: czPanelInLeft 0.75s cubic-bezier(.2,.9,.2,1) both;
            }

                .cz-showcase::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background-image: url('https://wallpaperaccess.com/full/329633.jpg');
                    background-size: cover;
                    background-position: center;
                    opacity: 0.28;
                    filter: brightness(0.76) saturate(1.15);
                    transform: scale(1.05);
                }

                .cz-showcase::after {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(to top, rgba(0,0,0,0.82), transparent 72%), linear-gradient(115deg, rgba(229,9,20,0.52), transparent 54%);
                }

            .cz-showcase-content {
                position: relative;
                z-index: 3;
                height: 100%;
                min-height: 430px;
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
            }

            .cz-chip {
                width: fit-content;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 10px 14px;
                border-radius: 999px;
                color: #fff;
                background: rgba(229,9,20,0.76);
                border: 1px solid rgba(255,255,255,0.16);
                font-size: 0.78rem;
                font-weight: 950;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 18px;
                backdrop-filter: blur(10px);
            }

            .cz-showcase-title {
                font-family: 'Be Vietnam Pro', sans-serif;
                font-weight: 900;
                letter-spacing: -0.07em;
                line-height: 0.94;
                font-size: clamp(2.75rem, 5.4vw, 5.5rem);
                margin-bottom: 18px;
                text-shadow: 0 12px 38px rgba(0,0,0,0.78);
            }

                .cz-showcase-title span {
                    color: #ff2632;
                    display: block;
                }

            .cz-showcase-desc {
                max-width: 520px;
                color: rgba(255,255,255,0.82);
                font-size: 1rem;
                line-height: 1.75;
                margin-bottom: 22px;
            }

            .cz-feature-row {
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
            }

            .cz-feature-pill {
                min-height: 42px;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 0 14px;
                border-radius: 999px;
                color: #fff;
                background: rgba(255,255,255,0.09);
                border: 1px solid rgba(255,255,255,0.12);
                font-size: 0.84rem;
                font-weight: 850;
                backdrop-filter: blur(12px);
            }

                .cz-feature-pill i {
                    color: var(--cine-red-2);
                }

            .movie-float-card {
                position: absolute;
                z-index: 2;
                width: 108px;
                height: 150px;
                border-radius: 22px;
                overflow: hidden;
                border: 1px solid rgba(255,255,255,0.18);
                box-shadow: 0 18px 48px rgba(0,0,0,0.48);
                background: #111;
            }

                .movie-float-card img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    filter: brightness(0.88) saturate(1.08);
                }

                .movie-float-card.card-1 {
                    top: 42px;
                    right: 56px;
                    transform: rotate(8deg);
                    animation: czFloatOne 4.5s ease-in-out infinite alternate;
                }

                .movie-float-card.card-2 {
                    right: 150px;
                    bottom: 76px;
                    transform: rotate(-9deg);
                    animation: czFloatTwo 4.2s ease-in-out infinite alternate;
                }

                .movie-float-card.card-3 {
                    top: 225px;
                    right: 8px;
                    transform: rotate(11deg);
                    animation: czFloatThree 4.8s ease-in-out infinite alternate;
                }

            .cz-form-panel {
                position: relative;
                border-radius: 34px;
                padding: 34px;
                min-height: 500px;
                display: flex;
                align-items: center;
                background: radial-gradient(circle at 88% 12%, rgba(229,9,20,0.22), transparent 34%), rgba(8,8,11,0.88);
                border: 1px solid rgba(255,255,255,0.13);
                box-shadow: 0 30px 90px rgba(0,0,0,0.52);
                backdrop-filter: blur(18px);
                overflow: hidden;
                animation: czPanelInRight 0.75s cubic-bezier(.2,.9,.2,1) both;
            }

                .cz-form-panel::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(115deg, transparent 0%, rgba(255,255,255,0.08) 45%, transparent 62%);
                    transform: translateX(-120%);
                    animation: czShine 5.2s ease-in-out infinite;
                    pointer-events: none;
                }

            .cz-form-card {
                position: relative;
                z-index: 2;
                width: 100%;
            }

            .cz-brand {
                font-family: 'Be Vietnam Pro', sans-serif;
                font-weight: 900;
                letter-spacing: -0.06em;
                color: #ff2632;
                font-size: 2.45rem;
                line-height: 1;
                margin-bottom: 22px;
                text-shadow: 0 0 28px rgba(229,9,20,0.35);
            }

            .cz-form-card h2 {
                font-weight: 950;
                letter-spacing: -0.05em;
                font-size: 2.05rem;
                margin-bottom: 10px;
            }

            .cz-form-card .sub-text {
                color: #9a9aa2;
                line-height: 1.65;
                margin-bottom: 28px;
            }

            .form-label {
                color: #a6a6ad;
                font-weight: 900;
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.02em;
                margin-bottom: 8px;
            }

            .cz-input {
                min-height: 54px;
                color: #fff !important;
                background: rgba(255,255,255,0.10) !important;
                border: 1px solid rgba(255,255,255,0.12) !important;
                border-radius: 18px !important;
                padding: 0 18px !important;
                font-weight: 760;
                transition: 0.24s ease;
            }

                .cz-input::placeholder {
                    color: #85858d;
                }

                .cz-input:focus {
                    background: rgba(255,255,255,0.14) !important;
                    border-color: rgba(229,9,20,0.72) !important;
                    box-shadow: 0 0 0 4px rgba(229,9,20,0.15) !important;
                }

            .info-box {
                display: flex;
                gap: 12px;
                padding: 14px 15px;
                border-radius: 18px;
                background: rgba(255, 193, 7, 0.08);
                border: 1px solid rgba(255, 193, 7, 0.18);
                color: #d4d4da;
                line-height: 1.58;
                font-size: 0.9rem;
                margin: 18px 0 24px;
            }

                .info-box i {
                    color: #ffc94a;
                    font-size: 1.25rem;
                    margin-top: 2px;
                    flex-shrink: 0;
                }

            .cz-submit {
                min-height: 54px;
                border: none;
                border-radius: 18px;
                color: #fff;
                width: 100%;
                font-weight: 950;
                letter-spacing: 0.02em;
                background: linear-gradient(135deg, #ff9f99 0%, #e50914 70%, #a9040d 100%);
                box-shadow: 0 18px 42px rgba(229,9,20,0.32);
                transition: 0.24s ease;
                position: relative;
                overflow: hidden;
            }

                .cz-submit::after {
                    content: "";
                    position: absolute;
                    top: 0;
                    left: -100px;
                    width: 80px;
                    height: 100%;
                    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55), transparent);
                    transform: skewX(-22deg);
                    animation: czButtonSweep 2.6s ease-in-out infinite;
                }

                .cz-submit:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 24px 58px rgba(229,9,20,0.48);
                }

                .cz-submit:disabled {
                    opacity: 0.78;
                    cursor: not-allowed;
                    transform: none;
                    box-shadow: none;
                }

            .cz-bottom-link {
                margin-top: 26px;
                padding-top: 22px;
                border-top: 1px solid rgba(255,255,255,0.10);
                text-align: center;
                color: #8e8e96;
                font-size: 0.92rem;
            }

                .cz-bottom-link a {
                    color: #fff;
                    font-weight: 950;
                    text-decoration: none;
                }

                    .cz-bottom-link a:hover {
                        color: var(--cine-red-2);
                    }

            @@keyframes czBgDrift {
                from {
                    transform: scale(1.04) translate3d(-8px, -6px, 0);
                }

                to {
                    transform: scale(1.08) translate3d(10px, 8px, 0);
                }
            }

            @@keyframes czOrbMove {
                from {
                    transform: translate3d(0, 0, 0) scale(1);
                    opacity: 0.65;
                }

                to {
                    transform: translate3d(42px, 24px, 0) scale(1.12);
                    opacity: 0.95;
                }
            }

            @@keyframes czFloatOne {
                from {
                    translate: 0 0;
                }

                to {
                    translate: 0 -18px;
                }
            }

            @@keyframes czFloatTwo {
                from {
                    translate: 0 0;
                }

                to {
                    translate: -10px 16px;
                }
            }

            @@keyframes czFloatThree {
                from {
                    translate: 0 0;
                }

                to {
                    translate: 12px -14px;
                }
            }

            @@keyframes czPanelInLeft {
                from {
                    opacity: 0;
                    transform: translateX(-34px) scale(0.98);
                }

                to {
                    opacity: 1;
                    transform: translateX(0) scale(1);
                }
            }

            @@keyframes czPanelInRight {
                from {
                    opacity: 0;
                    transform: translateX(34px) scale(0.98);
                }

                to {
                    opacity: 1;
                    transform: translateX(0) scale(1);
                }
            }

            @@keyframes czShine {
                0%, 42% {
                    transform: translateX(-120%);
                    opacity: 0;
                }

                55% {
                    opacity: 0.65;
                }

                100% {
                    transform: translateX(120%);
                    opacity: 0;
                }
            }

            @@keyframes czButtonSweep {
                0% {
                    left: -100px;
                }

                45%, 100% {
                    left: calc(100% + 100px);
                }
            }

            @@media (max-width: 991.98px) {
                .cz-auth-page {
                    padding: 86px 18px 42px;
                    align-items: flex-start;
                }

                .cz-auth-shell {
                    grid-template-columns: 1fr;
                    width: min(560px, 100%);
                }

                .cz-showcase {
                    min-height: 310px;
                    padding: 26px;
                }

                .cz-showcase-content {
                    min-height: 260px;
                }

                .cz-showcase-title {
                    font-size: clamp(2.3rem, 8vw, 4rem);
                }

                .movie-float-card {
                    width: 82px;
                    height: 116px;
                }

                    .movie-float-card.card-1 {
                        top: 24px;
                        right: 24px;
                    }

                    .movie-float-card.card-2 {
                        right: 120px;
                        bottom: 28px;
                    }

                    .movie-float-card.card-3 {
                        display: none;
                    }

                .cz-form-panel {
                    min-height: auto;
                    padding: 28px;
                }
            }

            @@media (max-width: 575.98px) {
                .cz-auth-page {
                    padding: 28px 14px;
                }

                .cz-showcase {
                    display: none;
                }

                .cz-form-panel {
                    padding: 24px;
                    border-radius: 26px;
                }

                .cz-brand {
                    font-size: 2.1rem;
                }

                .cz-form-card h2 {
                    font-size: 1.8rem;
                }
            }
    </style>
</head>

<body>
    <main class="cz-auth-page">
        <div class="cz-auth-bg"></div>
        <div class="cz-light-orb orb-1"></div>
        <div class="cz-light-orb orb-2"></div>

        <div class="cz-auth-shell">
            <section class="cz-showcase">
                <div class="movie-float-card card-1">
                    <img src="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&w=500&auto=format&fit=crop" alt="Cinema" />
                </div>

                <div class="movie-float-card card-2">
                    <img src="https://images.unsplash.com/photo-1542204165-65bf26472b9b?q=80&w=500&auto=format&fit=crop" alt="Movie" />
                </div>

                <div class="movie-float-card card-3">
                    <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?q=80&w=500&auto=format&fit=crop" alt="Ticket" />
                </div>

                <div class="cz-showcase-content">
                    <div class="cz-chip">
                        <i class="bi bi-shield-lock-fill"></i>
                        Account Recovery
                    </div>

                    <h1 class="cz-showcase-title">
                        Back to
                        <span>movie night.</span>
                    </h1>

                    <p class="cz-showcase-desc">
                        Nhập email đã đăng ký để nhận liên kết đặt lại mật khẩu và tiếp tục hành trình đặt vé tại CineZone.
                    </p>

                    <div class="cz-feature-row">
                        <div class="cz-feature-pill">
                            <i class="bi bi-envelope-check-fill"></i>
                            Gửi qua email
                        </div>

                        <div class="cz-feature-pill">
                            <i class="bi bi-shield-check"></i>
                            Bảo mật tài khoản
                        </div>

                        <div class="cz-feature-pill">
                            <i class="bi bi-lightning-charge-fill"></i>
                            Nhanh chóng
                        </div>
                    </div>
                </div>
            </section>

            <section class="cz-form-panel">
                <div class="cz-form-card">
                    <div class="cz-brand">CineZone</div>

                    <h2>Quên mật khẩu?</h2>

                    <p class="sub-text">
                        Nhập địa chỉ email tài khoản của bạn. CineZone sẽ gửi liên kết đặt lại mật khẩu qua email.
                    </p>

                    <form method="post" id="forgotPasswordForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">
                                Địa chỉ email
                            </label>

                            <input asp-for="Input.Email"
                                   class="form-control cz-input"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="name@gmail.com" />

                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="info-box">
                            <i class="bi bi-info-circle-fill"></i>

                            <div>
                                Nếu email tồn tại trong hệ thống, bạn sẽ nhận được hướng dẫn đặt lại mật khẩu.
                                Hãy kiểm tra cả hộp thư spam.
                            </div>
                        </div>

                        <button type="submit"
                                id="forgotSubmit"
                                class="cz-submit">
                            Gửi liên kết đặt lại mật khẩu
                        </button>

                        <div class="cz-bottom-link">
                            Nhớ mật khẩu rồi?
                            <a asp-page="./Login">Đăng nhập ngay</a>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("forgotPasswordForm");
        const btn = document.getElementById("forgotSubmit");

        if (!form || !btn) {
        return;
        }

        form.addEventListener("submit", function () {
        if (window.jQuery && !$(form).valid()) {
        return;
        }

        btn.disabled = true;
        btn.innerHTML = `
        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
        Đang gửi email...
        `;
        });
        });
    </script>
</body>
</html>