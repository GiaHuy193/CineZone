@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Xác nhận thành công";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | CineZone</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@900&family=Manrope:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            body, html { margin: 0; padding: 0; height: 100%; background-color: #000; font-family: 'Manrope', sans-serif; overflow: hidden; }
            .auth-page { position: fixed; inset: 0; z-index: 1; }
        
            .auth-bg {
                position: absolute; inset: 0;
                background-image: url('https://assets.nflxext.com/ffe/siteui/vlv3/f841d4c7-10e1-40af-bca1-0746f37673ae/e3224b74-1b15-467b-8370-13d80327f394/VN-vi-20220502-popsignuptwoweeks-perspective_alpha_website_medium.jpg');
                background-size: cover; background-position: center;
                filter: brightness(0.5); z-index: -2;
                transform: scale(1.05); animation: slowZoom 20s linear infinite alternate;
            }

            .auth-overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.4); z-index: -1; }

            @@keyframes slowZoom { from { transform: scale(1.05); } to { transform: scale(1.15); } }

            .auth-card {
                background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(15px);
                border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 12px;
                width: 100%; max-width: 500px; box-shadow: 0 25px 50px rgba(0,0,0,0.8); z-index: 10;
            }

            .brand-font { font-family: 'Be Vietnam Pro', sans-serif; font-weight: 900; letter-spacing: 1px; }
        
            .btn-gradient {
                background: linear-gradient(135deg, #ffb4aa 0%, #e50914 100%);
                border: none; color: white; transition: 0.3s ease; border-radius: 6px;
            }
            .btn-gradient:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(229, 9, 20, 0.5); color: white; }
        
            .success-icon { font-size: 5rem; color: #28a745; text-shadow: 0 0 20px rgba(40, 167, 69, 0.4); animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
            @@keyframes popIn { 0% { transform: scale(0); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
    </style>
</head>
<body>

    <div class="auth-page">
        <div class="auth-bg"></div>
        <div class="auth-overlay"></div>

        <div class="container d-flex align-items-center justify-content-center min-vh-100">
            <div class="auth-card p-5 text-center">
                <h1 class="brand-font text-danger mb-4">CINEZONE</h1>
            
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill success-icon"></i>
                </div>
            
                <h2 class="text-white fw-bold mb-3">Xác thực thành công!</h2>
                <p class="text-secondary mb-5" style="font-size: 1.1rem;">
                    Tuyệt vời! Tài khoản của bạn đã được kích hoạt. Hãy chuẩn bị bắp rang bơ và tận hưởng thế giới điện ảnh ngay thôi.
                </p>
            
                <a asp-page="./Login" class="btn btn-gradient w-100 py-3 fw-bold fs-5">BẮT ĐẦU XEM PHIM</a>
            </div>
        </div>
    </div>

</body>
</html>