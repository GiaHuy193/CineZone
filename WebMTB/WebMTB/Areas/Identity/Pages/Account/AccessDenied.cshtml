@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Không có quyền truy cập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Không có quyền truy cập | CineZone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@800;900&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            :root {
                --cine-red: #e50914;
                --cine-red-soft: rgba(229, 9, 20, 0.18);
                --cine-dark: #101010;
            }

            body, html {
                margin: 0;
                padding: 0;
                min-height: 100%;
                background-color: #000;
                font-family: 'Manrope', sans-serif;
                color: #fff;
            }

            .access-page {
                position: relative;
                min-height: 100vh;
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 32px 18px;
            }

            .access-bg {
                position: absolute;
                inset: 0;
                background-image: url('https://wallpaperaccess.com/full/329633.jpg');
                background-size: cover;
                background-position: center;
                filter: brightness(0.45);
                transform: scale(1.05);
                z-index: 0;
            }

            .access-overlay {
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 50% 50%, rgba(229, 9, 20, 0.18), transparent 28%), linear-gradient(180deg, rgba(0,0,0,0.20), rgba(0,0,0,0.82));
                z-index: 1;
            }

            .access-card {
                position: relative;
                z-index: 2;
                width: min(100%, 560px);
                padding: 42px;
                border-radius: 26px;
                background: rgba(0, 0, 0, 0.86);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255,255,255,0.14);
                box-shadow: 0 28px 80px rgba(0,0,0,0.75);
                text-align: center;
            }

            .brand-font {
                font-family: 'Be Vietnam Pro', sans-serif;
                font-weight: 900;
                letter-spacing: 1px;
            }

            .brand-title {
                color: var(--cine-red);
                font-size: 2rem;
                margin-bottom: 22px;
            }

            .lock-icon-wrap {
                width: 96px;
                height: 96px;
                margin: 0 auto 24px;
                border-radius: 30px;
                background: radial-gradient(circle at top left, rgba(255,255,255,0.18), transparent 36%), linear-gradient(135deg, #ff8a85, #e50914 62%, #8f050b);
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 20px 42px rgba(229, 9, 20, 0.34);
            }

                .lock-icon-wrap i {
                    font-size: 3rem;
                    color: #fff;
                }

            .access-card h1 {
                font-size: clamp(2rem, 5vw, 3.2rem);
                font-weight: 900;
                letter-spacing: -1.4px;
                margin-bottom: 12px;
            }

            .access-card p {
                color: #b8b8b8;
                line-height: 1.7;
                margin-bottom: 26px;
            }

            .access-note {
                padding: 14px 16px;
                border-radius: 18px;
                background: rgba(229, 9, 20, 0.12);
                border: 1px solid rgba(229, 9, 20, 0.26);
                color: #ffd6d6;
                font-size: 0.92rem;
                line-height: 1.6;
                margin-bottom: 26px;
            }

            .access-actions {
                display: flex;
                justify-content: center;
                flex-wrap: wrap;
                gap: 12px;
            }

            .btn-cine-primary {
                min-height: 48px;
                padding: 0 22px;
                border-radius: 999px;
                color: #fff;
                border: none;
                background: linear-gradient(135deg, #ffb4aa 0%, var(--cine-red) 100%);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                font-weight: 800;
                text-decoration: none;
                box-shadow: 0 14px 32px rgba(229, 9, 20, 0.28);
                transition: 0.2s ease;
            }

                .btn-cine-primary:hover {
                    color: #fff;
                    transform: translateY(-2px);
                    box-shadow: 0 18px 42px rgba(229, 9, 20, 0.42);
                }

            .btn-cine-outline {
                min-height: 48px;
                padding: 0 22px;
                border-radius: 999px;
                color: #fff;
                border: 1px solid rgba(255,255,255,0.18);
                background: rgba(255,255,255,0.07);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                font-weight: 800;
                text-decoration: none;
                transition: 0.2s ease;
            }

                .btn-cine-outline:hover {
                    color: #fff;
                    background: rgba(255,255,255,0.13);
                    transform: translateY(-2px);
                }

            @@media (max-width: 575.98px) {
                .access-card {
                    padding: 30px 22px;
                    border-radius: 22px;
                }

                .access-actions {
                    flex-direction: column;
                }

                .btn-cine-primary,
                .btn-cine-outline {
                    width: 100%;
                }
            }
    </style>
</head>

<body>
    <div class="access-page">
        <div class="access-bg"></div>
        <div class="access-overlay"></div>

        <div class="access-card">
            <div class="brand-font brand-title">CineZone</div>

            <div class="lock-icon-wrap">
                <i class="bi bi-shield-lock-fill"></i>
            </div>

            <h1>Không có quyền truy cập</h1>

            <p>
                Tài khoản của bạn hiện không có quyền truy cập vào khu vực này.
                Có thể trang này chỉ dành cho quản trị viên hoặc tài khoản có vai trò phù hợp.
            </p>

            <div class="access-note">
                Nếu bạn cho rằng đây là nhầm lẫn, hãy đăng nhập bằng tài khoản admin hoặc liên hệ quản trị viên hệ thống.
            </div>

            <div class="access-actions">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn-cine-primary">
                    <i class="bi bi-house-door-fill"></i>
                    Về trang chủ
                </a>

                <a asp-page="./Login" class="btn-cine-outline">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Đăng nhập tài khoản khác
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>