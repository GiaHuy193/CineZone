@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập | CineZone</title>

    <!-- Fonts are loaded in layout; styles moved to site.css -->
</head>
<body>

<div class="auth-page">
    <div class="auth-bg"></div>
    <div class="auth-overlay"></div>

    <div class="container d-flex align-items-center justify-content-center min-vh-100">
        <div class="auth-card p-4 p-md-5">
            <div class="text-center mb-4">
                <h1 class="brand-font text-danger fs-1">CineZone</h1>
                <p class="text-secondary small">Chào mừng bạn quay trở lại!</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Email" class="form-label small fw-bold text-secondary">ĐỊA CHỈ EMAIL</label>
                    <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Password" class="form-label small fw-bold text-secondary">MẬT KHẨU</label>
                    <input asp-for="Input.Password" class="form-control auth-input" type="password" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input bg-dark border-secondary" asp-for="Input.RememberMe" />
                        <label class="form-check-label small text-secondary" asp-for="Input.RememberMe">Ghi nhớ tôi</label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="text-danger small text-decoration-none">Quên mật khẩu?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-gradient w-100 py-3 fw-bold mb-3">ĐĂNG NHẬP</button>

                <div class="text-center mt-4 pt-2 border-top border-secondary border-opacity-25">
                    <p class="text-secondary small mb-0">
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-white fw-bold text-decoration-none ms-1">Đăng ký ngay</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>