:root {
    --netflix-red: #E50914;
    --bg-dark: #141414;
    --bg-light-dark: #222222;
    --text-muted: #aaaaaa;
}

body {
    background-color: var(--bg-dark);
    color: white;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Ghi đè màu nền mặc định của ASP.NET Core */
.container-fluid {
    background-color: var(--bg-dark);
}

/* Nút bấm Custom */
.btn-netflix {
    background-color: var(--netflix-red);
    color: white;
    border-radius: 4px;
    font-weight: 500;
}

    .btn-netflix:hover {
        background-color: #f40612;
        color: white;
    }

.btn-outline-light {
    border-radius: 4px;
}

/* Section Hero (Phim nổi bật nhất) */
.hero-section {
    height: 75vh;
    /* Dùng ảnh placeholder tạm thời, sau này bạn gọi từ Database */
    background: linear-gradient(to top, var(--bg-dark) 0%, rgba(20,20,20,0.4) 50%, transparent 100%), url('https://images.unsplash.com/photo-1534447677768-be436bb09401?q=80&w=2094&auto=format&fit=crop') center/cover no-repeat;
    display: flex;
    align-items: flex-end;
    padding-bottom: 60px;
    border-radius: 10px;
    margin-top: 20px;
}

.hero-title {
    font-size: 4rem;
    font-weight: 900;
    text-transform: uppercase;
}

/* Thẻ Phim (Movie Cards) */
.movie-card {
    background-color: transparent;
    border: none;
    transition: transform 0.3s ease;
    cursor: pointer;
}

    .movie-card:hover {
        transform: scale(1.05); /* Hiệu ứng phình to giống Netflix */
    }

.movie-poster {
    border-radius: 8px;
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: cover;
}

.movie-title {
    font-size: 1rem;
    font-weight: bold;
    margin-top: 10px;
    margin-bottom: 2px;
}

.movie-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
}

/* Bento Box - Exclusive Experiences */
.experience-card {
    background-color: var(--bg-light-dark);
    border-radius: 12px;
    padding: 20px;
    height: 100%;
    background-blend-mode: overlay;
    background-size: cover;
    background-position: center;
}

/* Nav Pills Custom cho phần Now Showing */
.nav-pills .nav-link {
    color: white;
    border: 1px solid var(--text-muted);
    border-radius: 20px;
    padding: 5px 15px;
    margin-right: 10px;
}

    .nav-pills .nav-link.active {
        background-color: var(--netflix-red);
        border-color: var(--netflix-red);
    }
