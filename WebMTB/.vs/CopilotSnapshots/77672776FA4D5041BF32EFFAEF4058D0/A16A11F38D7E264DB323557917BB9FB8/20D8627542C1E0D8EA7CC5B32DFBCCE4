@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập | CineZone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@900&family=Manrope:wght@400;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --cine-red: #e50914;
            --cine-dark: #131313;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            background-color: #000;
            font-family: 'Manrope', sans-serif;
            overflow: hidden;
        }

        .auth-page {
            position: fixed;
            inset: 0;
            z-index: 1;
        }

        /* --- BACKGROUND RÕ NÉT --- */
        .auth-bg {
            position: absolute;
            inset: 0;
            /* Thay URL ảnh collage của bạn vào đây */
            background-image: url('https://wallpaperaccess.com/full/329633.jpg');
            background-size: cover;
            background-position: center;
            
            /* ĐÃ CHỈNH: Bỏ blur, tăng brightness để ảnh rõ nét và sáng */
            filter: brightness(0.6); 
            
            z-index: -2;
            transform: scale(1.05);
            animation: slowZoom 20s linear infinite alternate;
        }

        /* Lớp phủ tối nhẹ để làm dịu các chi tiết quá sắc cạnh của ảnh nền */
        .auth-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.3); /* Phủ một lớp đen 30% để nhìn rõ Form */
            z-index: -1;
        }

        @@keyframes slowZoom {
            from { transform: scale(1.05); }
            to { transform: scale(1.15); }
        }

        /* --- CARD ĐĂNG NHẬP --- */
        .auth-card {
            background: rgba(0, 0, 0, 0.88); /* Tăng độ đen để không bị lẫn vào nền rõ nét */
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 12px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.8);
            z-index: 10;
        }

        .auth-input {
            background-color: #333 !important;
            border: 1px solid transparent !important;
            color: white !important;
            padding: 12px 15px !important;
            border-radius: 6px !important;
        }

        .auth-input:focus {
            background-color: #444 !important;
            border-color: var(--cine-red) !important;
            box-shadow: 0 0 0 2px rgba(229, 9, 20, 0.3) !important;
        }

        .btn-gradient {
            background: linear-gradient(135deg, #ffb4aa 0%, var(--cine-red) 100%);
            border: none;
            color: white;
            transition: 0.3s ease;
            border-radius: 6px;
        }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(229, 9, 20, 0.5);
            color: white;
        }

        .brand-font {
            font-family: 'Be Vietnam Pro', sans-serif;
            font-weight: 900;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

<div class="auth-page">
    <div class="auth-bg"></div>
    <div class="auth-overlay"></div>

    <div class="container d-flex align-items-center justify-content-center min-vh-100">
        <div class="auth-card p-4 p-md-5">
            <div class="text-center mb-4">
                <h1 class="brand-font text-danger fs-1">CineZone</h1>
                <p class="text-secondary small">Chào mừng bạn quay trở lại!</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Email" class="form-label small fw-bold text-secondary">ĐỊA CHỈ EMAIL</label>
                    <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Password" class="form-label small fw-bold text-secondary">MẬT KHẨU</label>
                    <input asp-for="Input.Password" class="form-control auth-input" type="password" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input bg-dark border-secondary" asp-for="Input.RememberMe" />
                        <label class="form-check-label small text-secondary" asp-for="Input.RememberMe">Ghi nhớ tôi</label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="text-danger small text-decoration-none">Quên mật khẩu?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-gradient w-100 py-3 fw-bold mb-3">ĐĂNG NHẬP</button>

                <div class="text-center mt-4 pt-2 border-top border-secondary border-opacity-25">
                    <p class="text-secondary small mb-0">
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-white fw-bold text-decoration-none ms-1">Đăng ký ngay</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>