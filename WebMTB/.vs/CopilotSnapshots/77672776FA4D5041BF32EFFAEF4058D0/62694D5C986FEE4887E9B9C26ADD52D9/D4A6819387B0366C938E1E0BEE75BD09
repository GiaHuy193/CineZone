@model WebMTB.Models.Movie

@{
    ViewData["Title"] = "Chỉnh Sửa Phim";
}

<div class="container mt-5 pt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white brand-font m-0">Chỉnh Sửa: @Model.Title</h1>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill d-flex align-items-center">
            <span class="material-symbols-outlined fs-6 me-1">arrow_back</span> Quay lại danh sách
        </a>
    </div>

    <div class="card bg-dark text-white border-0 shadow-lg" style="background-color: #1a1d20 !important;">
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Tên Phim</label>
                            <input asp-for="Title" class="form-control custom-input" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả nội dung</label>
                            <textarea asp-for="Description" class="form-control custom-input" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Director" class="form-label fw-bold">Đạo diễn</label>
                                <input asp-for="Director" class="form-control custom-input" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Duration" class="form-label fw-bold">Thời lượng (Phút)</label>
                                <input asp-for="Duration" class="form-control custom-input" type="number" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Cast" class="form-label fw-bold">Diễn viên chính</label>
                            <input asp-for="Cast" class="form-control custom-input" />
                        </div>

                        <div class="mb-3 w-25">
                            <label asp-for="Rating" class="form-label fw-bold">Đánh giá (Sao)</label>
                            <input asp-for="Rating" class="form-control custom-input" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-bold">Đường dẫn ảnh Poster (URL)</label>
                            <input asp-for="ImageUrl" id="imageInput" class="form-control custom-input" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>

                            <div class="mt-3 rounded overflow-hidden d-flex align-items-center justify-content-center bg-black shadow-sm"
                                 style="aspect-ratio: 2/3; width: 100%; max-width: 280px; margin: 0 auto; position: relative; border: 1px solid rgba(255,255,255,0.1);">

                                <img id="imagePreview" src="@Model.ImageUrl" alt="Poster Preview"
                                     style="width: 100%; height: 100%; object-fit: cover; @(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")" />

                                <div id="previewPlaceholder" class="text-center text-secondary p-3" style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")">
                                    <span class="material-symbols-outlined d-block mb-2" style="font-size: 3.5rem;">image</span>
                                    <p class="small m-0">Chưa có ảnh</p>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TrailerUrl" class="form-label fw-bold">Đường dẫn Trailer (YouTube)</label>
                            <input asp-for="TrailerUrl" class="form-control custom-input" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="ReleaseDate" class="form-label fw-bold">Ngày khởi chiếu</label>
                            <input asp-for="ReleaseDate" class="form-control custom-input" type="date" />
                        </div>

                        <div class="p-3 rounded bg-black bg-opacity-25 mb-4" style="border: 1px solid rgba(255,255,255,0.1);">
                            <h6 class="text-secondary mb-3 border-bottom border-secondary pb-2">Thiết lập trạng thái</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" asp-for="IsHot" />
                                <label class="form-check-label" asp-for="IsHot">🔥 Phim Hot</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" asp-for="IsActive" />
                                <label class="form-check-label" asp-for="IsActive">🎬 Đang hiển thị</label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-gradient w-100 py-3 fw-bold fs-5 shadow-sm border-0">
                            <span class="material-symbols-outlined align-middle">save</span> CẬP NHẬT THAY ĐỔI
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            const $input = $('#imageInput');
            const $preview = $('#imagePreview');
            const $placeholder = $('#previewPlaceholder');

            function updatePreview() {
                const url = $input.val().trim();
                if (url !== "") {
                    $preview.attr('src', url).show();
                    $placeholder.hide();
                } else {
                    $preview.hide();
                    $placeholder.show();
                }
            }

            $input.on('input propertychange', function () {
                updatePreview();
            });

            $preview.on('error', function () {
                $(this).hide();
                $placeholder.show().html(
                    '<span class="material-symbols-outlined text-danger mb-2" style="font-size: 3.5rem;">broken_image</span>' +
                    '<p class="text-danger small">Link ảnh không hợp lệ!</p>'
                );
            });
        });
    </script>

    <style>
        /* Khử hoàn toàn lỗi vạch kẻ ngang */
        .card, .row, .col-md-8, .col-md-4 {
            border: none !important;
        }

        .custom-input {
            background-color: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: white !important;
        }

            .custom-input:focus {
                background-color: rgba(255, 255, 255, 0.1) !important;
                border-color: #00d4ff !important;
                box-shadow: none !important;
            }

        .btn-gradient {
            background: linear-gradient(45deg, #007bff, #00d4ff);
            color: white;
            transition: all 0.3s ease;
        }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0, 123, 255, 0.4);
                color: white;
            }

        .brand-font {
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: bold;
        }
    </style>
}