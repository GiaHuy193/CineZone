@{
    var title = ViewData["Title"] ?? "WebMTB";
}
<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - CineZone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebMTB.styles.css" asp-append-version="true" />

    <style>
        :root {
            --bs-body-bg: #131313;
            --bs-body-color: #e5e2e1;
            --cine-red: #e50914;
            --cine-surface: #1c1b1b;
            --cine-surface-high: #2a2a2a;
        }
        body { font-family: 'Manrope', sans-serif; background-color: var(--bs-body-bg); color: var(--bs-body-color); }
        h1,h2,h3,h4,h5,.brand-font { font-family: 'Be Vietnam Pro', sans-serif; font-weight: 800; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
        .glass-nav { background: rgba(19, 19, 19, 0.85); backdrop-filter: blur(15px); border-bottom: 1px solid rgba(255,255,255,0.05); }
        .btn-gradient { background: linear-gradient(135deg, #ffb4aa 0%, var(--cine-red) 100%); color: white; border: none; }
        .btn-gradient:hover { transform: scale(1.02); box-shadow: 0 8px 16px rgba(229,9,20,0.18); color: white; }
        .brand-font { letter-spacing: .5px; }
        .navbar .nav-link.text-secondary:hover, .hover-white:hover { color: #fff !important; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top glass-nav py-3 px-4 px-lg-5">
            <div class="container-fluid">
                <a class="navbar-brand brand-font text-danger fs-3 fst-italic tracking-tight" asp-area="" asp-controller="Home" asp-action="Index">CineZone</a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="material-symbols-outlined text-white">menu</span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-semibold brand-font">
                        <li class="nav-item"><a class="nav-link text-white border-bottom border-danger border-2 px-3" asp-area="" asp-controller="Home" asp-action="Index">Phim</a></li>
                        <li class="nav-item"><a class="nav-link text-secondary px-3" href="#">Cụm Rạp</a></li>
                        <li class="nav-item"><a class="nav-link text-secondary px-3" href="#">Khuyến Mãi</a></li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0" style="padding-top:86px;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="py-4" style="background-color:#0e0e0e; border-top:1px solid #222;">
        <div class="container-fluid p-0 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div>
                <span class="fs-5 fw-bold text-white brand-font">WEB-MTB</span>
                <p class="text-secondary small mb-0 mt-2">© 2026 WebMTB. Hệ thống đặt vé xem phim.</p>
            </div>
            <div class="d-flex gap-4">
                <a href="#" class="text-secondary text-decoration-none hover-white">Điều khoản</a>
                <a href="#" class="text-secondary text-decoration-none hover-white">Bảo mật</a>
                <a href="#" class="text-secondary text-decoration-none hover-white">Liên hệ</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
